  unit             String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, panelId, analyte])
  @@unique([tenantId, id])
  @@index([tenantId, importBatchId])
  @@index([tenantId])
  @@map("migration_analysis_reading")
}

model MigrationReconciliationItem {
  tenantId        String    @default("")
  id              String    @id @default(cuid())
  importBatchId   String
  kind            String
  subjectType     String
  subjectKey      String
  label           String
  expectedValue   Decimal?  @db.Decimal(18, 6)
