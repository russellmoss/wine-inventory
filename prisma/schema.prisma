// Bhutan Wine Company — Prisma schema (Prisma 6, Neon Postgres)
// Auth models (User/Session/Account/Verification) are owned by Better Auth
// (generated via its CLI). Domain + audit models follow.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ───────────────────────── Auth (Better Auth) ─────────────────────────

model User {
  id                     String                  @id
  name                   String
  email                  String
  emailVerified          Boolean                 @default(false)
  image                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  role                   String?
  banned                 Boolean?                @default(false)
  banReason              String?
  banExpires             DateTime?
  mustChangePassword     Boolean?                @default(false)
  passwordChangedAt      DateTime?
  sessions               Session[]
  accounts               Account[]
  fieldNotes             FieldNote[]
  assistantConversations AssistantConversation[]
  voiceProfiles          VoiceProfile[]
  voicePreferences       VoicePreference[]
  // Phase 5 (D9): vineyard MEMBERSHIP set — replaced the single assignedVineyardId column
  // (dropped in migration 20260629000300 after the backfill was verified).
  vineyardMemberships    UserVineyard[]
  // Phase 12 multi-tenancy (K2): org memberships (user↔org join, multi-org capable) + invites sent.
  memberships            Member[]
  sentInvitations        Invitation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy       String?
  // Multi-tenancy (K2): the tenant the session is currently acting in. Set by the Better Auth
  // organization plugin on login (see auth.ts session hook); re-validated against `member` each
  // request in getCurrentUser (K13). Plain string, no FK — matches the plugin's schema.
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ───────────────────────── Organizations = tenants (Phase 12) ─────────────────────────
// The Organization IS the tenant (K2). These + the auth core (User/Session/Account/Verification)
// stay GLOBAL — no tenantId, no RLS, and on the Prisma-extension DENYLIST (U8) — because Better
// Auth queries them during login, BEFORE a tenant is known. A user is a global identity with
// org memberships. Hand-authored to match the Better Auth organization plugin schema (v1.6.x):
// member = user↔org join (multi-org capable); active org lives on session.activeOrganizationId.

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  logo        String?
  metadata    String? // Better Auth stores org metadata as a JSON string here
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?    @updatedAt
  members     Member[]
  invitations Invitation[]

  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("member") // owner | admin | member (org-level)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId]) // a user is a member of an org at most once
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String? // invited org role
  status         String       @default("pending") // pending | accepted | rejected | canceled
  expiresAt      DateTime?
  inviterId      String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([inviterId])
  @@map("invitation")
}

// ───────────────────────── Enums ─────────────────────────

enum VesselType {
  BARREL
  TANK
}

enum ItemKind {
  BOTTLED_WINE
  FINISHED_GOOD
}

enum MovementKind {
  RECEIVE
  ADJUST
  TRANSFER
  // Phase 16 (Commerce7 DTC): a settled DTC/club/POS sale depletes finished goods. Added in an
  // ISOLATED ALTER TYPE migration (Windows enum rule) BEFORE any column defaults to it.
  SALE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  PASSWORD_RESET
  PASSWORD_CHANGE
  USER_CREATED
  USER_DELETED
  BOTTLING
  STOCK_MOVEMENT
  FIELD_NOTE_CREATED
  FIELD_INPUT_CREATED
  USER_VINEYARD_ASSIGNED
  BRIX_LOGGED
  HARVEST_ESTIMATED
  HARVEST_PICK_RECORDED
  // Phase 4 sample lifecycle (added in a dedicated ALTER TYPE migration — a new enum
  // VALUE can't be used in the transaction that adds it). Panel/tasting create+void
  // reuse CREATE/DELETE.
  SAMPLE_PULLED
  SAMPLE_SENT
  SAMPLE_ATTACHED
  SAMPLE_CANCELLED
  IMPERSONATE
}

enum FeedbackAutomationMode {
  REPORT_ONLY
  PLAN_MODE
  AGENTIC_FIX
}

enum FeedbackTicketKind {
  BUG_REPORT
  FEATURE_REQUEST
}

enum FeedbackSeverity {
  P0
  P1
  P2
}

enum FeedbackItemStatus {
  NEW
  TRIAGED
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum FeedbackAutomationStatus {
  NOT_REQUESTED
  AWAITING_APPROVAL
  QUEUED
  RUNNING
  PLANNED
  PR_OPENED
  FAILED
  SKIPPED
  AWAITING_CLARIFICATION // Plan 079: parked waiting on the reporter's answer to a clarification DM
}

// Plan 079: lifecycle of one clarification round asked of a bug reporter.
enum FeedbackClarificationStatus {
  OPEN
  ANSWERED
  CANCELLED
}

enum FeedbackAttachmentCaptureSource {
  AUTO_SCREENSHOT
  MANUAL_UPLOAD
}

enum FeedbackAutomationSource {
  ASSISTANT_FEEDBACK
  FEEDBACK_TICKET
}

enum FeedbackAutomationKind {
  PLAN
  AGENTIC_FIX
}

// The triaged DISPOSITION — what KIND of problem an item is, assigned by the bug-triage goalie
// from root cause (NOT the reporter's intake kind). Decides which workflow the item belongs in.
// Nullable on the models: an untriaged item has no disposition yet. Mirror of the skill's `type`.
enum FeedbackTriageClass {
  DEFECT // real code bug with a concrete lever → auto-fix (in-fence) / human (out-of-fence)
  MODEL_BEHAVIOR // LLM/assistant adherence miss; prompt/eval mitigation, recurrence expected
  PRODUCT_GAP // missing capability / unmodeled path / design decision → /plan or /office-hours
  NOT_A_BUG // works-as-designed / user-error / permissions / empty-state → dismiss
  UNCLEAR // needs /investigate
}

enum VoiceProfileStatus {
  ACTIVE
  DISABLED
  NEEDS_REENROLL
}

enum VoiceProfileProvider {
  LOCAL_VOICEPRINT
  VENDOR_REF
}

enum VoiceFocusDefaultMode {
  OPEN
  MY_VOICE
  TEAM_SESSION
}

// ───────────────────────── Shared registries ─────────────────────────

model Location {
  tenantId              String                  @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id                    String                  @id @default(cuid())
  name                  String
  isSystem              Boolean                 @default(false) // "Winery" = true
  isActive              Boolean                 @default(true)
  kind                  String? // plan 053 B9: classification (cellar/warehouse/crush_pad/lab/bottling/external/other); validated string, nullable = unclassified
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  bottledInventory      BottledInventory[]
  finishedGoodInventory FinishedGoodInventory[]
  stockMovements        StockMovement[]
  bottlingRuns          BottlingRun[]
  bottledLotStates      BottledLotState[] // Phase 7: en-tirage bottle lots physically stored here

  @@unique([tenantId, name])
  // Plan 080 U13a: composite-tenant-FK target (K11). supply_lot + material_movement reference a Location,
  // which is a cross-tenant-risk FK (Phase-12 checklist step 5) — without this unique those FKs can only be
  // simple `-> location(id)`, which does NOT stop a lot in tenant B pointing at tenant A's location.
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("location")
}

// Berry (skin) color of the fruit — the winemaker's "black or white". NOT the map
// display color; that is `Variety.color` (a hex string) and the two are unrelated.
enum BerryColor {
  BLACK
  WHITE
}

// Vine species grouping. OTHER is the deliberate escape hatch (e.g. rupestris,
// riparia) so the closed set never blocks recording a variety.
enum VineSpecies {
  VINIFERA
  HYBRID
  OTHER
}

model Variety {
  tenantId        String            @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id              String            @id @default(cuid())
  name            String
  abbreviation    String? // 2–4 uppercase code for lot codes (PN, CS). Nullable→backfilled; Postgres unique allows multiple NULLs.
  isActive        Boolean           @default(true)
  color           String? // canonical per-variety map color (hex), consistent across vineyards
  // Optional REFERENCE/presentation attributes (ticket #308). Descriptive only: they
  // are never part of variety identity (name + abbreviation), never feed a lot code,
  // and are not read by the ledger/cost/compliance paths. All nullable so every
  // pre-existing variety keeps its exact historical shape — NAMING-2 provenance.
  clone           String? // e.g. "Dijon 115", "FPS 04"
  rootstock       String? // e.g. "101-14", "3309C", "own-rooted"
  nursery         String? // source nursery the vine material came from
  berryColor      BerryColor? // black or white — see BerryColor, distinct from `color`
  species         VineSpecies?
  createdAt       DateTime          @default(now())
  components      VesselComponent[]
  bottlingSources BottlingSource[]
  vineyardBlocks  VineyardBlock[]

  @@unique([tenantId, name])
  @@unique([tenantId, abbreviation])
  @@index([tenantId])
  @@map("variety")
}

model Vineyard {
  tenantId        String            @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id              String            @id @default(cuid())
  name            String
  abbreviation    String? // 2–4 uppercase code for lot codes (GS, NT). Nullable→backfilled; Postgres unique allows multiple NULLs.
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  components      VesselComponent[]
  bottlingSources BottlingSource[]
  detail          VineyardDetail?
  blocks          VineyardBlock[]
  fieldNotes      FieldNote[]
  brixLogs        BrixLog[]
  harvestRecords  HarvestRecord[]
  // Phase 5.
  lotMemberships  LotVineyard[] // lots whose source set includes this vineyard
  userMemberships UserVineyard[] // users who manage this vineyard (D9 membership set)

  @@unique([tenantId, name])
  @@unique([tenantId, abbreviation])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("vineyard")
}

// ───────────────────────── Vineyard details + blocks ─────────────────────────

// Sparse, optional per-vineyard metadata (1:1 with Vineyard, created lazily).
// Spacing/elevation are stored canonically in METRIC; the UI converts for display.
model VineyardDetail {
  tenantId    String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id          String   @id @default(cuid())
  vineyardId  String   @unique
  gpsLat      Decimal? @db.Decimal(9, 6)
  gpsLng      Decimal? @db.Decimal(9, 6)
  elevationM  Decimal? @db.Decimal(8, 2)
  soilType    String?
  manager     String?
  defaultUnit String   @default("imperial") // "imperial" | "metric"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vineyard    Vineyard @relation(fields: [vineyardId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("vineyard_detail")
}

// A planted block within a vineyard. All fields optional; nothing required to save.
// Acreage is NOT stored — it is derived from rowSpacing * vineSpacing * vineCount.
model VineyardBlock {
  tenantId       String             @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id             String             @id @default(cuid())
  vineyardId     String
  blockLabel     String? // e.g. "Block 1", "A"
  code           String? // short token for lot codes (e.g. "1", "A"); falls back to a normalized blockLabel
  numRows        Int? // informational (drives optional vines/row readout)
  rowSpacingM    Decimal?           @db.Decimal(10, 4) // canonical metric
  vineSpacingM   Decimal?           @db.Decimal(10, 4) // canonical metric
  varietyId      String?
  clone          String?
  rootstock      String?
  vineCount      Int?
  yearPlanted    Int?
  irrigated      Boolean?
  polygon        Json? // GeoJSON Polygon geometry (illustrative, not the area source)
  color          String? // optional per-block polygon color override (hex)
  sortOrder      Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  vineyard       Vineyard           @relation(fields: [vineyardId], references: [id], onDelete: Cascade)
  variety        Variety?           @relation(fields: [varietyId], references: [id], onDelete: SetNull)
  brixLogs       BrixLog[]
  harvestRecords HarvestRecord[]
  subblocks      VineyardSubblock[]

  @@unique([tenantId, id]) // plan 039: composite-FK target for work_order_task.blockId (Phase-12 rule)
  @@index([vineyardId])
  @@index([varietyId])
  @@index([tenantId])
  @@map("vineyard_block")
}

// A geographic sub-division of a block (e.g. "A"/"B") for differential picks / experiments.
// `code` is the short token that appears in a lot code between BLOCK and VARIETY.
model VineyardSubblock {
  tenantId  String        @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id        String        @id @default(cuid())
  blockId   String
  code      String // short uppercase token for lot codes (e.g. "A")
  label     String? // optional human label
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  block     VineyardBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([tenantId, blockId, code])
  @@index([blockId])
  @@index([tenantId])
  @@map("vineyard_subblock")
}

// ───────────────────────── Vineyard operations: field notes ─────────────────────────

// One canonical weekly field report per vineyard (Friday-anchored). JSON columns
// hold the LLM-friendly weather / inputs / per-block status payloads; vineyard +
// manager stay real FKs for querying. `userEmail` snapshots provenance (mirror
// BottlingRun) so deleting the manager (SetNull) never erases who logged it.
model FieldNote {
  tenantId           String    @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id                 String    @id @default(cuid())
  vineyardId         String
  userId             String? // manager who logged it; SetNull so user delete doesn't cascade
  userEmail          String // durable provenance snapshot
  weekOf             DateTime  @db.Date // Friday anchor, written via the canonical UTC helper
  weatherData        Json // { rainfallMm, maxTempC, minTempC }
  spraysApplied      Json // [{ name, scope: "WHOLE"|"BLOCKS", blockIds: [] }]
  fertilizersApplied Json // same shape as spraysApplied
  blockLevelStatuses Json // { [blockId]: BlockStatus }
  schemaVersion      Int       @default(1) // JSON shape version
  generalNotes       String?
  aiSummary          String?
  aiSummaryStatus    String    @default("PENDING") // PENDING | READY | FAILED
  aiSummaryAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  vineyard           Vineyard  @relation(fields: [vineyardId], references: [id], onDelete: Cascade)
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([tenantId, vineyardId, weekOf]) // one canonical note per vineyard per week
  @@index([vineyardId, weekOf])
  @@index([tenantId])
  @@map("field_note")
}

// Master list of sprays/fertilizers. `normalizedKey` (strip-all-non-alphanumeric
// UPPERCASE) dedupes "NEEM OIL" / "NEEM-OIL" to one row; `name` keeps the label.
model FieldInput {
  tenantId      String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id            String   @id @default(cuid())
  type          String // SPRAY | FERTILIZER
  name          String // display, cleaned UPPERCASE
  normalizedKey String // dedup key, strip-all-non-alphanumeric UPPERCASE
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@unique([tenantId, type, normalizedKey])
  @@index([tenantId])
  @@map("field_input")
}

// ───────────────────────── Vineyard operations: harvest ledger ─────────────────────────

// Per-block Brix readings logged repeatedly across the ripening window.
// `vineyardId` denormalized for clean aggregates; block delete is Restricted so
// ripening history is never erased by a block edit. DB CHECK enforces 0..40.
model BrixLog {
  tenantId       String        @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id             String        @id @default(cuid())
  blockId        String
  vineyardId     String // denormalized FK for aggregates
  brixValue      Decimal       @db.Decimal(4, 1)
  recordedAt     DateTime      @default(now())
  createdById    String?
  createdByEmail String // provenance snapshot
  note           String?
  block          VineyardBlock @relation(fields: [blockId], references: [id], onDelete: Restrict)
  vineyard       Vineyard      @relation(fields: [vineyardId], references: [id], onDelete: Restrict)

  @@index([blockId, recordedAt])
  @@index([vineyardId])
  @@index([tenantId])
  @@map("brix_log")
}

// One record per (block, vintage): holds the pre-harvest estimate and parents the
// pick passes. `totalWeightKg` is NOT stored — it is the sum of `picks`.
model HarvestRecord {
  tenantId        String        @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id              String        @id @default(cuid())
  blockId         String
  vineyardId      String // denormalized FK for aggregates
  vintageYear     Int
  yieldEstimateKg Decimal?      @db.Decimal(12, 3) // pre-harvest estimate, canonical kg
  createdById     String?
  createdByEmail  String
  updatedByEmail  String?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  block           VineyardBlock @relation(fields: [blockId], references: [id], onDelete: Restrict)
  vineyard        Vineyard      @relation(fields: [vineyardId], references: [id], onDelete: Restrict)
  picks           HarvestPick[]

  @@unique([tenantId, blockId, vintageYear])
  @@index([vineyardId, vintageYear])
  @@index([tenantId])
  @@map("harvest_record")
}

// Each pick pass against a HarvestRecord. Vineyards pick a block in multiple
// passes; the total auto-rolls up from these rows.
model HarvestPick {
  tenantId        String             @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id              String             @id @default(cuid())
  harvestRecordId String
  pickDate        DateTime           @db.Date
  weightKg        Decimal            @db.Decimal(12, 3) // canonical kg
  brixAtPick      Decimal?           @db.Decimal(4, 1) // optional Brix the fruit came off at
  phAtPick        Decimal?           @db.Decimal(4, 2) // optional field pH (analyte registry: 2.5–4.5)
  taAtPick        Decimal?           @db.Decimal(4, 1) // optional field titratable acidity, g/L tartaric (registry: 0–20)
  createdById     String?
  createdByEmail  String
  note            String?
  createdAt       DateTime           @default(now())
  harvestRecord   HarvestRecord      @relation(fields: [harvestRecordId], references: [id], onDelete: Cascade)
  // Phase 6: lots this pick was (partially) crushed into. A pick can feed several fermenters;
  // Σ consumedKg ≤ weightKg is enforced in the crush tx (no DB unique on harvestPickId).
  crushSources    LotHarvestSource[]

  @@unique([tenantId, id])
  @@index([harvestRecordId, pickDate])
  @@index([tenantId])
  @@map("harvest_pick")
}

// ───────────────────────── Bulk / in-process wine ─────────────────────────

model Vessel {
  tenantId         String              @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id               String              @id @default(cuid())
  code             String // barrels: "Barrel #"; tanks: code. Unique per type (see @@unique below).
  type             VesselType
  capacityL        Decimal             @db.Decimal(10, 2)
  isActive         Boolean             @default(true)
  blendName        String? // optional label for the current blend in this vessel
  // Barrel-only metadata (null for tanks). Volume = capacityL (not duplicated here).
  // The barrel's "Barrel #" is its `code` above — no separate number column.
  oakOrigin        String? // e.g. French, American, Hungarian
  cooperageYear    Int? // year the barrel was made
  cooperage        String? // barrel maker, e.g. Seguin Moreau
  toastLevel       String? // e.g. Light, Medium, Medium+, Heavy
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  components       VesselComponent[]
  bottlingSources  BottlingSource[]
  transfersOut     VesselTransfer[]    @relation("VesselTransfersOut")
  transfersIn      VesselTransfer[]    @relation("VesselTransfersIn")
  // Lot + ledger spine (Phase 1): the projection rows, group memberships, and the
  // operation lines that reference this vessel. Additive; existing relations unchanged.
  vesselLots       VesselLot[]
  groupMemberships VesselGroupMember[]
  operationLines   LotOperationLine[]
  treatments       LotTreatment[]
  // Phase 4 standalone records (snapshot context; vessel delete SetNulls these).
  analysisPanels   AnalysisPanel[]
  tastingNotes     LotTastingNote[]
  samples          Sample[]
  // Phase 6: ferment-state transitions captured in this vessel (snapshot context).
  stateEvents      LotStateEvent[]
  // Phase 8b (Unit 8): the 1:1 depreciating-asset sidecar (barrels only; null for tanks).
  barrelAsset      BarrelAsset?

  @@unique([tenantId, type, code]) // barrel "1" and tank "1" can coexist; numbers unique within a type
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("vessel")
}

model VesselComponent {
  tenantId   String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id         String   @id @default(cuid())
  vesselId   String
  varietyId  String
  vineyardId String
  vintage    Int
  volumeL    Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vessel     Vessel   @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  variety    Variety  @relation(fields: [varietyId], references: [id], onDelete: Restrict)
  vineyard   Vineyard @relation(fields: [vineyardId], references: [id], onDelete: Restrict)

  @@unique([tenantId, vesselId, varietyId, vineyardId, vintage])
  @@index([vesselId])
  @@index([varietyId])
  @@index([tenantId])
  @@map("vessel_component")
}

// One racking / wine transfer between two vessels. `volumeL` is the volume drawn
// OUT of the source; `lossL` is what was lost to lees (volume INTO the destination
// = volumeL - lossL). `components` is a JSON snapshot of the moved breakdown
// ([{ varietyName, vineyardName, vintage, volumeL }]) so history reads correctly
// even for multi-lot (tank) racks and survives later vessel edits. Vessel codes
// are snapshotted so a deleted vessel (FK SetNull) still shows in history.
model VesselTransfer {
  tenantId       String           @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id             String           @id @default(cuid())
  fromVesselId   String?
  toVesselId     String?
  fromVesselCode String
  toVesselCode   String
  volumeL        Decimal          @db.Decimal(10, 2)
  lossL          Decimal          @default(0) @db.Decimal(10, 2)
  components     Json
  note           String?
  actorUserId    String?
  actorEmail     String
  rackedAt       DateTime         @default(now())
  // Revert tracking (LEGACY undo path). Phase 1 (D6/D15) replaces row-reversion with
  // a CORRECTION ledger op; "reverted" is derived from a correction's existence. These
  // columns remain for the pre-cutover history read and are dropped in a later cleanup.
  revertedAt     DateTime?
  revertsId      String?
  reverts        VesselTransfer?  @relation("TransferReversal", fields: [revertsId], references: [id], onDelete: SetNull)
  reversedBy     VesselTransfer[] @relation("TransferReversal")
  fromVessel     Vessel?          @relation("VesselTransfersOut", fields: [fromVesselId], references: [id], onDelete: SetNull)
  toVessel       Vessel?          @relation("VesselTransfersIn", fields: [toVesselId], references: [id], onDelete: SetNull)
  // Phase 1: a RACK is a derived read-model of one ledger operation. Unique 1:1 link;
  // written only by the ledger writer.
  lotOperationId Int?             @unique
  lotOperation   LotOperation?    @relation(fields: [lotOperationId], references: [id], onDelete: SetNull)

  @@index([fromVesselId, rackedAt])
  @@index([toVesselId, rackedAt])
  @@index([rackedAt])
  @@index([revertsId])
  @@index([tenantId])
  @@map("vessel_transfer")
}

// ───────────────────────── Bottling ─────────────────────────

model WineSku {
  tenantId         String                 @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id               String                 @id @default(cuid())
  name             String
  // Phase 7 (K11): NULLABLE for NV / multi-vintage sparkling; isNonVintage marks a true NV
  // SKU (no lying sentinel). Because Postgres treats NULLs as distinct, the old compound
  // @@unique breaks for NV — replaced with TWO partial unique indexes added by hand in the
  // Unit 2 migration: UNIQUE(name,vintage,bottleSizeMl) WHERE vintage IS NOT NULL, and
  // UNIQUE(name,bottleSizeMl) WHERE isNonVintage. Finalize uses find-or-create, not upsert.
  vintage          Int?
  isNonVintage     Boolean                @default(false)
  bottleSizeMl     Int                    @default(750)
  // Phase 7: sparkling metadata on the catalog SKU (batch facts like disgorgedAt / actual
  // dosage g/L live on BottlingRun, not here — council CRITICAL #5).
  method           SparklingMethod?
  dosageStyle      DosageStyle?
  // Plan 080 U7: list PRICE. Safe as a mutable SKU column — it is what you SELL for, not what it COST.
  // COGS deliberately does NOT live here (council C4: a mutable cost column is a second source of truth
  // with no history); purchased cost lives in FinishedGoodReceipt, bottled cost in BottlingCostSnapshot.
  msrp             Decimal?               @db.Decimal(18, 2)
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  categoryId       String?
  category         FinishedGoodCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  bottlingRuns     BottlingRun[]
  bottledInventory BottledInventory[]
  stockMovements   StockMovement[]
  costSnapshots    BottlingCostSnapshot[] // Phase 8: frozen per-SKU COGS snapshots

  @@unique([tenantId, id]) // Phase 8: composite-tenant-FK target for bottling_cost_snapshot (K11)
  @@index([categoryId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("wine_sku")
}

model BottlingRun {
  tenantId              String                 @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id                    String                 @id @default(cuid())
  date                  DateTime
  wineSkuId             String
  bottlesProduced       Int
  volumeConsumedL       Decimal                @db.Decimal(10, 2)
  destinationLocationId String
  createdById           String? // soft-deleted users; snapshot below survives
  createdByEmail        String
  createdAt             DateTime               @default(now())
  // Phase 7: sparkling BATCH facts belong on the run, not the catalog SKU (council CRITICAL
  // #5). One BottlingRun per finalize; multiple disgorgement tranches → multiple runs / SKU.
  disgorgedAt           DateTime?
  dosageGramsPerL       Decimal?               @db.Decimal(6, 2)
  // Phase 14 (Fork 1A): the ABV stamped at bottling — required for still wine (validated at the
  // action), resolved at FINISH for sparkling (base ABV + tirage bump). Nullable in the DB so
  // historical runs backfill; the tax-ABV resolver reads it as the as-of-bottling authority.
  bottledAbv            Decimal?               @db.Decimal(5, 2)
  wineSku               WineSku                @relation(fields: [wineSkuId], references: [id], onDelete: Restrict)
  destinationLocation   Location               @relation(fields: [destinationLocationId], references: [id], onDelete: Restrict)
  sources               BottlingSource[]
  stockMovements        StockMovement[]
  costSnapshots         BottlingCostSnapshot[] // Phase 8: frozen per-run+line COGS snapshots

  @@unique([tenantId, id]) // Phase 8: composite-tenant-FK target for bottling_cost_snapshot (K11)
  @@index([wineSkuId])
  @@index([date])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("bottling_run")
}

model BottlingSource {
  tenantId        String      @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id              String      @id @default(cuid())
  bottlingRunId   String
  // Phase 7 (K13, extended): origin columns are NULLABLE. A blended / multi-vintage sparkling
  // (or blended still-wine) lot has NO single variety/vineyard/vessel origin — the honest
  // provenance is `lotId` (required for lot-sourced runs) + the lineage DAG. Historically
  // `applyBottling` wrote `?? ""`, which inserts an invalid FK and would blow up finalize
  // against Restrict — a latent bug this fixes. `vesselId` is nullable too: a finalized bottle
  // lot has no vessel. Still-wine bottling always sets all three, so no behavior change there.
  vesselId        String?
  varietyId       String?
  vineyardId      String?
  vintage         Int?
  volumeConsumedL Decimal     @db.Decimal(10, 2)
  lotId           String?
  bottlingRun     BottlingRun @relation(fields: [bottlingRunId], references: [id], onDelete: Cascade)
  vessel          Vessel?     @relation(fields: [vesselId], references: [id], onDelete: Restrict)
  variety         Variety?    @relation(fields: [varietyId], references: [id], onDelete: Restrict)
  vineyard        Vineyard?   @relation(fields: [vineyardId], references: [id], onDelete: Restrict)
  lot             Lot?        @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([bottlingRunId])
  @@index([vesselId])
  @@index([lotId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("bottling_source")
}

// ───────────────────────── Inventory ledger + cached balances ─────────────────────────

model StockMovement {
  tenantId        String        @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  createdById     String?
  createdByEmail  String
  itemKind        ItemKind
  wineSkuId       String?
  finishedGoodId  String?
  locationId      String
  kind            MovementKind
  deltaUnits      Int // bottles (wine) or each (goods); signed
  reason          String?
  transferGroupId String? // pairs the out/in legs of a TRANSFER
  bottlingRunId   String?
  wineSku         WineSku?      @relation(fields: [wineSkuId], references: [id], onDelete: Restrict)
  finishedGood    FinishedGood? @relation(fields: [finishedGoodId], references: [id], onDelete: Restrict)
  location        Location      @relation(fields: [locationId], references: [id], onDelete: Restrict)
