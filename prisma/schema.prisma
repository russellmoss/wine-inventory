// ───────────────────────── Phase 8: supply stock + cost roll-up (D16 separated concerns) ─────────────────────────
// All six tables are tenant-scoped + RLS-isolated per the AGENTS.md Phase-12 checklist (tenantId
// @default("") + @@index([tenantId]) + FK→organization ON DELETE RESTRICT + RLS ENABLE+FORCE+
// tenant_isolation, kept OUT of GLOBAL_MODELS). Cross-tenant-risk FKs to the ledger (operation/lot/
// supplyLot/run/sku) are COMPOSITE (tenantId, refId)→(tenantId, id) at the DB level (K11) — added in
// the migration raw SQL; Prisma relations stay single-column referencing id, matching the repo's
// existing composite-FK convention. Money is Decimal(18,8) internally (D9); volumes stay Decimal(10,2).
// Migrations: 20260702000000_cost_enums (enum types), 20260702000100_cost_schema (these tables +
// extensions), 20260702000200_cost_rls (RLS). NONE deployed until the operator runs migrate deploy.

// A costed receipt of a stock-tracked supply (Unit 1). One row per purchase/opening balance; the
// current on-hand for a material is Σ qtyRemaining over its non-depleted lots. `unitCost` is per
// stockUnit; NULL cost = UNKNOWN (D14), never $0. WA/FIFO depletion draws these down (Unit 3).
model SupplyLot {
  tenantId      String              @default("")
  id            String              @id @default(cuid())
  materialId    String
  qtyReceived   Decimal             @db.Decimal(18, 6)
  qtyRemaining  Decimal             @db.Decimal(18, 6)
  stockUnit     String // snapshot of the unit these quantities are held in (g | kg | mL | L | unit …)
  unitCost      Decimal?            @db.Decimal(18, 8) // per stockUnit; NULL = unknown cost (D14). Plan 073: ALWAYS in the tenant BASE currency — the roll-up basis; a foreign invoice is converted at receipt (never revalued).
  currency      String              @default("USD") // Plan 073: the BASE currency (== tenant base); the foreign figures live below for audit only
  // Plan 073: immutable foreign-invoice provenance (historical cost, IAS 21 — stored for audit/reversal, NEVER enters the roll-up). All null for a base-currency receipt.
  foreignUnitCost   Decimal?        @db.Decimal(18, 8) // per stockUnit in the invoice (foreign) currency
  foreignCurrency   String? // the invoice currency (e.g. "EUR")
  fxRate            Decimal?        @db.Decimal(18, 8) // base per 1 foreign at receipt (unitCost == foreignUnitCost × fxRate)
  fxRateDate        DateTime? // the ECB publication date the rate was for
  fxRateSource      String? // e.g. "ECB via Frankfurter" or "manual override"
  receivedAt    DateTime            @default(now())
  lotCode       String? // supplier lot / PO reference
  supplierNote  String?
  expiresAt     DateTime? // Plan 072: batch/lot expiry (attached from a COA by lot no.); nullable, RLS-neutral column add
  vendorId      String? // Plan 069: per-purchase vendor — composite-tenant FK → vendor(tenantId,id) (raw SQL, K11)
  // Plan 080: physical location of this lot. CONTRACTED to NOT NULL in U13a
  // (20260719180000_supplylot_location_not_null) once every writer — app paths AND the verify/seed scripts —
  // stamped it and the backfill reached 0 nulls across all tenants. Composite-tenant FK
  // (tenantId,locationId)→location(tenantId,id) in raw SQL (K11), NO Prisma relation (mirrors vendorId) so
  // Location's back-relations stay untouched.
  locationId    String
  // Plan 080 U1: transfer lineage. When a transfer SPLITS a lot, the destination lot points back at the source lot
  // here; provenance (LotDocument/expiry) is derived TRANSITIVELY through this edge (council S2 — never row-copy).
  splitFromLotId String?
  policyVersion Int                 @default(1) // costing-policy version at receipt (D17)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  material      CellarMaterial      @relation(fields: [materialId], references: [id], onDelete: Restrict)
  consumptions  SupplyConsumption[]

  @@unique([tenantId, id]) // composite-tenant-FK target for supply_consumption (K11)
  @@index([tenantId])
  @@index([tenantId, materialId, receivedAt]) // FIFO / on-hand scan (partial WHERE qtyRemaining>0 added in SQL)
  @@index([tenantId, locationId]) // Plan 080 U1: per-location filters
  @@index([tenantId, materialId, locationId, receivedAt, id]) // Plan 080 U1: per-location FIFO scan, deterministic (receivedAt,id) tiebreak
  @@map("supply_lot")
}

// Plan 080 U1: append-only per-location movement ledger for consumables (mirrors StockMovement for wine).
// Every RECEIVE / ADJUST / TRANSFER / CONSUME of a material at a location writes one row. `deltaQty` is SIGNED
// (negative for a draw / the out-leg of a transfer). A transfer pairs its two legs via `transferGroupId`.
// Tenant-scoped + RLS (Phase-12). Composite-tenant FKs (tenantId,materialId)/(tenantId,locationId)/(tenantId,supplyLotId)
// in raw SQL (K11 — council S3); `kind` is a validated string CHECK-constrained to the four values.
model MaterialMovement {
  tenantId        String   @default("")
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  createdById     String?
  createdByEmail  String
  materialId      String
  locationId      String
  kind            String // RECEIVE | ADJUST | TRANSFER | CONSUME (CHECK-constrained in SQL)
  deltaQty        Decimal  @db.Decimal(18, 6) // signed
  supplyLotId     String? // the lot drawn/created, when applicable
  transferGroupId String? // pairs the two legs of a transfer
  reason          String?

  @@unique([tenantId, id]) // composite-tenant-FK target (K11)
  @@index([tenantId])
  @@index([tenantId, materialId, locationId])
  @@index([tenantId, transferGroupId])
  @@index([tenantId, createdAt])
  @@map("material_movement")
}

// Direct absorbed cost on an op, tagged by component (D2, D16). The append-only money artifact the
// roll-up sums. `lotId` is the lot the cost lands on (null for a run-level packaging line resolved via
// the op). `reversalOfCostLineId` links an identity-negation row (Unit 11). Never mutated.
model CostLine {
  tenantId             String                @default("")
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id                   String                @id @default(cuid())
  operationId          Int
  lotId                String?
  component            CostComponent
  amount               Decimal               @db.Decimal(18, 8)
  currency             String                @default("USD")
  basisCompleteness    CostBasisCompleteness @default(KNOWN)
  policyVersion        Int                   @default(1)
  reversalOfCostLineId String? // set on the negation row that reverses another CostLine (Unit 11)
  note                 String?
  createdAt            DateTime              @default(now())
  operation            LotOperation          @relation(fields: [operationId], references: [id], onDelete: Restrict)
  lot                  Lot?                  @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([tenantId, operationId, component])
  @@index([tenantId, lotId])
  @@map("cost_line")
}

// Physical + cost depletion of supply stock (D11). One consume op → many rows (multi-lot depletion
// under WA/FIFO). `methodUsed` is stamped at write so recompute is stable (D17). Reversal negates by
// identity and restores exact qty (Unit 11) via `reversalOfConsumptionId`.
model SupplyConsumption {
  tenantId                String                @default("")
  id                      String                @id @default(cuid())
  operationId             Int
  supplyLotId             String
  qty                     Decimal               @db.Decimal(18, 6)
  unitCost                Decimal?              @db.Decimal(18, 8) // snapshot of the supply lot's unit cost (NULL = unknown, D14)
  extendedCost            Decimal?              @db.Decimal(18, 8) // qty × unitCost (NULL when unitCost unknown)
  methodUsed              CostingMethod
  basisCompleteness       CostBasisCompleteness @default(KNOWN)
  policyVersion           Int                   @default(1)
  reversalOfConsumptionId String? // set on the negation row that reverses another consumption (Unit 11)
  createdAt               DateTime              @default(now())
  operation               LotOperation          @relation(fields: [operationId], references: [id], onDelete: Restrict)
  supplyLot               SupplyLot             @relation(fields: [supplyLotId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, operationId])
  @@index([tenantId, supplyLotId])
  @@map("supply_consumption")
}

// Immutable lot→lot inherited-cost artifact for a blend/split (D10). Cost moved =
// parentTotalCost × transferredVolumeL / parentPreOpVolumeL — an UNAMBIGUOUS transferred-volume basis,
// NOT the lineage `fraction` (council C2). Conservation is asserted per op. Reversal via
// `reversalOfTransferId` (Unit 11).
model OperationCostTransfer {
  tenantId             String       @default("")
  id                   String       @id @default(cuid())
  operationId          Int
  fromLotId            String
  toLotId              String
  transferredVolumeL   Decimal      @db.Decimal(10, 2)
  parentPreOpVolumeL   Decimal      @db.Decimal(10, 2)
  transferredCost      Decimal      @db.Decimal(18, 8)
  currency             String       @default("USD")
  policyVersion        Int          @default(1)
  reversalOfTransferId String?
  createdAt            DateTime     @default(now())
  operation            LotOperation @relation(fields: [operationId], references: [id], onDelete: Restrict)
  fromLot              Lot          @relation("CostTransferFrom", fields: [fromLotId], references: [id], onDelete: Restrict)
  toLot                Lot          @relation("CostTransferTo", fields: [toLotId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, toLotId])
  @@index([tenantId, fromLotId])
  @@index([tenantId, operationId])
  @@map("operation_cost_transfer")
}

// FROZEN, immutable COGS per bottling run + line (D15, D18). Bottling is a bill-of-materials:
// totalRunCost = liquid + dry goods (+ labor/oh later); costPerBottle = totalRunCost / ACTUAL good
// bottles. ALL Phase-15 export-seam columns ship here in 8a (D21) so Units 6/13/14 populate, never
// re-migrate: postingKey (idempotency), sourceSnapshotId / reversalOfSnapshotId (lineage), postedAt,
// externalSystemId. componentBreakdown is the {component: amount} decomposition frozen at file time.
model BottlingCostSnapshot {
  tenantId                 String                @default("")
  id                       String                @id @default(cuid())
  runId                    String
  skuId                    String
  taxClass                 String? // derived tax class snapshot (Phase 14 union as text)
  bottledAt                DateTime
  goodBottles              Int
  totalRunCost             Decimal               @db.Decimal(18, 8)
  costPerBottle            Decimal               @db.Decimal(18, 2) // rounded to cents at snapshot (D9)
  currency                 String                @default("USD")
  costBasisAsOfOperationId Int? // the max cost-affecting opId the basis reflects (D4 watermark)
  componentBreakdown       Json // { MATERIAL: n, FRUIT: n, PACKAGING: n, … } frozen decomposition
  basisCompleteness        CostBasisCompleteness @default(KNOWN)
  policyVersion            Int                   @default(1)
  // Phase 15 export seam (D18) — all shipped in 8a, populated by 8b Unit 14.
  postingKey               String? // idempotency key for an accounting export event
  sourceSnapshotId         String? // the snapshot this one was derived/re-stated from
  reversalOfSnapshotId     String? // set on a snapshot that reverses another
  postedAt                 DateTime?
  externalSystemId         String? // id assigned by the external accounting system on post
  createdAt                DateTime              @default(now())
  run                      BottlingRun           @relation(fields: [runId], references: [id], onDelete: Restrict)
  sku                      WineSku               @relation(fields: [skuId], references: [id], onDelete: Restrict)
  varianceEvents           CostVarianceEvent[]

  @@unique([tenantId, postingKey]) // per-tenant idempotency (partial WHERE postingKey IS NOT NULL in SQL)
  @@index([tenantId])
  @@index([tenantId, skuId, runId])
  @@index([tenantId, taxClass, bottledAt])
  @@map("bottling_cost_snapshot")
}

// A LAZY, VERSIONED cache of a lot's rolled-up cost (D4) — NOT an invariant projection. The DAG
// recompute (Unit 4) is the AUTHORITY; this row is refreshed on read when the lot's max cost-affecting
// opId exceeds `computedThroughOpId` (the watermark). NEVER eagerly fanned out from the write
// chokepoint. 1:1 with Lot (lotId @id), deleted-at-zero like VesselLot. `basisVersion` tracks the
// costing-policy version the cache reflects so a policy bump invalidates it.
model LotCostState {
  tenantId            String                @default("")
  lotId               String                @id
  totalCost           Decimal               @db.Decimal(18, 8)
  volumeL             Decimal               @db.Decimal(10, 2)
  costPerL            Decimal?              @db.Decimal(18, 8) // totalCost / volumeL; NULL at zero volume (D9)
  basisCompleteness   CostBasisCompleteness @default(UNKNOWN)
  computedThroughOpId Int                   @default(0) // watermark: max cost-affecting opId folded in
  basisVersion        Int                   @default(1)
  componentBreakdown  Json? // { MATERIAL: n, FRUIT: n, … } cached decomposition
  updatedAt           DateTime              @updatedAt
  lot                 Lot                   @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("lot_cost_state")
}

// Phase 8b (Unit 8, D7) — a barrel-as-depreciating-asset sidecar (1:1 with a BARREL Vessel). Barrel
// carrying cost amortizes over its useful life measured in FILLS, accelerated by fill number (first
// fill imparts the most oak character → the most cost). `currentFillNumber` is the running fill counter
// bumped when wine enters an empty barrel. Optional: a barrel with no BarrelAsset simply accrues no
// barrel cost (physical tracking unaffected). Not the tank's concern — tanks never get one.
model BarrelAsset {
  tenantId          String       @default("")
  id                String       @id @default(cuid())
  vesselId          String       @unique // the BARREL vessel this asset describes (1:1)
  purchaseCost      Decimal      @db.Decimal(18, 8)
  currency          String       @default("USD")
  usefulLifeFills   Int          @default(4) // fills over which the barrel fully depreciates
  currentFillNumber Int          @default(0) // running counter; ++ when wine enters the empty barrel
  acquiredAt        DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  vessel            Vessel       @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  fills             BarrelFill[]

  @@unique([tenantId, id]) // composite-tenant-FK target for barrel_fill (K11)
  @@index([tenantId])
  @@map("barrel_asset")
}

// Phase 8b (Unit 8, D7) — one barrel-residency interval: a lot occupying a barrel over [startedAt,
// endedAt]. `fillNumber` picks the accelerated-depreciation slice; `fillDepreciation` is the $ that
// slice allocates ($ = purchaseCost × slice-fraction). While OPEN (endedAt null) the roll-up derives
// an accrue-to-date BARREL cost event (days-so-far); when the lot leaves the barrel the fill CLOSES and
// an immutable BARREL CostLine is materialized on the close op (so the snapshot can freeze it and the
// on-read derivation stops double-counting it). Volume is snapshotted at fill open (v1). Two lots in one
// barrel each get their own fill row → cost splits by volume×time.
model BarrelFill {
  tenantId               String      @default("")
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id                     String      @id @default(cuid())
  barrelAssetId          String
  lotId                  String
  fillNumber             Int
  volumeL                Decimal     @db.Decimal(10, 2) // resident volume at fill open
  capacityL              Decimal     @db.Decimal(10, 2) // barrel capacity snapshot
  purchaseCostSnapshot   Decimal     @db.Decimal(18, 8) // barrel purchase cost at fill open (D17-stable)
  fillDepreciation       Decimal     @db.Decimal(18, 8) // $ this fill amortizes = purchaseCost × slice
  startedAt              DateTime
  endedAt                DateTime?
  openOpId               Int // the op that opened this fill
  closeOpId              Int? // the op that closed it (materialized the CostLine)
  materializedCostLineId String? // the BARREL CostLine written at close (null while open)
  policyVersion          Int         @default(1)
  createdAt              DateTime    @default(now())
  barrelAsset            BarrelAsset @relation(fields: [barrelAssetId], references: [id], onDelete: Cascade)
  lot                    Lot         @relation(fields: [lotId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([tenantId, lotId])
  @@index([tenantId, barrelAssetId, endedAt])
  @@map("barrel_fill")
}

// Phase 8b (Unit 13, D12/D17) — an explicit, auditable post-bottling cost variance. When a backdated
// correction changes a bottled lot's cost basis after its snapshot froze, the snapshot stays immutable
// and THIS row records the delta, split across sold (→ period COGS variance) and on-hand (→ inventory
// value) bottles. Append-only; one event per (snapshot, triggering op) — idempotent re-detection.
model CostVarianceEvent {
  tenantId          String                @default("")
  id                String                @id @default(cuid())
  snapshotId        String // the frozen BottlingCostSnapshot this varies (never mutated)
  triggeringOpId    Int // the correction op that changed the basis
  runId             String
  skuId             String
  oldCostPerBottle  Decimal               @db.Decimal(18, 2)
  newCostPerBottle  Decimal               @db.Decimal(18, 2)
  goodBottles       Int
  onHandBottles     Int
  soldBottles       Int
  soldDelta         Decimal               @db.Decimal(18, 8) // → period COGS variance (shipped bottles)
  unsoldDelta       Decimal               @db.Decimal(18, 8) // → on-hand inventory-value adjustment
  totalDelta        Decimal               @db.Decimal(18, 8)
  currency          String                @default("USD")
  basisCompleteness CostBasisCompleteness @default(KNOWN)
  policyVersion     Int                   @default(1)
  note              String?
  createdAt         DateTime              @default(now())
  snapshot          BottlingCostSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Restrict)

  @@unique([tenantId, snapshotId, triggeringOpId]) // idempotent: one variance per snapshot per trigger
  @@index([tenantId])
  @@index([tenantId, snapshotId])
  @@map("cost_variance_event")
}

// Phase 8b (Unit 14, D18) — the per-tenant (component, tax-class) → debit/credit account map. A null
// taxClass is the default row for that component; an exact tax-class match wins over it. This is the ONLY
// tenant-specific knob Phase 15 needs to turn cost export events into postable journal lines.
model AccountMapping {
  tenantId      String        @default("")
  id            String        @id @default(cuid())
  component     CostComponent
  // Phase 15 (council C7): the DEFAULT row uses the sentinel '*' (never NULL). Postgres treats
  // NULLs as distinct, so a NULL default could not be uniquely enforced (two "defaults" per
  // component). '*' matches the pure seam's accountKey(component, null) => `${component}|*`, so
  // resolveAccounts' fallback still finds it. An exact tax-class row (e.g. 'WINE_UNDER_16') wins.
  taxClass      String        @default("*")
  debitAccount  String
  creditAccount String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([tenantId, component, taxClass]) // single default enforced (no NULLs — sentinel '*')
  @@index([tenantId])
  @@map("account_mapping")
}

// Phase 8b (Unit 14, D18) — an immutable, idempotent, reversible accounting export LINE. One per
// capitalized component of a COGS snapshot (or variance event). `postingKey` is unique per tenant so a
// re-emit is a no-op; `reversalOfExportEventId` links a negated reversal line back to its original.
// Phase 15 posts these as-is (debit/credit + amount); `postedAt` + `externalSystemId` are stamped when it
// does. Incomplete-basis sources are never emitted (D14). Reading these IS the per-SKU/per-run export view.
model CostExportEvent {
  tenantId                String                @default("")
  id                      String                @id @default(cuid())
  postingKey              String // per-line idempotency (source postingKey : component [: rev])
  sourceType              String // SNAPSHOT | VARIANCE
  sourceSnapshotId        String?
  sourceVarianceEventId   String?
  reversalOfExportEventId String?
  runId                   String?
  skuId                   String?
  taxClass                String?
  component               CostComponent
  amount                  Decimal               @db.Decimal(18, 8)
  debitAccount            String? // null = WITHHELD (component unmapped or basis not KNOWN) — never posted (U7)
  creditAccount           String?
  currency                String                @default("USD")
  basisCompleteness       CostBasisCompleteness @default(KNOWN)
  policyVersion           Int                   @default(1)
  postedAt                DateTime?
  externalSystemId        String?
  createdAt               DateTime              @default(now())

  @@unique([tenantId, postingKey]) // idempotent re-emit
  @@unique([tenantId, id]) // Phase 15: composite-tenant-FK target for accounting_delivery (K11)
  @@index([tenantId])
  @@index([tenantId, skuId, runId])
  @@index([tenantId, sourceSnapshotId])
  @@map("cost_export_event")
}

// ───────────────────────── Phase 15: QuickBooks / accounting integration ─────────────────────────
// Tenant-scoped, RLS-isolated (Phase-12 checklist). OAuth tokens are AEAD-envelope-encrypted
// (src/lib/crypto/envelope.ts, Unit 1): ONLY the encrypted refresh token + its wrapped per-record DEK
// are persisted; the access token is cached in memory, never a column (SEC-N2). AccountingDelivery is
// the MUTABLE state machine over the IMMUTABLE export seam (CostExportEvent / ApExportEvent). Composite
// tenant FKs, the DB CHECK that non-CONNECTED rows hold no tokens (SEC-S5), the global
// one-realmId-per-provider guard (SEC-C2), the delivery source XOR CHECK + partial index, and the
// least-privilege cron enumerator role (SEC-C3) all live in the migration SQL, mirroring Phase 12.

enum AccountingProvider {
  QBO
  XERO
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  NEEDS_REAUTH
  // Phase 16 (Commerce7): a nonce-verified install that is staged but not yet admin-confirmed. Only
  // used by commerce7_connection; accounting connections never enter this state. Added by an ISOLATED
  // ALTER TYPE migration (Windows enum rule).
  PENDING_CONFIRM
}

enum DeliveryStatus {
  PENDING
  IN_FLIGHT
  VERIFYING
  POSTED
  FAILED
  WITHHELD
  DELETED_IN_GL
}

// Plan 076: A/P payment state for an ingested invoice / its aggregate bill. OUTSTANDING = a posted QBO Bill
// with a full balance (shows as owed in A/P aging); PAID = a BillPayment recorded against the Bill from a
// chosen pay-from account (zeroes the balance). Binary in v1; a partial payment reads back as still OUTSTANDING.
enum ApPaymentStatus {
  OUTSTANDING
  PAID
}

model AccountingConnection {
  tenantId              String             @default("")
  id                    String             @id @default(cuid())
  provider              AccountingProvider
  status                ConnectionStatus   @default(DISCONNECTED)
  environment           String // "sandbox" | "production" — keys + realm are env-split
  externalRealmId       String? // canonical company id derived from Intuit, NOT the callback param (SEC-C2)
  refreshTokenCt        String? // AEAD ciphertext — present only when CONNECTED (SEC-S5 DB CHECK)
  dekWrapped            String? // the wrapped per-record DEK (SEC-C4) — present only when CONNECTED
  refreshTokenExpiresAt DateTime? // Nov-2025 refresh-token absolute expiry
  scope                 String?
  tokenVersion          Int                @default(0) // CAS guard for serialized refresh (SEC-N4)
  homeCurrency          String? // QBO company home currency (multi-currency withhold — U6/U7)
  multiCurrencyEnabled  Boolean? // Plan 073: Preferences.CurrencyPrefs.MultiCurrencyEnabled, read at connect (council #2). null = unknown/not-yet-read. A foreign Bill needs this true.
  companyName           String? // display only ("Connected to <company>") — non-secret, from CompanyInfo
  connectedAt           DateTime? // when the current CONNECTED link was established (display)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([tenantId, provider]) // one company per tenant per provider
  @@unique([tenantId, id]) // composite-tenant-FK target for accounting_delivery (K11)
  @@index([tenantId])
  @@map("accounting_connection")
}

// Plan 073: GLOBAL FX-rate cache — NOT tenant-scoped. ECB reference rates are identical for every tenant,
// so this is a shared reference/lookup table (like a currency list): NO tenantId, NO RLS, NOT wrapped by
// the tenant extension. It is added to GLOBAL_MODELS (src/lib/tenant/models.ts + the mirror in
// scripts/verify-tenant-isolation.ts) so the extension passes it through untouched and the RLS coverage
// guard skips it (a deliberate non-auth global — the only one besides the Better-Auth core). One row per
// (base, quote, rateDate). `rate` is quote-per-1-base — HOME per 1 FOREIGN when fetched base=foreign,
// quote=home (the QBO ExchangeRate convention, council #5), so no inversion anywhere. Money precision
// Decimal(18,8) (D9). `rateDate` is the ECB publication day the feed actually used (may be a prior
// business day for a weekend/holiday) — @db.Date so a late-day PST ingest can't create a "tomorrow" row.
model FxRate {
  id        String   @id @default(cuid())
  base      String // the currency being priced (e.g. "EUR")
  quote     String // the currency it is priced in (e.g. "USD") — rate is quote per 1 base
  rateDate  DateTime @db.Date // the CET effective date this rate is used for (cache key); the rate value is the latest ECB publication on/before it. The true ECB quote date is returned by the service + stored on SupplyLot.fxRateDate for audit.
  rate      Decimal  @db.Decimal(18, 8) // quote per 1 base
  source    String // provenance, e.g. "ECB via Frankfurter"
  fetchedAt DateTime @default(now())

  @@unique([base, quote, rateDate])
  @@index([base, quote])
  @@map("fx_rate")
}

// ───────────────────────── Knowledge base — RAG corpus (Plan 079) ─────────────────────────
// GLOBAL reference corpus (like FxRate): trusted public winemaking/viticulture sources, crawled +
// maintained ONCE and shared by all tenants. These tables have NO tenantId and NO RLS; they are listed
// in GLOBAL_MODELS (src/lib/tenant/models.ts) and mirrored in scripts/verify-tenant-isolation.ts so the
// RLS-coverage guard skips them. Per-winery control is the ONE tenant-scoped table below,
// KnowledgeSourceSubscription (full Phase-12 RLS). Document identity is deliberately split (council C3):
//   KnowledgeBlob        = byte-level dedup (one row per contentHash; the same PDF from many URLs = one blob)
//   KnowledgeDocument    = one LOGICAL document per (source, canonicalUrl); carries provenance + revision
//   KnowledgeUrlObservation = every URL a document was seen at (aliases/mirrors) — provenance, not identity
// The vector + tsvector columns are Unsupported() and written via raw SQL (hybrid retrieval, Unit 6).

model KnowledgeSource {
  id             String   @id @default(cuid())
  key            String   @unique // stable slug, e.g. "awri"
  publisher      String // display name, e.g. "AWRI"
  homeDomain     String   @unique // e.g. "awri.com.au"
  tier           Int // 1 = peer-reviewed / official extension, 2 = reputable trade, 3 = other
  license        String // reuse/provenance note (we store paraphrasable text + a link back)
  seedRoots      String[] // sitemap/section roots to crawl
  allowPrefixes  String[] // path prefixes permitted
  denyPrefixes   String[] // path prefixes refused (e.g. paywalled sections)
  crawlCadence   String   @default("weekly")
  defaultEnabled Boolean  @default(true) // tenants get this unless a subscription row overrides
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  documents KnowledgeDocument[]

  @@map("knowledge_source")
}

model TrustedDomain {
  id        String   @id @default(cuid())
  domain    String   @unique // crawler follows links only INTO these domains
  sourceKey String? // optional link to a KnowledgeSource.key
  note      String?
  createdAt DateTime @default(now())

  @@map("trusted_domain")
}

model CandidateSource {
  id                String   @id @default(cuid())
  domain            String   @unique // discovered but not allowlisted — queued for human promotion
  discoveredFromUrl String
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now())
  timesSeen         Int      @default(1)
  status            String   @default("pending") // pending | promoted | rejected

  @@map("candidate_source")
}

model KnowledgeBlob {
  id          String   @id @default(cuid())
  contentHash String   @unique // sha256 of the fetched bytes
  contentType String
  byteSize    Int
  blobUrl     String? // private Vercel Blob snapshot for audit / re-extract
  firstSeenAt DateTime @default(now())

  documents KnowledgeDocument[]

  @@map("knowledge_blob")
}

model KnowledgeDocument {
  id               String    @id @default(cuid())
  sourceId         String
  canonicalUrl     String
  blobId           String?
  canonicalTitle   String?
  publisher        String
  tier             Int
  license          String
  contentType      String
  sitemapLastmod   DateTime?
  publishedAt      DateTime?
  etag             String?
  lastModifiedHttp String?
  status             String    @default("active") // active | withdrawn (tombstoned, kept for audit)
  activeRevision     Int       @default(0) // retrieval reads only chunks at this revision
  indexedContentHash String? // contentHash the active chunk-set was built from (idempotency: skip re-embed if unchanged)
  withdrawnAt        DateTime?
  firstSeenAt      DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  lastVerifiedAt   DateTime  @default(now())
  retrievedAt      DateTime  @default(now())

  source       KnowledgeSource           @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  blob         KnowledgeBlob?            @relation(fields: [blobId], references: [id], onDelete: SetNull)
  observations KnowledgeUrlObservation[]
  chunks       KnowledgeChunk[]

  @@unique([sourceId, canonicalUrl])
  @@index([sourceId, status])
  @@index([status])
  @@map("knowledge_document")
}

model KnowledgeUrlObservation {
  id          String   @id @default(cuid())
  documentId  String
  url         String   @unique
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("knowledge_url_observation")
}

model KnowledgeChunk {
  id             String                       @id // deterministic: sha256(documentId + revision + ordinal + text)
  documentId     String
  revision       Int
  ordinal        Int
  sectionPath    String // breadcrumb, e.g. "Winemaking > Brett > Sanitation"
  text           String                       @db.Text
  tokenCount     Int
  embedding      Unsupported("vector(1024)")? // dense arm; written via raw SQL (Unit 5)
  searchVector   Unsupported("tsvector")?     @map("search_vector") // lexical arm; GENERATED in SQL
  embeddingModel String? // e.g. "voyage-4"
  embeddingDim   Int? // 1024 (committed v1)
  embeddedAt     DateTime?
  createdAt      DateTime                     @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, revision, ordinal])
  @@index([documentId, revision])
  @@index([searchVector], type: Gin)
  @@map("knowledge_chunk")
}

// TENANT-scoped (full Phase-12 RLS): which GLOBAL sources are active in a winery's assistant. Absent row
// => fall back to KnowledgeSource.defaultEnabled. sourceId FK is a plain FK to the global knowledge_source.
model KnowledgeSourceSubscription {
  tenantId  String   @default("") // Phase 12 tenant scope; FK + RLS at the DB level
  id        String   @id @default(cuid())
  sourceId  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, sourceId])
  @@index([tenantId])
  @@index([sourceId])
  @@map("knowledge_source_subscription")
}

model OAuthState {
  tenantId     String             @default("")
  id           String             @id @default(cuid())
  nonceHash    String // SHA-256 of the random state nonce — the raw nonce is never stored (SEC-C1)
  userId       String // the admin who initiated; admin is re-checked at consume time (SEC-C1)
  sessionId    String
  provider     AccountingProvider
  redirectUri  String
  pkceVerifier String // PKCE code_verifier (SEC-S1)
  expiresAt    DateTime
  createdAt    DateTime           @default(now())

  @@unique([tenantId, nonceHash]) // consumed with DELETE … RETURNING (single-use)
  @@index([tenantId])
  @@index([expiresAt])
  @@map("oauth_state")
}

model Vendor {
  tenantId         String   @default("")
  id               String   @id @default(cuid())
  name             String
  currency         String   @default("USD") // Plan 073: informational "currency we usually bill this vendor in" (backfilled USD). NOT the posting authority — the A/P bill's currency comes from ApExportEvent.currency, and the QBO vendor is resolved currency-scoped from THAT (currency-suffixed DisplayName + CurrencyRef), so one Vendor row can source bills in several currencies without a unique-key change (council #4 handled QBO-side).
  terms            String? // payment terms, e.g. "Net 30" (drives Bill DueDate — U10) + "Pay at purchase"
  externalVendorId String? // QBO Vendor.Id cache (find-or-create — U10). PII stays here, never in events (D19)
  syncStatus       String   @default("synced") // Plan 077: synced | pending | conflict — eager QBO-push state. 'synced' = linked or doesn't need a push (existing rows); 'pending' = created, QBO push not yet done (offline → retry sweep); 'conflict' = the push hit the (tenantId, externalVendorId) unique.
  // Plan 069: first-class vendor management. Contact + purchasing metadata, columns-only (RLS-neutral — the
  // existing vendor tenant_isolation policy covers new columns). phone/email are REQUIRED in the setup UI but
  // stay nullable at the DB so backfill + non-UI paths (A/P find-or-create, assistant) never hard-error.
  phone            String? // primary phone
  email            String? // primary email
  contactName      String? // primary contact person
  accountNumber    String? // our account number with this vendor
  poRequired       Boolean  @default(false) // does this vendor require a PO?
  url              String? // vendor website / product URL — autofills the expendables vendor-URL field
  notes            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, name]) // find-or-create by name, no dupes per tenant
  @@unique([tenantId, id]) // composite-tenant-FK target for ap_export_event (K11)
  @@unique([tenantId, externalVendorId]) // Plan 075: one QBO vendor ↔ one local vendor (NULLs are DISTINCT in PG, so unlinked vendors are unconstrained)
  @@index([tenantId])
  @@map("vendor")
}

// Plan 069: additional contacts attached to a vendor (0..N, beyond the vendor's own core contact info).
// Tenant-scoped + RLS-forced (Phase 12). `vendorId` is a PLAIN ref pinned by a composite (tenantId, vendorId)
// FK in raw SQL (K11/K12) — NO Prisma relation (mirrors ap_export_event.vendorId / equipment_asset.locationId).
model VendorContact {
  tenantId  String   @default("")
  id        String   @id @default(cuid())
  vendorId  String // plain ref → vendor.id (composite-tenant FK in raw SQL, K11)
  name      String
  role      String? // e.g. "Sales rep", "Accounts payable"
  phone     String?
  mobile    String?
  email     String?
  isPrimary Boolean  @default(false) // at most one primary per vendor (enforced in the core)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, id]) // composite-tenant-FK target parity + K11
  @@index([tenantId])
  @@index([tenantId, vendorId])
  @@map("vendor_contact")
}

// Plan 075: user-defined measurement units, per tenant. A custom unit is structurally identical to a
// built-in (src/lib/units/measure.ts): a `dimension` (mass|volume|count) + a `perCanonical` factor — how
// many canonical base units (g / mL / count) one of this unit is worth. Weight/volume units MUST carry a
// real factor because portions get consumed via convert(); count units default to 1. Custom units live at
// the INTAKE/display boundary ONLY — stored stock stays canonical (g/mL/unit), so the cost core and
// coerceStockUnit are untouched. Tenant-scoped + RLS-forced (Phase 12). `normalizedName` is the lowercased
// de-dupe/lookup key. No cross-table FK (units aren't referenced by id — materials store the unit STRING).
model CustomUnit {
  tenantId       String   @default("")
  id             String   @id @default(cuid())
  name           String // as the user typed it, e.g. "drum", "tote", "roll"
  normalizedName String // lowercased/trimmed lookup + de-dupe key
  dimension      String // "mass" | "volume" | "count" (MeasureDimension)
  perCanonical   Decimal // canonical base units per 1 of this unit (g / mL / count); always > 0
  label          String? // optional display label (defaults to name in the UI)
  createdBy      String? // user id who created it (audit; nullable for backfill / non-UI paths)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, normalizedName]) // one unit name per tenant — the find-or-reject-dupes key
  @@unique([tenantId, id]) // composite-tenant-FK target parity (K11)
  @@index([tenantId])
  @@map("custom_unit")
}

// Plan 075 (QBO vendor sync, Slice 1): the review queue for QBO vendors pulled in but not yet resolved to a local
// Vendor. Every pulled QBO vendor is matched (by externalVendorId, else the Plan 074 fuzzy matcher); an
// unmatched one lands here for a human to accept / reject / merge-into-existing. Currency-variant QBO records
// ("Acme" / "Acme (EUR)", Plan 073) collapse into ONE candidate keyed on the stripped base name — the extra QBO
// ids ride along in currencyVariantIds. Tenant-scoped + RLS (Phase 12); a composite (tenantId, suggestedVendorId)
// FK pins any suggested match to a same-tenant vendor (K11). REJECTED rows are suppression tombstones (kept so a
// re-pull doesn't re-surface them); accepted/merged candidates are DELETED (the link lives on Vendor.externalVendorId).
model VendorImportCandidate {
  tenantId           String   @default("")
  id                 String   @id @default(cuid())
  externalVendorId   String // QBO Vendor.Id — the canonical/base id of a collapsed currency-variant group
  name               String // the collapsed base DisplayName (Plan 073 " (CUR)" suffix stripped)
  suggestedVendorId  String? // a HIGH local match, if any (plain ref → vendor.id; composite FK in raw SQL, K11)
  status             String   @default("PENDING") // PENDING | REJECTED (no enum — sidesteps the Windows ALTER TYPE rule)
  currencyVariantIds String[] // every QBO id collapsed into this candidate (base + its " (CUR)" variants)
  firstSeenAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tenantId, id]) // composite-tenant-FK target parity + K11
  @@unique([tenantId, externalVendorId]) // idempotent upsert key for the pull (one candidate per QBO vendor)
  @@index([tenantId])
  @@map("vendor_import_candidate")
}

model ApExportEvent {
  tenantId                  String                @default("")
  id                        String                @id @default(cuid())
  postingKey                String // `ap:${supplyLotId}` (:rev) — or Plan 076 `apinv:${ingestedInvoiceId}` for a whole-invoice aggregate bill — per-tenant idempotent
  supplyLotId               String? // the receipt this AP event came from (traceability; no hard FK)
  ingestedInvoiceId         String? // Plan 076: set on an AGGREGATE per-invoice event (one Bill per invoice); traceability, no hard FK (mirrors supplyLotId)
  billLinesJson             Json? // Plan 076: the QBO Bill's multiple lines for an aggregate event — [{ debitAccount, amount, description }] in the document currency (null = single-line legacy per-lot bill)
  paymentStatus             ApPaymentStatus? // Plan 076: OUTSTANDING (owed) | PAID (a BillPayment recorded). null on legacy events.
  paidFromAccount           String? // Plan 076: the QBO account the payment came from (bank or credit-card liability) — drives BillPayment
  paidAt                    DateTime? // Plan 076: when marked paid (app-side or read back from QBO)
  paymentExternalId         String? // Plan 076: the QBO BillPayment Id once posted (idempotency + reversal guard)
  vendorInvoiceNumber       String? // Plan 072: supplier invoice # — carried to the QBO Bill's PrivateNote memo (searchable; per-lot bills stay separate). NOT a grouping/idempotency key. RLS-neutral column add.
  vendorId                  String? // composite-tenant FK -> vendor (raw SQL)
  amount                    Decimal               @db.Decimal(18, 8) // Plan 073: the FOREIGN (document-currency) amount for a foreign bill — QBO derives the home GL = amount × exchangeRate (council #1, decoupled from SupplyLot base cost). Home-currency bills: amount == home amount, exchangeRate null.
  debitAccount              String? // Inventory Asset (resolved at emit; null => withheld)
  creditAccount             String? // Accounts Payable
  currency                  String                @default("USD") // the bill/document currency (EUR for a foreign bill)
  exchangeRate              Decimal?              @db.Decimal(18, 8) // Plan 073: HOME per 1 FOREIGN (USD per 1 EUR) — the QBO Bill ExchangeRate. null when currency == home (council #5 direction).
  receivedAt                DateTime
  dueDate                   DateTime?
  reversalOfApExportEventId String?
  basisCompleteness         CostBasisCompleteness @default(KNOWN)
  createdAt                 DateTime              @default(now())

  @@unique([tenantId, postingKey]) // idempotent re-emit
  @@unique([tenantId, id]) // composite-tenant-FK target for accounting_delivery (K11)
  @@index([tenantId])
  @@index([tenantId, supplyLotId])
  @@index([tenantId, ingestedInvoiceId]) // Plan 076: fetch the aggregate event for an invoice
  @@map("ap_export_event")
}

model AccountingDelivery {
  tenantId           String         @default("")
  id                 String         @id @default(cuid())
  connectionId       String // composite-tenant FK -> accounting_connection (raw SQL)
  costExportEventId  String? // composite-tenant FK -> cost_export_event (exactly-one-of-three — CHECK in SQL)
  apExportEventId    String? // composite-tenant FK -> ap_export_event
  salesExportEventId String? // Phase 16: composite-tenant FK -> sales_export_event (DTC revenue delta)
  status             DeliveryStatus @default(PENDING)
  objectType         String? // "JournalEntry" | "Bill" (A2 — ONE poster, typed by object)
  attemptCount       Int            @default(0)
  requestId          String? // deterministic QBO RequestId (idempotency)
  externalId         String? // QBO object Id once posted
  postingDate        DateTime? // GL posting date (current open period for reversals — U11)
  withheldReason     String?
  lastError          String?
  claimedAt          DateTime?
  leaseExpiresAt     DateTime?
  verifiedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([tenantId, costExportEventId]) // <=1 delivery per cost export event
  @@unique([tenantId, apExportEventId]) // <=1 delivery per AP export event
  @@unique([tenantId, salesExportEventId]) // Phase 16: <=1 delivery per sales export delta
  @@index([tenantId])
  @@index([tenantId, connectionId])
  @@map("accounting_delivery")
}

// ───────────────────────── Plan 072: invoice / document ingestion (staging + provenance) ─────────────────────────
// Tenant-scoped, RLS-forced (Phase-12 pattern). A dropped pile of supplier docs is OCR/LLM-extracted into
// these STAGING rows, human-reviewed on one screen, then applied through the existing material/vendor cores
// (createStockMaterialCore / receiveSupplyCore / findOrCreateVendorCore) — nothing here touches the ledger
// directly. Cross-tenant-risk refs (vendorId, materialId, supplyLotId, ingestedInvoiceId) are COMPOSITE
// (tenantId, refId)→(tenantId, id) FKs in the migration raw SQL (K11) — plain String cols, NO Prisma
// relation (mirrors ap_export_event.vendorId + the inbox tables; children queried explicitly). Money is
// Decimal(18,8) (D9); NULL cost = UNKNOWN (D14), never $0.

// One ingested document (header). docType routes it: only `invoice` (+ a landed `proforma`) is a receipt;
// `coa`/`other` are stored for provenance but never intaken. `status` drives the apply state machine
// (pending → applying → applied | discarded | held); the pending→applying compare-and-set is the concurrency
// claim (one apply at a time, ChatGPT #4). `extractedJson` is the raw structured extraction (audit + reload).
model IngestedInvoice {
  tenantId            String    @default("")
  id                  String    @id @default(cuid())
  batchId             String // ingestion session id — scopes same-session COA↔invoice matching (Unit 10)
  blobUrl             String // private Vercel Blob URL of the source document
  fileName            String
  mimeType            String
  fileSha256          String? // exact-file duplicate guard (alongside vendor+invoice#); the blob helper computes it
  docType             String // invoice | proforma | coa | other
  status              String    @default("pending") // pending | applying | applied | discarded | held
  currency            String? // one currency per document (mixed-currency rejected upstream) — the invoice/foreign currency
  // Plan 073: the FX rate applied at apply time (editable pre-apply on the review screen; locked once applied — council #3).
  baseCurrency        String? // the tenant base currency the lines were converted TO (snapshot at apply)
  fxRate              Decimal?  @db.Decimal(18, 8) // base per 1 foreign (manual override or the resolved ECB rate)
  fxRateDate          DateTime? // the rate date used
  fxRateSource        String? // "ECB via Frankfurter" | "manual override"
  vendorId            String? // composite-tenant FK → vendor (raw SQL, K11); resolved on apply
  vendorNameRaw       String? // extracted vendor name before match/create
  vendorInvoiceNumber String? // supplier invoice # — duplicate-upload guard on (vendor, invoice#)
  invoiceTotal        Decimal?  @db.Decimal(18, 8) // extracted grand total — the reconciliation-gate target (Unit 7)
  taxTotal            Decimal?  @db.Decimal(18, 8) // extracted tax — surfaced in the gate, excluded from capitalized landed cost
  landedReceipt       Boolean? // proforma gate answer: true = goods physically received IN FULL → intake as a receipt
  // Plan 076: A/P payment status chosen on the review screen (required before confirm) and carried to the
  // aggregate A/P event → QBO. PAID records a BillPayment from paidFromAccount; OUTSTANDING posts the Bill only.
  paymentStatus       ApPaymentStatus? // null until the human picks (gate blocks confirm)
  paidFromAccount     String? // the QBO account the payment came from (required when PAID)
  paidAt              DateTime? // when marked paid (app-side or read back from QBO)
  extractedJson       Json // full structured extraction result (audit + review reload)
  createdBy           String // actor userId who uploaded/ingested
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  appliedAt           DateTime?

  @@unique([tenantId, id]) // composite-tenant-FK target for ingested_invoice_line + lot_document (K11)
  @@index([tenantId])
  @@index([tenantId, batchId]) // same-session COA matching
  @@index([tenantId, vendorId, vendorInvoiceNumber]) // duplicate-invoice soft-dedup lookup
  @@index([tenantId, fileSha256]) // exact-file duplicate lookup
  @@map("ingested_invoice")
}

// One extracted line of an ingested invoice (editable staging). `matchDecision` (new|existing|skip) + the
// resolved fields carry the human's dedup + classification choices; `createdSupplyLotId` is a
// belt-and-suspenders audit link written INSIDE the atomic apply tx (the apply is all-or-nothing via an
// injected tx, NOT resumed off this marker — the marker-outside-tx design was unsound, council P1).
// Plan 080 U5 (council C5) — an invoice line for 2 pumps creates TWO EquipmentAssets, and a single FK on
// the line cannot represent N of them. This append-only join records every asset a line minted, so the
// line→assets provenance survives and a reversal knows exactly what to undo.
model IngestedInvoiceLineCreatedAsset {
  tenantId         String   @default("")
  id               String   @id @default(cuid())
  lineId           String // composite-tenant FK → ingested_invoice_line(tenantId,id)
  equipmentAssetId String // composite-tenant FK → equipment_asset(tenantId,id)
  createdAt        DateTime @default(now())

  @@unique([tenantId, id])
  @@unique([tenantId, lineId, equipmentAssetId]) // idempotent: one row per (line, asset)
  @@index([tenantId])
  @@index([tenantId, lineId])
  @@map("ingested_invoice_line_created_asset")
}

model IngestedInvoiceLine {
  tenantId           String   @default("")
  id                 String   @id @default(cuid())
  ingestedInvoiceId  String // composite-tenant FK → ingested_invoice (raw SQL, K11)
  lineNo             Int
  descriptionRaw     String
  vendorItemCodeRaw  String?
  qty                Decimal? @db.Decimal(18, 6)
  unitRaw            String? // invoice UOM (e.g. "25 kg", "case") — normalized to the material's stock unit at apply (Unit 5)
  unitPrice          Decimal? @db.Decimal(18, 8) // per invoice unit (NULL = unknown, D14 — never a fabricated $0)
  lineTotal          Decimal? @db.Decimal(18, 8) // extracted line extended total (charge-allocation basis)
  lotNoRaw           String? // supplier lot no. (→ SupplyLot.lotCode; the COA match key)
  allocatedUnitCost  Decimal? @db.Decimal(18, 8) // per-stock-unit landed cost after charge allocation + UOM normalize (Unit 5)
  matchDecision      String? // new | existing | skip (human dedup decision; null = undecided)
  matchedMaterialId  String? // existing/backfill target — composite-tenant FK → cellar_material (raw SQL, K11)
  resolvedKind       String? // material family for a `new` line
  resolvedCategory   String? // material category for a `new` line (EQUIPMENT for parts)
  createdSupplyLotId String? // audit: the SupplyLot this line created (set inside the atomic apply tx)
  // Plan 080 U5 — where this line's goods GO. NULLABLE with NO default (council C2): a null target is a
  // hard needsAck at apply, never a silent MATERIAL assumption, because guessing mis-posts real money.
  // CHECK-constrained in SQL to {MATERIAL, EQUIPMENT_ASSET, FINISHED_GOOD}.
  targetKind         String?
  // Finished-goods target, resolved at REVIEW time — apply-time auto-create is irreversible (council S11).
  // Exactly one may be set, and only when targetKind = FINISHED_GOOD (CHECK-constrained).
  wineSkuTargetId    String? // composite-tenant FK → wine_sku(tenantId,id) (raw SQL, K11)
  finishedGoodTargetId String? // composite-tenant FK → finished_good(tenantId,id) (raw SQL, K11)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tenantId, id])
  @@unique([tenantId, ingestedInvoiceId, lineNo]) // stable line identity within an invoice
  @@index([tenantId])
  @@index([tenantId, ingestedInvoiceId])
  @@map("ingested_invoice_line")
}

// Provenance join: links a created SupplyLot to its source document(s). A lot can carry its INVOICE plus
// one-or-more COAs (role distinguishes). Powers the tenant-scoped "view source PDF" on the lot/material
// history (Unit 10). Both refs are composite-tenant FKs (raw SQL, K11).
model LotDocument {
  tenantId          String   @default("")
  id                String   @id @default(cuid())
  supplyLotId       String // composite-tenant FK → supply_lot (raw SQL, K11)
  ingestedInvoiceId String // composite-tenant FK → ingested_invoice (raw SQL, K11)
  role              String // INVOICE | COA
  createdAt         DateTime @default(now())

  @@unique([tenantId, id])
  @@unique([tenantId, supplyLotId, ingestedInvoiceId, role]) // one link per (lot, doc, role)
  @@index([tenantId])
  @@index([tenantId, supplyLotId])
  @@index([tenantId, ingestedInvoiceId])
  @@map("lot_document")
}

// Vendor-scoped supplier item-code → material mapping (the re-order learning loop). The SAME material bought
// from two vendors has two codes, so a code is unique per (tenant, vendor, code) — NEVER global. Backfilled
// only on a human-confirmed `existing` match (Unit 7) so one bad OCR code can't poison future dedup. Both
// refs are composite-tenant FKs (raw SQL, K11).
model VendorMaterialCode {
  tenantId   String   @default("")
  id         String   @id @default(cuid())
  vendorId   String // composite-tenant FK → vendor (raw SQL, K11)
  materialId String // composite-tenant FK → cellar_material (raw SQL, K11)
  code       String // supplier's item/catalog code for this material
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, id])
  @@unique([tenantId, vendorId, code]) // vendor-scoped code identity (dedup match key)
  @@index([tenantId])
  @@index([tenantId, materialId])
  @@map("vendor_material_code")
}

// ───────────────────────── Phase 16: Commerce7 DTC/sales integration ─────────────────────────
// Tenant-scoped, RLS-isolated (Phase-12 checklist). The revenue side of the money loop: pull settled
// Commerce7 DTC/club/POS orders in, deplete finished goods (SALE StockMovement), post DTC revenue
// through the SAME AccountingDelivery outbox/poster as Phase 15, and mirror finished-goods INCREASES
// back to Commerce7 (additive, watermark-idempotent). ERP is authoritative; Commerce7 is a replica.
//
// Commerce7 has NO OAuth — App ID + Secret Key over HTTP Basic Auth + a `tenant:` header (env-resident,
// never a DB column). So there is no token table here; the "install" is nonce-bound (commerce7_install_state
// reuses the OAuthState single-use-nonce pattern) and the connection carries no secret. PII is
// data-minimized (D19): the order projection + delta events + dirty markers hold only opaque ids +
// amounts + SKU refs — NEVER a customer name/email (a schema test asserts this).

enum CommerceProvider {
  COMMERCE7
  WINEDIRECT // v1 unused — the provider-neutral seam is WineDirect-ready
}

// The kind of economic delta a normalize→diff pass emits for a mutable order (append-only, D2/D6):
// the first settled snapshot is a SALE; a later edit is an ADJUSTMENT of the difference; a cancel is a
// REVERSAL; a (full/partial) refund is a REFUND. Each posts the DIFFERENCE, never a re-book.
enum SalesDeltaKind {
  SALE
  ADJUSTMENT
  REVERSAL
  REFUND
}

// Per-tenant Commerce7 link. NO token columns (the app Secret Key is env-global). status uses the
// shared ConnectionStatus incl. PENDING_CONFIRM (nonce-verified but awaiting admin confirm). The poll
// watermark (updatedAt, id) lives here so the reconciler advances only past a fully-drained page.
model Commerce7Connection {
  tenantId            String           @default("")
  id                  String           @id @default(cuid())
  provider            CommerceProvider @default(COMMERCE7)
  status              ConnectionStatus @default(DISCONNECTED)
  environment         String // "sandbox" | "production"
  externalTenantId    String? // the Commerce7 tenant slug (naming the winery in the `tenant:` header)
  scopes              String[]
  installedByUserId   String?
  webhookId           String? // the registered Commerce7 webhook id (for delete/recreate — U8)
  webhookConfiguredAt DateTime?
  lastWebhookAt       DateTime? // last inbound webhook hint (webhook-health chip; stale → recreate)
  lastPolledAt        DateTime?
  pollCursorUpdatedAt DateTime? // (updatedAt, id) composite poll watermark with overlap
  pollCursorId        String?
  // Phase 16 U6 — the inventory cron writes a read-only DRIFT SUMMARY here (ERP on-hand vs C7 available
  // per mapped variant). Surfaced in the dashboard for human review; NEVER auto-corrects C7 inventory.
  driftSummary        Json?
  driftCheckedAt      DateTime?
  companyName         String? // display only ("Connected to <winery>") — non-secret
  connectedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@unique([tenantId, provider]) // one commerce connection per tenant per provider
  @@unique([tenantId, id]) // composite-tenant-FK target (K11)
  @@index([tenantId])
  @@map("commerce7_connection")
}

// Short-lived, single-use install nonce (reuses the OAuthState shape). Bound to the initiating admin +
// workspace so an unauthenticated install callback cannot link a victim's Commerce7 tenant (P0 fix).
model Commerce7InstallState {
  tenantId  String   @default("")
  id        String   @id @default(cuid())
  nonceHash String // SHA-256 of the random nonce; the raw nonce is never stored
  userId    String // the admin who initiated; re-checked at confirm time
  sessionId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([tenantId, nonceHash]) // consumed with DELETE … RETURNING (single-use)
  @@index([tenantId])
  @@index([expiresAt])
  @@map("commerce7_install_state")
}

// SKU mapping: a Commerce7 (variant, inventory-location) ↔ our (WineSku, Location). Match, never
// silently create (respect the NV partial-unique split). `lastPushedMovementAt`/`lastPushedMovementId`
// is the OUTBOUND (createdAt, id) watermark for additive inventory push (StockMovement has no numeric
// seq, so the watermark is the same composite cursor shape the poller uses). wineSkuId is a
// composite-tenant FK (SQL); locationId is a plain ref (resolved at runtime).
model Commerce7SkuMap {
  tenantId                    String    @default("")
  id                          String    @id @default(cuid())
  externalProductId           String
  externalVariantId           String
  externalSku                 String
  externalInventoryLocationId String
  wineSkuId                   String? // composite-tenant FK -> wine_sku (raw SQL)
  locationId                  String? // our finished-goods Location (plain ref)
  lastPushedMovementAt        DateTime? // outbound watermark (createdAt of the last pushed movement)
  lastPushedMovementId        String? // …with id as the tiebreak, so the push is idempotent
  active                      Boolean   @default(true)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@unique([tenantId, externalVariantId, externalInventoryLocationId])
  @@index([tenantId])
  @@index([tenantId, wineSkuId])
  @@map("commerce7_sku_map")
}

// The MUTABLE order projection (NO PII). Keyed by the stable Commerce7 order id. `normalizedSnapshot`
// is the last-known economic snapshot (sku+qty+cents+tax+discount, no PII) we diff against; `dirty`
// is the webhook hint. `lastSeenUpdatedAt` + id back the poll watermark. `withheldReason` records a
// still-un-emitted order (unmapped SKU/account) so the dashboard can surface it.
model Commerce7Order {
  tenantId             String    @default("")
  id                   String    @id @default(cuid())
  commerce7OrderId     String // stable Commerce7 order UUID
  commerce7OrderNumber String?
  commerce7CustomerId  String? // opaque Commerce7 id ONLY — never a name/email (D19)
  channel              String? // DTC / club / POS (kept allocation-ready)
  paymentStatus        String? // Paid | Authorized | Cancelled | …
  fulfillmentStatus    String?
  normalizedSnapshot   Json? // last-known PII-free economic snapshot (the diff base)
  lastDeltaSeq         Int       @default(0)
  dirty                Boolean   @default(false)
  withheldReason       String?
  lastSeenUpdatedAt    DateTime?
  occurredAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([tenantId, commerce7OrderId])
  @@unique([tenantId, id]) // composite-tenant-FK target (K11)
  @@index([tenantId])
  @@index([tenantId, dirty])
  @@index([tenantId, lastSeenUpdatedAt, commerce7OrderId]) // poll watermark
  @@map("commerce7_order")
}

// IMMUTABLE append-only revenue DELTA (NO PII), mirroring cost_export_event/ap_export_event. Each is
// the DIFFERENCE for one order edit; `postingKey = sale:${orderId}:v${deltaSeq}` is per-tenant unique
// so a replay is a no-op. Accounts are resolved + frozen at emit (null → withheld, never posted).
// `reversalOfSalesExportEventId` links a REFUND/REVERSAL back to what it reverses.
model SalesExportEvent {
  tenantId                     String         @default("")
  id                           String         @id @default(cuid())
  postingKey                   String // sale:${orderId}:v${deltaSeq}
  commerce7OrderId             String
  deltaSeq                     Int
  kind                         SalesDeltaKind
  currency                     String         @default("USD")
  channel                      String? // carried from the order projection (allocation-ready margin)
  revenueDelta                 Decimal        @db.Decimal(18, 8)
  salesTaxDelta                Decimal        @default(0) @db.Decimal(18, 8)
  shippingDelta                Decimal        @default(0) @db.Decimal(18, 8)
  discountDelta                Decimal        @default(0) @db.Decimal(18, 8)
  lineDeltas                   Json // [{ skuRef, qtyDelta }] — no PII
  revenueAccount               String?
  clearingAccount              String?
  taxAccount                   String?
  shippingAccount              String?
  discountAccount              String?
  reversalOfSalesExportEventId String?
  accountingDate               DateTime // the sale's winery-local business date (period matching)
  occurredAt                   DateTime
  createdAt                    DateTime       @default(now())

  @@unique([tenantId, postingKey]) // idempotent re-emit / exactly-once
  @@unique([tenantId, id]) // composite-tenant-FK target for accounting_delivery (K11)
  @@index([tenantId])
  @@index([tenantId, commerce7OrderId])
  @@map("sales_export_event")
}

// ───────────────────────── plan-027: compliance filing-deadline reminders ─────────────────────────
// Two tenant-scoped, RLS-isolated tables (Phase-12 checklist). Deadlines themselves are DERIVED (a pure
// function of cadence + filed-status), never stored; the only persisted state is the per-user opt-in +
// the idempotent send log.

// Per-user opt-in for reminder EMAILS, per tenant (admin-managed in User Management). userId is the
// global Better-Auth user id; the pref is tenant-scoped so the same person can opt in per winery.
model ComplianceReminderPreference {
  tenantId         String   @default("")
  id               String   @id @default(cuid())
  userId           String
  remindersEnabled Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("compliance_reminder_preference")
}

// Idempotent send log: at most one email per (tenant, form, period, mark, recipient). The daily cron
// inserts PENDING → sends → marks SENT; a stale PENDING is retried (council S2). recipientEmail is a
// durable snapshot so a later user deletion doesn't orphan the audit row (no FK on recipientUserId).
model ComplianceReminderLog {
  tenantId        String    @default("")
  id              String    @id @default(cuid())
  form            String // "5120.17" | "5000.24"
  periodKey       String // deadlines.ts periodKey, e.g. "5120.17:2026-06-30"
  dueDate         DateTime
  mark            String // WEEK | TWO_DAY | DAY_OF
  recipientUserId String
  recipientEmail  String
  status          String    @default("PENDING") // PENDING | SENT
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, form, periodKey, mark, recipientUserId])
  @@index([tenantId])
  @@map("compliance_reminder_log")
}

// ───────────────────────── Phase 9: Work Orders (issue → execute → auto-log → approve → finalize) ─────────────────────────
// Enums land FIRST in their own isolated migration (20260703010000_work_order_enums), committed before
// any table references them (the Windows enum rule). The tables + RLS follow in the sibling
// _work_order_schema / _work_order_rls migrations. See docs/plans/2026-07-03-032-feat-work-orders-plan.md.

// The work-order shell lifecycle. A guarded status machine (mirrors SampleStatus): DRAFT is the
// pre-issue editable state; ISSUED assigns + schedules + reserves; IN_PROGRESS = a crew tapped Start
// (D5 live claim); PENDING_APPROVAL = every task is done and at least one awaits review; APPROVED is
// terminal (all tasks finalized); CANCELLED is terminal.
enum WorkOrderStatus {
  DRAFT
  ISSUED
  IN_PROGRESS
  PENDING_APPROVAL
  APPROVED
  CANCELLED
}

// A single task's lifecycle. PENDING (issued, not started) → IN_PROGRESS (claimed, D5) →
// PENDING_APPROVAL (an OPERATION task completed; a real immutable op exists, awaiting review) →
// APPROVED (finalized) | REJECTED (op reversed; resubmit allowed → back to PENDING per decision 1).
// DONE is the OBSERVATION-lane terminal (no approval gate). SKIPPED = intentionally not done.
// A5: the status enum IS the approval state — there is no separate approvalStatus column.
enum WorkOrderTaskStatus {
  PENDING
  IN_PROGRESS
  PENDING_APPROVAL
  APPROVED
  REJECTED
  DONE
  SKIPPED
}

// OPERATION tasks write a real ledger op on completion (approval-gated). OBSERVATION tasks write
// directly to the measurement store (chem/ferment/tasting), no approval gate, no reservation.
enum WorkOrderTaskKind {
  OPERATION
  OBSERVATION
  MAINTENANCE // Phase 9.1: vessel-activity lane (temp setpoints + cleaning/sanitizing/steaming/gas) — lotless, no ledger op, no approval gate
  NOTE // Plan 034: free-text checklist item — a checkable line, completes straight to DONE, writes NOTHING (no ledger op, no measurement, no vessel-activity, no cost). No approval gate, no reservation.
}

// Phase 9.1 (Unit 3): the vessel-scoped, lotless activity subtypes. A setpoint/maintenance task is NOT
// a wine operation (no lot, no ledger op) — it records intent + optional overhead supply use on a vessel
// that may be empty, partial, or full. Stored on VesselActivityEvent.kind AND mirrored onto
// WorkOrderTask.activityType (A3, a validated String) so archive/print/detail can render + filter it.
enum VesselActivityKind {
  TEMP_SETPOINT // cold-settle / warm-to-start / cool-to-arrest — a target temperature hold
  CLEAN // tank/barrel cleaning (proxycarb, caustic) — consumes a CLEANING supply as overhead
  SANITIZE // sanitization (PAA, ozone) — consumes a SANITIZER supply as overhead
  STEAM // barrel/tank steaming — typically no supply
  GAS // inert gas / sparging (Ar / N₂ / CO₂ / dry ice) headspace blanket (dec 2)
  OZONE // ozone / ozonated-water barrel sanitation (plan 044) — typically no supply
  SO2 // SO₂ treatment: burned sulfur strip/ring OR SO₂ gas (plan 044) — method on targetUnit, strips/discs drain as overhead
  WET_STORAGE // change/replenish citric+SO₂ storage solution in a wet-stored empty barrel (plan 044) — reagents drain as overhead
  OTHER
}

// A1 (council + eng P0): a task can't be a one-shot wrapper around an immutable op. Each execution
// is an append-only ATTEMPT that owns the commandId (idempotency on the immutable event, not the
// mutable task) and links to its operation. A rejected attempt is reversed; a resubmit is a NEW
// attempt. PENDING_APPROVAL → APPROVED | REJECTED.
enum WorkOrderTaskAttemptStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

// Soft, advisory, expiring holds (warn-not-block). ACTIVE holds count against available-to-promise;
// RELEASED (completed/cancelled/reconciled) and EXPIRED (past validUntil) do not. Hard capacity +
// SupplyLot decrements at commit remain the real guarantee (WORKORDER-2).
enum ReservationStatus {
  ACTIVE
  RELEASED
  EXPIRED
}

// What a reservation holds. LOT_VOLUME = source-lot liters; VESSEL_CAPACITY = destination headroom;
// MATERIAL_QTY = supply on-hand at the MATERIAL level (A9 — never a specific SupplyLot, so it doesn't
// fight the FIFO/WA costing engine).
enum ReservationKind {
  LOT_VOLUME
  VESSEL_CAPACITY
  MATERIAL_QTY
}

// ── Work Order tables (Phase-12 checklist verbatim; migrations 20260703010100_work_order_schema +
// _work_order_rls). tenantId + @@index, per-tenant uniques, @@unique([tenantId, id]) targets, and RLS.
// Cluster relations (WO↔task↔attempt↔template↔version↔reservation) are declared single-column here;
// their composite (tenantId, refId)→(tenantId, id) FKs live in the migration raw SQL (repo convention,
// K11). External refs (lotId/vesselId/materialId/operationId) are PLAIN SCALARS — no Prisma relation,
// so Lot/Vessel/CellarMaterial/LotOperation stay untouched; their composite FKs are also raw SQL. Do
// NOT add these models to GLOBAL_MODELS. Money/qty Decimal(18,6); volumes fit within it too. ──

// The work-order shell: issue → assign → schedule → execute → approve → finalize. Status is the single
// source of truth for approval state (A5 — no separate approvalStatus column); timestamps + *ById/*ByEmail
// carry provenance. `autoFinalize` = decision-2 config (admin approves; self-executed auto-finalizes).
model WorkOrder {
  tenantId             String          @default("")
  id                   String          @id @default(cuid())
  number               Int // per-tenant human WO number (assigned on issue)
  title                String
  status               WorkOrderStatus @default(DRAFT)
  templateVersionId    String? // the version snapped onto this instance at issue (immutable thereafter)
  instructions         String? // order-level notes (Unit 9)
  // Canonical query columns (A6) — the WO's default assignee + schedule; JSON stays a snapshot only.
  assigneeId           String?
  assigneeEmail        String?
  dueAt                DateTime?
  // Did the requester ask for a TIME OF DAY, or just a date? `dueAt` is an instant either way, so the
  // stored value alone can't tell "the 23rd" from "the 23rd at midnight" — and midnight work is real
  // during harvest, so it can't be inferred. Every legacy row was date-only, hence the `false` default.
  dueAtHasTime         Boolean         @default(false)
  scheduledFor         DateTime?
  // Plan 053 B8: ERP planning fields (data capture only; no auto-scheduling). priority is a validated
  // string (LOW/NORMAL/HIGH/URGENT — no enum, Windows ALTER TYPE hazard); scheduledStart/End are a window.
  priority             String?
  estimatedDurationMin Int?
  scheduledStart       DateTime?
  scheduledEnd         DateTime?
  locationId           String? // plan 053 B9: where the work happens (plain ref → location.id, resolved at runtime; K11/K12)
  autoFinalize         Boolean         @default(false) // auto-finalize self-executed work (decision 2)
  issuedAt             DateTime?
  issuedById           String?
  issuedByEmail        String?
  startedAt            DateTime? // D5 live claim ("in progress by …")
  startedById          String?
  startedByEmail       String?
  completedAt          DateTime?
  approvedAt           DateTime?
  approvedById         String?
  approvedByEmail      String?
  cancelledAt          DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  tasks           WorkOrderTask[]
  reservations    Reservation[]
  templateVersion WorkOrderTemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)

  @@unique([tenantId, number])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, status, dueAt]) // A7: dashboard bucketing (scheduled/today/overdue/pending)
  @@index([tenantId, status, updatedAt]) // E2: archive recency sort (finalized WOs by most-recent)
  @@map("work_order")
}

// Plan 053 A5: cross-order dependency ("finish WO-A before you start WO-B"). A directed edge: the
// dependent `workOrderId` is WARNED at task start and HARD-BLOCKED from completion until every
// `dependsOnWorkOrderId` (predecessor) is worker-complete (all its tasks worker-completed). Tenant-scoped
// + RLS-isolated (Phase 12). Both endpoints carry a composite cross-tenant FK to work_order(tenantId, id)
// in RAW SQL (K11 — no Prisma @relation), so an edge can never span tenants; ON DELETE CASCADE clears a
// deleted WO's edges. Cycle prevention is enforced in the same tx as the insert (SF6).
model WorkOrderDependency {
  tenantId             String   @default("")
  id                   String   @id @default(cuid())
  workOrderId          String // the dependent WO (blocked by the predecessor)
  dependsOnWorkOrderId String // the predecessor WO that must finish first
  createdAt            DateTime @default(now())
  createdById          String?
  createdByEmail       String?

  @@unique([tenantId, workOrderId, dependsOnWorkOrderId])
  @@index([tenantId, workOrderId])
  @@index([tenantId, dependsOnWorkOrderId])
  @@map("work_order_dependency")
}

// Plan 053 B10: a simple equipment registry (presses, filters, pumps…). Tenant-scoped + RLS-isolated.
// `kind`/`status` are validated strings (no enum). Referenced by work-order tasks as ADVISORY required
// equipment (WorkOrderTaskEquipment) — surfaced, never blocks (WORKORDER-2). Maintenance stays record-only.
model EquipmentAsset {
  tenantId   String   @default("")
  id         String   @id @default(cuid())
  name       String
  kind       String // press / filter / pump / tank-accessory / other (validated string)
  status     String   @default("available") // available / in_use / maintenance / retired
  locationId String? // plain ref → location.id (K11/K12)
  notes      String?
  isActive   Boolean  @default(true)
  // Plan 080 U3: acquisition cost + invoice provenance (all nullable — existing assets stay uncosted; a
  // capitalized asset is a FIXED ASSET, never dosed: EQUIPMENT stays non-doseable, WORKORDER-7).
  // `purchaseCostBase` is ALWAYS the tenant BASE currency (the roll-up basis, COST-4); the foreign quintet
  // below mirrors SupplyLot exactly — immutable historical provenance (IAS 21), audit only, never revalued.
  purchaseCostBase    Decimal?  @db.Decimal(18, 8)
  currency            String?   @default("USD") // the BASE currency stamp for purchaseCostBase
  foreignPurchaseCost Decimal?  @db.Decimal(18, 8) // the price in the invoice (foreign) currency
  foreignCurrency     String? // e.g. "EUR"
  fxRate              Decimal?  @db.Decimal(18, 8) // base per 1 foreign at purchase (base == foreign × fxRate)
  fxRateDate          DateTime? // the ECB quote date the rate was for
  fxRateSource        String? // e.g. "ECB via Frankfurter" | "manual override"
  purchaseDate        DateTime?
  vendorId            String? // Plan 069/080: composite-tenant FK → vendor(tenantId,id) (raw SQL, K11)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, name])
  @@unique([tenantId, id]) // composite-FK target for work_order_task_equipment
  @@index([tenantId])
  @@index([tenantId, vendorId]) // Plan 080 U3: per-vendor asset lookups
  @@map("equipment_asset")
}

// Plan 053 B10: ADVISORY link from a work-order task to the equipment it needs. Append-only join; never
// blocks completion. Composite cross-tenant FKs (raw SQL) to work_order_task + equipment_asset (K11).
model WorkOrderTaskEquipment {
  tenantId    String   @default("")
  id          String   @id @default(cuid())
  taskId      String
  equipmentId String
  createdAt   DateTime @default(now())

  @@unique([tenantId, taskId, equipmentId])
  @@index([tenantId, equipmentId])
  @@index([tenantId, taskId])
  @@map("work_order_task_equipment")
}

// Plan 053 C11: a tenant-authored "Custom Log" task type. RECORD-ONLY by construction — there is NO kind/
// opType column, so it can never be anything but a NOTE (assertUserTaskTypeSafe re-checks on every resolve).
// fieldsJson is a CustomLogFieldSpec[] (type/options/required/dimension/stage). `code` is the per-tenant key
// used in specs/taskBuilds. Tenant-scoped + RLS-isolated (Phase 12).
model WorkOrderTaskType {
  tenantId   String    @default("")
  id         String    @id @default(cuid())
  code       String // per-tenant task-type key (e.g. "BARREL_WEIGH")
  label      String
  fieldsJson Json // CustomLogFieldSpec[]
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("work_order_task_type")
}

// Plan 053 C12: a tenant's DISPLAY customization of a BUILT-IN task type (hide/relabel/reorder fields).
// Display + template-authoring only — never changes kind/opType and can only hide fields on a per-opType
// HIDEABLE allowlist (assertOverlaySafe), so a governed core never loses a field it needs. One per built-in.
model WorkOrderTaskTypeOverlay {
  tenantId     String    @default("")
  id           String    @id @default(cuid())
  baseTaskType String // a built-in TASK_VOCABULARY key (e.g. "RACK")
  hiddenFields String[]
  relabels     Json      @default("{}") // Record<fieldKey, label>
  fieldOrder   String[]
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, baseTaskType])
  @@index([tenantId])
  @@map("work_order_task_type_overlay")
}

// One task in a work order. OPERATION tasks write a real immutable ledger op on completion (via an
// attempt); OBSERVATION tasks write to the measurement store and go straight to DONE. `plannedPayload`
// snapshots the planned inputs incl. the target RATE + basis (A3 — the amount is computed at open time
// from the vessel's then-current volume, never frozen at issue). Canonical columns (A6) mirror the JSON
// for querying + composite FKs. `currentAttemptId` is the attempt owning the task's live op (A4); it is
// a plain scalar (no FK) to avoid a cluster relation cycle — always set in the same tx as the attempt.
model WorkOrderTask {
  tenantId             String              @default("")
  id                   String              @id @default(cuid())
  workOrderId          String
  seq                  Int // display + execution order within the WO
  groupSeq             Int                 @default(0) // plan 053 A3: sequential-group index. Tasks share a group (run in parallel); a task may complete only once every task in a LOWER group is worker-completed. Positional → reject/reissue-safe, no task-dep edge table.
  kind                 WorkOrderTaskKind
  status               WorkOrderTaskStatus @default(PENDING)
  title                String
  opType               OperationType? // set for OPERATION tasks (RACK/ADDITION/TOPPING/…); null for OBSERVATION
  observationType      String? // set for OBSERVATION tasks (e.g. "BRIX", "TASTING"); null for OPERATION
  activityType         String? // A3: set for MAINTENANCE tasks (TEMP_SETPOINT/CLEAN/SANITIZE/STEAM/GAS); validated String mirror of VesselActivityKind
  instructions         String? // task-level notes (Unit 9)
  // Canonical query columns (A6) extracted from plannedPayload; composite-FK'd in raw SQL.
  sourceVesselId       String?
  destVesselId         String?
  lotId                String?
  materialId           String?
  blockId              String? // plan 039: vineyard-block target for a HARVEST_WEIGH_IN observation (composite-FK'd in raw SQL)
  assigneeId           String?
  assigneeEmail        String?
  dueAt                DateTime?
  // Plan 053 B8: per-task planning fields (data capture only). priority is a validated string.
  priority             String?
  estimatedDurationMin Int?
  scheduledStart       DateTime?
  scheduledEnd         DateTime?
  locationId           String? // plan 053 B9: where this task happens (plain ref → location.id; K11/K12)
  plannedPayload       Json // snapshot of the planned inputs (target rate + basis, note, etc.)
  currentAttemptId     String? // A4: the attempt currently owning this task's ledger op (plain scalar, no FK)
  completionNote       String?
  deviationReason      String?
  startedAt            DateTime? // D5 claim
  startedById          String?
  startedByEmail       String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  workOrder    WorkOrder              @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  attempts     WorkOrderTaskAttempt[]
  reservations Reservation[]

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, workOrderId])
  @@index([tenantId, status, dueAt]) // A7: review-queue + dashboard scans
  @@map("work_order_task")
}

// A1 (P0): each execution of a task is an append-only ATTEMPT. The commandId (idempotency key on the
// IMMUTABLE event) lives here, not on the mutable task. An attempt links to the real ledger op it wrote;
// a rejected attempt records the reversal (correctionOperationId) and a resubmit is a NEW attempt.
model WorkOrderTaskAttempt {
  tenantId              String                     @default("")
  id                    String                     @id @default(cuid())
  taskId                String
  seq                   Int // attempt number within the task (1-based)
  commandId             String                     @unique // idempotency on the immutable event
  status                WorkOrderTaskAttemptStatus @default(PENDING_APPROVAL)
  actualPayload         Json // the worker's actuals merged over the planned payload
  operationId           Int? // the immutable ledger op this attempt wrote (composite-FK'd in raw SQL)
  correctionOperationId Int? // the reversal op if this attempt was rejected (raw-SQL composite FK)
  completionNote        String?
  deviationReason       String?
  rejectedReason        String?
  completedAt           DateTime                   @default(now())
  completedById         String?
  completedByEmail      String?
  reviewedAt            DateTime?
  reviewedById          String?
  reviewedByEmail       String?
  createdAt             DateTime                   @default(now())

  task WorkOrderTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([tenantId, operationId]) // A1: one attempt per immutable op
  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, taskId])
  @@map("work_order_task_attempt")
}

// Phase 9.1 (Unit 3) — the VESSEL-ACTIVITY lane. A lotless, vessel-scoped event for temperature setpoints
// and maintenance (cleaning / sanitizing / steaming / gas). NOT a wine operation: it writes NO LotOperation,
// no CostLine, no SupplyConsumption, and never enters the Phase-8 wine cost roll-up (WORKORDER-3). It works
// on an EMPTY, PARTIAL, or FULL vessel (A6). Any overhead supply it consumes is recorded as an append-only
// VesselActivitySupplyUse child (A1) — the physical depletion record, outside the wine cost DAG. Built to the
// Phase-12 checklist; migrations 20260703020000_vessel_activity_enums + _schema + _rls. External refs
// (vesselId / materialId) + the cluster edge (taskId) are COMPOSITE (tenantId, refId)→(tenantId, id) in raw SQL.
model VesselActivityEvent {
  tenantId       String             @default("")
  id             String             @id @default(cuid())
  vesselId       String // the vessel the activity is on (composite-FK'd to vessel)
  kind           VesselActivityKind
  taskId         String? // the WO task that recorded it (composite-FK'd; null if recorded outside a WO)
  attemptId      String? // the attempt that recorded it (plain scalar, mirrors WorkOrderTask.currentAttemptId)
  targetValue    Decimal?           @db.Decimal(18, 6) // TEMP_SETPOINT target (e.g. 4.0)
  targetUnit     String? // °C | °F for TEMP_SETPOINT; the gas (Ar/N₂/CO₂/dry ice) for GAS
  achievedValue  Decimal?           @db.Decimal(18, 6) // dec 4b: the actual reading captured at completion (e.g. current tank temp)
  achievedUnit   String?
  materialId     String? // the cleaning/sanitizer/gas supply consumed, if any (composite-FK'd)
  note           String?
  observedAt     DateTime           @default(now())
  enteredById    String?
  enteredByEmail String
  commandId      String             @unique // idempotency on the immutable event (mirrors the attempt)
  voidedAt       DateTime? // A2: set when the activity is reversed/undone (its supply uses are restored)
  createdAt      DateTime           @default(now())

  supplyUses VesselActivitySupplyUse[]

  @@unique([tenantId, id]) // composite-tenant-FK target for vessel_activity_supply_use (K11)
  @@index([tenantId])
  @@index([tenantId, vesselId])
  @@index([tenantId, taskId])
  @@map("vessel_activity_event")
}

// Phase 9.1 (Unit 3, A1) — the append-only overhead depletion ledger: one row per SupplyLot drawn down by a
// vessel activity (FIFO across N lots). This is the PHYSICAL depletion record for cleaning/sanitizer/gas use;
// it is deliberately OUTSIDE SupplyConsumption / CostLine / the wine cost roll-up (WORKORDER-3) because a
// sanitizer isn't a cost of any specific wine — it's overhead. A reversal (A2) increments the SupplyLot back
// and appends a negating row (reversalOfSupplyUseId → the original). Never mutated.
model VesselActivitySupplyUse {
  tenantId              String   @default("")
  id                    String   @id @default(cuid())
  vesselActivityEventId String // parent event (composite-FK'd to vessel_activity_event)
  supplyLotId           String // the depleted lot (composite-FK'd to supply_lot)
  materialId            String // the material (composite-FK'd to cellar_material)
  qty                   Decimal  @db.Decimal(18, 6) // qty drawn from this lot (stock unit); negative on a reversal row
  unit                  String
  unitCost              Decimal? @db.Decimal(18, 8) // per stock unit; NULL = unknown cost (D14)
  extendedCost          Decimal? @db.Decimal(18, 8) // qty × unitCost; NULL when the rate is unknown
  reversalOfSupplyUseId String? // set on a negating row that restores another use (A2 identity reversal)
  createdAt             DateTime @default(now())

  event VesselActivityEvent @relation(fields: [vesselActivityEventId], references: [id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, vesselActivityEventId])
  @@index([tenantId, supplyLotId])
  @@map("vessel_activity_supply_use")
}

// A reusable template. System defaults ship seeded (isSystem); a tenant clones-on-customize
// (clonedFromId lineage). Issuing snaps the CURRENT version onto the instance so later edits never
// rewrite history. Recurring config is stored; generation is Unit 15.
model WorkOrderTemplate {
  tenantId         String    @default("")
  id               String    @id @default(cuid())
  code             String // per-tenant stable key
  name             String
  description      String?
  category         String?
  isSystem         Boolean   @default(false)
  clonedFromId     String? // lineage of a clone-on-customize (plain scalar)
  recurringCadence String? // Unit 15 config: null | "WEEKLY" | "BIWEEKLY" | "MONTHLY" (generation deferred)
  currentVersion   Int       @default(1)
  archivedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  versions WorkOrderTemplateVersion[]

  @@unique([tenantId, code])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("work_order_template")
}

// An immutable version snapshot of a template's typed-field spec (tasks + fields). Issuing a WO
// references exactly one version; editing a template creates a new version, never mutating an old one.
model WorkOrderTemplateVersion {
  tenantId       String   @default("")
  id             String   @id @default(cuid())
  templateId     String
  version        Int
  spec           Json // the validated typed-field vocabulary snapshot (task list + fields)
  createdAt      DateTime @default(now())
  createdById    String?
  createdByEmail String?

  template   WorkOrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@unique([tenantId, templateId, version])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("work_order_template_version")
}

// A soft, advisory, expiring hold (WORKORDER-2). ACTIVE holds count against available-to-promise;
// hard capacity + SupplyLot decrements at commit remain the real guarantee. Exactly one target column
// is set per `kind`. A9: MATERIAL_QTY holds at materialId (on-hand level), never a specific SupplyLot.
// A10: validUntil is SEPARATE from the task/WO dueAt and defaults well past due — a past-due WO does
// NOT auto-expire its holds (harvest would double-book otherwise).
model Reservation {
  tenantId    String            @default("")
  id          String            @id @default(cuid())
  workOrderId String
  taskId      String?
  kind        ReservationKind
  status      ReservationStatus @default(ACTIVE)
  lotId       String? // LOT_VOLUME target (composite-FK'd in raw SQL)
  vesselId    String? // VESSEL_CAPACITY target
  materialId  String? // MATERIAL_QTY target (A9)
  qty         Decimal           @db.Decimal(18, 6) // liters (lot/vessel) or stock qty (material)
  unit        String? // snapshot of the qty unit
  validUntil  DateTime // A10: hold horizon, independent of dueAt
  releasedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  workOrder WorkOrder      @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  task      WorkOrderTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@index([tenantId])
  // Partial indexes (A7) on ACTIVE holds by target are added in the migration raw SQL (Prisma can't
  // express a partial WHERE); these plain indexes back the ATP aggregation scans.
  @@index([tenantId, lotId])
  @@index([tenantId, vesselId])
  @@index([tenantId, materialId])
  @@map("reservation")
}

// ── Plan 040 PR2: winemaking-calculator traceability ──

// Where a logged calculation was run from: the calculator PAGE, or the in-app ASSISTANT (chat/voice).
enum CalculationSource {
  PAGE
  ASSISTANT
}

// Append-only, tenant-scoped audit of every winemaking-calculator run (page + assistant). If a bad
// cellar addition happens, we can pull up exactly what was entered and what the engine returned —
// which almost always proves the calculator was right and the entry was user error, but makes it
// PROVABLE either way. `engineVersion` (CALC_ENGINE_VERSION) makes it forensic across formula fixes.
//
// Phase-12 checklist: tenantId NOT NULL from creation (new table, no backfill dance), FK →
// organization ON DELETE RESTRICT, RLS ENABLE+FORCE+tenant_isolation, app_rls grant. DB-ENFORCED
// APPEND-ONLY: the migration REVOKEs UPDATE + DELETE on this table from app_rls (INSERT + SELECT
// only) — a tamper-resistant audit, with no edit/delete code path either. PII-free by construction:
// inputs/outputs are numeric bench values + unit choices; the only identity is userId + userEmail.
model CalculationLog {
  tenantId      String            @default("") // Phase 12 tenant scope; FK+RLS at DB level
  id            String            @id @default(cuid())
  userId        String // who ran it (FK-free by design — userEmail snapshot survives user delete/rename)
  userEmail     String // snapshot at calc time (no join needed to render history; survives rename)
  calculatorId  String // the registry descriptor id, e.g. "so2-kmbs"
  formulaId     String // the formula used (currently mirrors calculatorId; room for sub-formula granularity)
  section       String // the calculator's section label, e.g. "SO₂ Additions"
  inputs        Json // the (normalized) input record
  output        Json // the CalcResult values array
  unitsUsed     Json // the unit selections in play (subset of inputs, kept explicit for querying)
  source        CalculationSource
  engineVersion String // CALC_ENGINE_VERSION at calc time — proves code-bug vs user-error after a fix
  advisory      Boolean           @default(false)
  danger        Boolean           @default(false)
  createdAt     DateTime          @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, userId, createdAt])
  @@index([tenantId, calculatorId, createdAt])
  @@map("calculation_log")
}

// ─────────────────────────────────────────────────────────────────────────────
// Plan 068 — User Inbox (Gmail-like in-app message center). Four tenant-scoped tables
// (tenant RLS in the paired _inbox_rls migration; per-user RLS in _inbox_user_rls — Unit 1b).
// Composite cross-tenant FKs are raw SQL (K11). recipient/sender/participant ids are plain
// single-column FKs to the GLOBAL `user` table (no tenantId there). Deep links are DERIVED at
// render from sourceType+sourceId — no stored href (council amendment 5).
// ─────────────────────────────────────────────────────────────────────────────

enum InboxCategory {
  WORK_ORDER
  TICKET
  DIRECT_MESSAGE
  SYSTEM
}

enum InboxKind {
  TICKET_REPLY
  TICKET_STATUS
  WO_ASSIGNED
  WO_STATUS
  DIRECT_MESSAGE
}

// One discrete, read/unread-tracked event per row. `readAt IS NULL AND archivedAt IS NULL` = unread
// (drives the avatar badge). `sourceId` is POLYMORPHIC (WO / ticket / DM thread) so it carries NO FK —
// the reader must tombstone a dangling / no-longer-accessible source (council amendment 6).
model InboxNotification {
  tenantId        String        @default("")
  id              String        @id @default(cuid())
  recipientUserId String
  recipientEmail  String
  category        InboxCategory
  kind            InboxKind
  title           String
  snippet         String
  sourceType      String
  sourceId        String
  actorUserId     String?
  actorEmail      String?
  readAt          DateTime?
  archivedAt      DateTime?
  createdAt       DateTime      @default(now())

  @@unique([tenantId, id])
  // Covering index for countUnreadInbox (recipient + readAt IS NULL + archivedAt IS NULL) — amendment 8.
  @@index([tenantId, recipientUserId, readAt, archivedAt])
  @@index([tenantId, recipientUserId, category, createdAt])
  @@map("inbox_notification")
}

// 1:1 DM thread. Two participants stored directly (v1). Sorted-pair convention userAId < userBId
// (enforced by DB CHECK in the schema migration — amendment 9) makes resolveOrCreateThread idempotent.
model DirectMessageThread {
  tenantId        String   @default("")
  id              String   @id @default(cuid())
  subject         String?
  createdByUserId String
  userAId         String
  userAEmail      String
  userBId         String
  userBEmail      String
  lastMessageAt   DateTime
  createdAt       DateTime @default(now())

  @@unique([tenantId, id])
  @@unique([tenantId, userAId, userBId])
  @@index([tenantId, userAId, lastMessageAt])
  @@index([tenantId, userBId, lastMessageAt])
  @@map("direct_message_thread")
}

model DirectMessage {
  tenantId     String   @default("")
  id           String   @id @default(cuid())
  threadId     String
  senderUserId String
  senderEmail  String
  body         String
  createdAt    DateTime @default(now())

  @@unique([tenantId, id])
  @@index([tenantId, threadId, createdAt])
  @@map("direct_message")
}

// Mirrors FeedbackAttachment fields. blobUrl is SERVER-ONLY — never sent to the client; downloads
// go through the authed proxy route /api/inbox/attachments/[id] (council amendment 1).
model DirectMessageAttachment {
  tenantId    String   @default("")
  id          String   @id @default(cuid())
  messageId   String
  filename    String
  contentType String
  byteSize    Int
  width       Int?
  height      Int?
  sha256      String
  blobUrl     String
  createdAt   DateTime @default(now())

  @@unique([tenantId, id])
  @@index([tenantId, messageId])
  @@map("direct_message_attachment")
}
