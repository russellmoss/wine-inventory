  @@unique([tenantId, ticketId])
  @@unique([tenantId, assistantFeedbackId])
  @@index([tenantId])
  @@index([tenantId, linearIssueKey])
  @@index([tenantId, linkedAt])
  @@map("feedback_linear_link")
}

// Plan 079: one clarification round asked of a bug reporter when a report is too
// thin to act on. Polymorphic over both feedback source types (mirrors AutomationRun /
// FeedbackAttachment). The DB adds (raw SQL in the migration): a partial unique so at
// most ONE clarification is OPEN per source (council C-1), and a CHECK that exactly one
// of ticketId/assistantFeedbackId is set and matches sourceType.
model FeedbackClarification {
  tenantId            String                      @default("")
  id                  String                      @id @default(cuid())
  sourceType          FeedbackAutomationSource
  sourceId            String
  ticketId            String?
  assistantFeedbackId String?
  automationRunId     String? // the run this clarification parked (workflow-retry idempotency via the unique below)
  round               Int                         @default(1) // clarification round, distinct from AutomationRun.attempt (council C-3.3)
  ref                 String // short human-facing token in the DM, e.g. "BUG-7Q2F" (council C-1 reply routing)
  reporterUserId      String // who we asked (denormalized for listing + reply fallback)
  dmThreadId          String?
  dmMessageId         String?
  questions           String // the questions we asked (may be UNTRUSTED once answered)
  askedByUserId       String // the Cellarhand Support sender
  askedAt             DateTime                    @default(now())
  status              FeedbackClarificationStatus @default(OPEN)
  answerBody          String? // the reporter's reply (UNTRUSTED)
  answeredAt          DateTime?
  answeredByUserId    String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  ticket              FeedbackTicket?             @relation(fields: [tenantId, ticketId], references: [tenantId, id], onDelete: Cascade)
  assistantFeedback   AssistantFeedback?          @relation(fields: [tenantId, assistantFeedbackId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, id])
  @@unique([tenantId, ref])
  @@unique([tenantId, automationRunId]) // one clarification per run (council C-1); multiple NULLs allowed
  @@index([tenantId, sourceType, sourceId, askedAt]) // source history
  @@index([tenantId, dmThreadId, status]) // reply-hook lookup (council C-3.8)
  @@index([tenantId, reporterUserId, status]) // per-reporter open listing (assistant nudge / My Reports)
  @@index([tenantId, ticketId])
  @@index([tenantId, assistantFeedbackId])
  @@map("feedback_clarification")
}

model AutomationRun {
  tenantId            String                   @default("")
  id                  String                   @id @default(cuid())
  sourceType          FeedbackAutomationSource
  sourceId            String
  assistantFeedbackId String?
  ticketId            String?
  kind                FeedbackAutomationKind
  attempt             Int                      @default(1)
  status              FeedbackAutomationStatus @default(QUEUED)
  idempotencyKey      String
  approvedByUserId    String?
  approvedAt          DateTime?
  claimedAt           DateTime?
  completedAt         DateTime?
  workflowRunId       String?
  githubIssueNumber   Int?
  githubPrNumber      Int?
  githubUrl           String?
  error               String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  ticket              FeedbackTicket?          @relation("FeedbackTicketAutomationRuns", fields: [tenantId, ticketId], references: [tenantId, id], onDelete: Cascade)
  assistantFeedback   AssistantFeedback?       @relation("AssistantFeedbackAutomationRuns", fields: [tenantId, assistantFeedbackId], references: [tenantId, id], onDelete: Cascade)

  @@unique([idempotencyKey])
  @@unique([tenantId, sourceType, sourceId, kind, attempt])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, ticketId])
  @@index([tenantId, assistantFeedbackId])
  @@map("automation_run")
}

// A persisted assistant chat. Scoped to the owning user (personal history, not
// vineyard data). `title` is auto-generated from the first user message. Messages
// cascade-delete with the conversation.
model AssistantConversation {
  tenantId    String             @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id          String             @id @default(cuid())
  ownerUserId String
  title       String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  owner       User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  messages    AssistantMessage[]

  @@index([ownerUserId, updatedAt])
  @@index([tenantId])
  @@map("assistant_conversation")
}

// One persisted text turn in a conversation. Only "user"/"assistant" text turns
// are stored (ephemeral write-proposal cards are not). `search_vector` is a
// Postgres generated tsvector column (added in the migration, not managed by
// Prisma) backing full-text search; it is intentionally absent from this model.
model AssistantMessage {
  tenantId       String                   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id             String                   @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String                   @db.Text
  metadata       Json?
  createdAt      DateTime                 @default(now())
  // Postgres GENERATED tsvector over `content` (see migration). Declared here so
  // Prisma tracks the column + GIN index and won't flag drift; never written by app.
  searchVector   Unsupported("tsvector")? @map("search_vector")
  conversation   AssistantConversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([searchVector], type: Gin)
  @@index([tenantId])
  @@map("assistant_message")
}

model VoiceProfile {
  tenantId          String               @default("")
  id                String               @id @default(cuid())
  userId            String
  status            VoiceProfileStatus   @default(ACTIVE)
  provider          VoiceProfileProvider @default(LOCAL_VOICEPRINT)
  providerRef       String?
  embeddingCt       String?
  dekWrapped        String?
  modelVersion      String
  threshold         Float                @default(0.82)
  enrollmentQuality Float?
  consentAcceptedAt DateTime?
  consentVersion    String?
  lastVerifiedAt    DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, userId])
  @@map("voice_profile")
}

model VoicePreference {
  tenantId              String                @default("")
  id                    String                @id @default(cuid())
  userId                String
  defaultFocusMode      VoiceFocusDefaultMode @default(OPEN)
  audioIsolationEnabled Boolean               @default(false)
  wakeWordEnabled       Boolean               @default(false)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, userId])
  @@map("voice_preference")
}

// ───────────────────────── Lot + operation ledger (Phase 1 spine) ─────────────────────────
// The append-only source of truth for BULK wine. `VesselComponent` (above) is retired
// after the Day-Zero migration; `VesselLot` is the materialized projection. See
// VISION §3, docs/INVARIANTS.md. Enums mirror src/lib/ledger/vocabulary.ts.
//
// NOTE: CHECK constraints (volumeL > 0, deltaL <> 0) and the vessel-capacity guard are
// NOT expressible in Prisma — they are added in the migration's raw SQL (D14).

enum LotForm {
  FRUIT
  MUST
  JUICE
  WINE
  BOTTLED_IN_PROCESS
  FINISHED
}

enum OperationType {
  SEED
  RACK
  LOSS
  ADJUST
  DEPLETE
  BOTTLE
  CORRECTION
  // Phase 3 cellar operations (added in a dedicated enum-only migration — Postgres
  // ALTER TYPE ... ADD VALUE can't be used in the same migration that adds it).
  ADDITION
  TOPPING
  FINING
  FILTRATION
  CAP_MGMT
  // Phase 5: blend operation (originates a new child lot OR grows an existing lot) —
  // added in its own enum-only migration (Postgres ALTER TYPE ADD VALUE gotcha).
  BLEND
  // Phase 6: state transforms (crush/press/saignée). Added in a dedicated enum-only
  // migration (Unit 1) so the ADD VALUEs commit before Unit 3/4 write them.
  CRUSH // consume harvest picks → originate a MUST lot at measured liters (kg = metadata)
  PRESS // split a must/wine lot into free-run + press fraction child lots (1 parent → N)
  SAIGNEE // bleed juice off a MUST lot pre-ferment (the same split, form MUST→JUICE)
  // Phase 7: méthode-champenoise sparkling as an operation SEQUENCE on the bottled lot.
  // Added in a dedicated enum-only migration (Unit 1) so the ADD VALUEs commit before
  // Units 5–9 write them (Postgres ALTER TYPE ADD VALUE can't be used in the tx that adds it).
  TIRAGE // bottle a bulk lot into an en-tirage bottle lot (+ liqueur de tirage ADDITION)
  RIDDLING // remuage — a zero-volume work step on the bottled lot
  DISGORGEMENT // eject the lees plug — a per-bottle volume LOSS (partial = a SPLIT)
  DOSAGE // liqueur d'expédition — adds volume back and sets the sweetness style
  FINISH // close out the bottled lot into a sellable WineSku via the shared materialization core
  // Phase 14: tax determination + all removal/used-for dispositions (TTB F 5120.17 A14–A23 /
  // B8–B14). Added in a DEDICATED enum-only migration (Postgres ALTER TYPE ADD VALUE can't be used
  // in the tx that adds it) so the value commits before removal-core.ts writes it.
  REMOVE_TAXPAID
  // Phase 2 (bond + tax-class): cross-bond movement (symmetric removed/received-in-bond) and the
  // refund-flagged re-admission of tax-paid wine. Added in a DEDICATED enum-only migration
  // (Postgres ALTER TYPE ADD VALUE can't be used in the tx that adds it) so the values commit
  // before transfer-in-bond-core.ts / return-to-bond-core.ts write them. CHANGE_OWNERSHIP is
  // DEFERRED (needs alternate-proprietor logic — Phase-2 OQ-1 resolved: not built this phase).
  TRANSFER_IN_BOND
  RETURN_TO_BOND
}

// Phase 6: fermentation is THREE orthogonal state vectors, NOT a linear phase enum
// (council C1 — real ferment isn't linear). `afState` + `mlfState` live here; the physical
// form is the existing `LotForm`. A white = JUICE + AF:ACTIVE; a co-inoculated red = MUST +
// AF:ACTIVE + MLF:ACTIVE; extended maceration = MUST + AF:DRY. STUCK is DERIVED, never
// stored (council C3) — recomputed from the Brix trend, so it isn't an enum value.
enum AlcoholicFermState {
  NONE
  ACTIVE
  DRY
}

enum MalolacticState {
  NONE
  ACTIVE
  COMPLETE
}

enum CaptureMethod {
  MANUAL
  VOICE
  SENSOR
  IMPORT
}

// ───────────────────────── Phase 14: TTB 5120.17 compliance classification (Fork 2A) ─────────────────────────
// Tax-class DERIVATION inputs. The 6-value tax class itself (WineTaxClass) is DERIVED at report
// time (never stored as a Lot column) and lives as a TS union in src/lib/compliance/types.ts — the
// single authority for the pure derivation; stored values are strings in the report snapshot Json.
// These two enums ARE stored on Lot (defaults WINE/NONE) so a/b/c/e derive fully automatically and
// d/f are reachable via the review-screen override without a dedicated capture UI in v1.
enum ProductType {
  WINE
  HARD_CIDER
}

enum CarbonationMethod {
  NONE
  NATURAL
  ARTIFICIAL
}

// TTB report lifecycle (status) is SEPARATE from the form version flag (council S4).
// NEEDS_AMENDMENT (Phase 2, AMEND-1): a FILED period reopened by a later-dated op (a correction,
// or a backdated bond/return op) landing in its window. The report keeps its last-filed onHandEnd
// (carry-forward still chains through it) but the UI must never present it as "Filed" — the operator
// must file an amended version. Added in the dedicated enum-only migration (Windows enum rule).
enum ComplianceReportStatus {
  DRAFT
  FILED
  NEEDS_AMENDMENT
}

// The form's VERSION selector (Original/Amended). "Final" is a separate business-closing flag
// (isFinalBusinessReport), NOT a per-period version state (council S4).
enum ComplianceReportVersion {
  ORIGINAL
  AMENDED
}

// Filing cadence. MONTHLY/QUARTERLY/ANNUAL are the operations-report cadences (27 CFR 24.300(g)(2)).
// SEMIMONTHLY (Phase 14 plan-026) is a wine EXCISE-return cadence only (27 CFR 24.271): the 1st–15th
// and 16th–EOM halves. It is never a valid operations-report cadence — the two cadences are separate
// regulatory tests ($ liability vs gallons) carried on separate profile columns.
enum ReportCadence {
  MONTHLY
  QUARTERLY
  ANNUAL
  SEMIMONTHLY
}

// Which TTB form a compliance_report row represents (plan-026 Fork 1A). One generalized filing table,
// two forms: TTB_5120_17 = Report of Wine Premises Operations (gallons, plan-025); TTB_5000_24 = Wine
// Excise Tax Return (dollars, plan-026). formType scopes EVERY report query so the two forms' filing
// chains, carry-forward, and lists never cross (council C4 / eng E1 — see src/lib/compliance/form-type.ts).
enum ComplianceFormType {
  TTB_5120_17
  TTB_5000_24
}

// ───────────────────────── Phase 7: sparkling (bottle-as-continuable-container) ─────────────────────────

// The sparkling production method. TRADITIONAL (méthode champenoise) and PETNAT are
// bottled-in-process (they get a BottledLotState); TANK (Charmat) stays a bulk WINE lot
// in a pressurized tank and is never bottled-in-process (council CRITICAL #3).
enum SparklingMethod {
  TRADITIONAL
  TANK
  PETNAT
}

// Where an en-tirage bottle lot sits in the traditional-method arc. A compact stepper in
// the UI (en tirage → riddling → disgorged → dosed → finished). Any *stage* divergence
// within a lot MUST be a split (K6).
enum BottleStage {
  EN_TIRAGE
  RIDDLING
  DISGORGED
  DOSED
}

// EU sweetness bands, set by the dosage sugar. Brut Nature ⇔ dosageGramsPerL == 0 (a dry /
// SO₂-only top-up still counts as Brut Nature — the rule is about *sugar*, K10).
enum DosageStyle {
  BRUT_NATURE
  EXTRA_BRUT
  BRUT
  EXTRA_DRY
  SEC
  DEMI_SEC
  DOUX
}

// The account a ledger line touches. Replaces the old implicit "vesselId=null ⇒ gone"
// convention with an explicit discriminator so Phase 8 cost roll-up can tell wine-in-bottle
// (BOTTLE_STORAGE) from wine that left the cellar (EXTERNAL) (council CRITICAL #2 / K3).
enum LedgerBucket {
  VESSEL
  EXTERNAL
  BOTTLE_STORAGE
}

// ───────────────────────── Phase 8: cost roll-up + supply stock (enums) ─────────────────────────
// New enum TYPES (created in their own enum-only migration 20260702000000_cost_enums, ahead of the
// table migration — matches the repo's isolated-enum convention; CREATE TYPE is safe same-tx but we
// keep the seam clean). None of these ADD VALUE to an existing enum, so there is no ALTER TYPE gotcha.

// The kind of cost a CostLine / consumption represents (D5). MATERIAL + DOSAGE_LIQUEUR are ALWAYS
// capitalized; FRUIT/BARREL default-on, LABOR/OVERHEAD default-off (recorded, allocation is Phase 11);
// PACKAGING is the bottling BOM (glass/cork/…); VARIANCE is a rounding/abnormal-loss/adjustment flush.
enum CostComponent {
  MATERIAL
  FRUIT
  BARREL
  LABOR
  OVERHEAD
  DOSAGE_LIQUEUR
  PACKAGING
  VARIANCE
  OPENING_BALANCE
}

// Per-tenant costing method (D5). Weighted-average absorption is the default (blends ARE weighted-avg
// by volume); FIFO optional. Stamped onto each immutable SupplyConsumption row so recompute never
// re-values history when the setting later changes (D17).
enum CostingMethod {
  WEIGHTED_AVG
  FIFO
}

// Cost-basis completeness (D14): null cost is UNKNOWN, NEVER $0. PARTIAL = some inputs known, some
// unknown. Propagates up the DAG (any unknown parent taints the child) and is frozen on the snapshot;
// an incomplete basis is surfaced in the UI and blocked from accounting export.
enum CostBasisCompleteness {
  KNOWN
  PARTIAL
  UNKNOWN
}

// Lot ownership (D19). ESTATE = the winery owns the wine (cost capitalizes to inventory). A
// CUSTOM_CRUSH_CLIENT lot is owned by a client — fruit/wine cost is suppressed from the winery's
// inventory asset and supply draw-downs route to a billable-expense CostLine (billed back, not
// capitalized). Ships as a seam in 8a; the routing logic is Unit 16.
enum LotOwnership {
  ESTATE
  CUSTOM_CRUSH_CLIENT
}

// Plan 093 (custom-crush data foundation) — the first-class party that OWNS wine. Replaces the scalar
// `LotOwnership` enum (kept as a mirror until Unit 3 cuts the 11 readers over and drops it). Facility's
// OWN wine = NO Owner row (ownerId NULL everywhere), so `kind` needs no ESTATE value — a NULL ownerId on
// a LOT means "Estate (facility)" (the load-bearing convention behind the cost predicate + verify).
// SCALAR ownership (one Owner per lot); a future `LotOwnershipShare(ownerId, lotId, pct)` is the additive
// fractional extension — do NOT build it, but Owner is shaped so adding it later is non-breaking.
enum OwnerKind {
  CUSTOM_CRUSH_CLIENT // a client whose wine we make under OUR bond (title differs, bond does not)
  AP_PROPRIETOR // an Alternating-Proprietor client operating under their OWN bond (distinct BWN)
}

model Owner {
  tenantId  String    @default("") // Phase 12 tenant scope; FK+RLS at DB level (AGENTS.md 9-step)
  id        String    @id @default(cuid())
  name      String // the client/proprietor name (per-tenant unique)
  kind      OwnerKind
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, name]) // per-tenant unique name
  @@unique([tenantId, id]) // composite cross-tenant FK target (K11) — bond.ownerId references this
  @@index([tenantId])
  @@map("owner")
}

// A singleton winery-level settings row (the app is single-tenant). Read/created via
// getAppSettings(). `sparklingEnabled` gates the ENTIRE traditional-method UI/nav (K14,
// default off) — backend enums/cores ship regardless and are inert when unused.
model AppSettings {
  tenantId                 String                 @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  // Phase 12: per-org now (K10). One row per tenant (@@unique([tenantId])); read/written by
  // tenantId, not the old "singleton" id. id is a plain cuid so a 2nd org's row can't collide.
  id                       String                 @id @default(cuid())
  sparklingEnabled         Boolean                @default(false)
  pushVendorsToQbo         Boolean                @default(false) // Plan 077: opt-in — eagerly create a QBO vendor when one is created in Cellarhand (off = author vendors in QBO, Slice 1's pull covers it)
  // Phase 8 (D5, D9, D17): per-tenant costing policy. `currency` (ISO code, default USD) heads every
  // cost row. `costingMethod` + `costingMethodEffectiveAt` set depletion order (WA default | FIFO); the
  // method actually used is STAMPED on each SupplyConsumption at write time so recompute is stable.
  // Capitalization toggles decide which components fold into capitalized cost — MATERIAL + DOSAGE_LIQUEUR
  // are ALWAYS capitalized (no toggle); the rest are recorded regardless and only the toggle gates
  // whether they roll up. `costingPolicyVersion` stamps every derived row so a toggle/method change
  // never re-values closed history (D17).
  currency                 String                 @default("USD")
  // The winery's OPERATING clock (IANA zone, e.g. "America/Los_Angeles"). Work is planned where the
  // wine is: a 9am pumpover means the crew's 9am, not the reader's — so a due time is entered, stored,
  // and displayed against this zone, and the assistant's "today" follows it too. NULLABLE on purpose:
  // unset means "not configured", and every reader falls back to the VIEWER's browser zone, which is
  // exactly the behaviour before this column existed. See src/lib/work-orders/due-at.ts.
  timeZone                 String?
  costingMethod            CostingMethod          @default(WEIGHTED_AVG)
  costingMethodEffectiveAt DateTime?
  capitalizeFruit          Boolean                @default(true)
  capitalizeBarrel         Boolean                @default(true)
  capitalizeLabor          Boolean                @default(false)
  capitalizeOverhead       Boolean                @default(false)
  capitalizePackaging      Boolean                @default(true)
  costingPolicyVersion     Int                    @default(1)
  // Phase 15 Unit 10 — supply-receipt A/P Bill accounts (winery-wide, not per-component): a receipt
  // posts DR inventory-asset / CR accounts-payable. Both unset → AP export is withheld (never posted).
  apInventoryAccount       String?
  apPayableAccount         String?
  // Plan 080 U5 (council C3): a MIXED invoice codes each line to its OWN account — a pump is a fixed
  // asset, a clamp is an expense, a case of merch is inventory. Posting all three to apInventoryAccount
  // corrupts the balance sheet. NULLABLE on purpose: an unconfigured account WITHHOLDS the invoice
  // (needsAck) instead of silently miscoding, and the accountant confirms this map before go-live.
  apFixedAssetAccount      String? // capitalized equipment
  apSuppliesExpenseAccount String? // consumables / spare parts (expensed, not capitalized)
  // Plan 076 — the pay-from accounts a BillPayment draws on when an invoice is marked Paid: a check/bank
  // payment credits the bank account; a company-card payment credits the credit-card LIABILITY account
  // (moves the debt from the vendor to the card). Either may be unset until first used.
  apPaymentBankAccount     String?
  apPaymentCardAccount     String?
  // Phase 16 Unit 1 — DTC (Commerce7) sales accounts (winery-wide, like AP): a settled DTC sale posts
  // DR undeposited-funds clearing / CR revenue + CR sales-tax-payable + CR shipping-income, with a
  // discount contra line. Revenue + clearing unset → the sales export is WITHHELD (never posted). Both
  // nullable + additive.
  dtcRevenueAccount        String?
  dtcTaxAccount            String?
  dtcShippingAccount       String?
  dtcClearingAccount       String?
  dtcDiscountAccount       String?
  assistantFeedbackMode    FeedbackAutomationMode @default(AGENTIC_FIX)
  bugReportMode            FeedbackAutomationMode @default(REPORT_ONLY)
  featureRequestMode       FeedbackAutomationMode @default(REPORT_ONLY)
  updatedAt                DateTime               @updatedAt

  @@unique([tenantId])
  @@index([tenantId])
  @@map("app_settings")
}

// A reusable, named press program (e.g. "Champagne cycle", "delicate white", "hard press").
// Optional metadata on a PRESS op — the name is stamped into LotOperation.metadata.pressCycle;
// this table is just the pick-list the press form offers so cycles can be reused across pressings.
model PressCycle {
  tenantId  String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("press_cycle")
}

// A batch of wine with a durable identity (VISION §1–3). Vintage is an ATTRIBUTE, not
// part of identity (D3). Origin columns are provenance snapshots (no FK — the
// authoritative tuple lives in legacySnapshot for legacy lots). Provenance metadata is
// immutable after the first operation (enforced in the service layer).
model Lot {
  tenantId           String             @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id                 String             @id @default(cuid())
  code               String
  // Phase 1 (identity presentation): a MUTABLE, NON-unique free-text human label. Deliberately
  // NO @@unique. Backfilled/left NULL; the presentation layer coalesces `displayName ?? code`
  // (plan Q12), so a `code` rename never leaves a stale displayName. Identity stays on `id`;
  // `code` is the mutable unique-per-tenant human code; see NAMING-1/2.
  displayName        String?
  // form is MUTABLE over the lot's life (D4) but ONLY via the Phase 6 domain transitions
  // (crush→MUST, press/saignée→JUICE, AF-dry→WINE) — direct writes are banned; every change
  // records a LotStateEvent. origin*/code/provenance stay immutable.
  form               LotForm            @default(WINE)
  // Phase 6: the two orthogonal fermentation vectors (council C1). The physical `form` is
  // the third vector. A legal form×afState×mlfState matrix is validated in the domain layer
  // (Unit 5). STUCK is DERIVED from the Brix trend (council C3), never stored here.
  afState            AlcoholicFermState @default(NONE)
  mlfState           MalolacticState    @default(NONE)
  originVineyardId   String?
  originBlockId      String?
  originSubblockId   String?
  originVarietyId    String?
  vintageYear        Int?
  status             String             @default("ACTIVE") // ACTIVE | DEPLETED | ARCHIVED | CORRECTED
  isLegacy           Boolean            @default(false)
  // Phase 14 (Fork 2A): TTB tax-class derivation inputs. Defaults keep grape-first behavior; d/f
  // are reachable via the review-screen override. `taxAbvOverride` is the optional per-lot tax ABV
  // used when no ALCOHOL AnalysisReading exists as-of the taxable event (abv resolver, Unit 2).
  productType        ProductType        @default(WINE)
  carbonation        CarbonationMethod  @default(NONE)
  taxAbvOverride     Decimal?           @db.Decimal(5, 2)
  // Phase 8 (D19): who owns this wine. ESTATE (default) capitalizes cost to the winery's inventory
  // asset; CUSTOM_CRUSH_CLIENT suppresses fruit/wine cost and bills supplies back (routing = Unit 16).
  ownership          LotOwnership       @default(ESTATE)
  // Phase 5: false when this lot's source-vineyard set may be incomplete (a blend with a
  // parent of unknown provenance). Contagious: a blend with any incomplete parent is itself
  // incomplete (council C6). Drives the "admin-only-visible" NULL-source bucket.
  provenanceComplete Boolean            @default(true)
  legacySnapshot     Json?
  sublotTag          String? // optional human variant tag in the lot code (experiments / differential picks)
  note               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  operationLines       LotOperationLine[]
  vesselLots           VesselLot[]
  parentEdges          LotLineage[]            @relation("LotChild") // edges where this lot is the child
  childEdges           LotLineage[]            @relation("LotParent") // edges where this lot is the parent
  bottlingSources      BottlingSource[]
  treatments           LotTreatment[]
  // Phase 4 standalone chemistry/tasting/sample records (NOT ledger ops).
  analysisPanels       AnalysisPanel[]
  tastingNotes         LotTastingNote[]
  samples              Sample[]
  // Phase 5 blends.
  sourceVineyards      LotVineyard[] // the lot's source-vineyard SET (union over lineage at blend)
  blendTrialComponents BlendTrialComponent[] // bench-trial component rows referencing this lot
  promotedFromTrials   BlendTrial[]            @relation("TrialPromotedLot") // trials promoted into this lot
  // Phase 6: harvest picks consumed by the crush that originated this lot (partial picks
  // allowed; this join is the single source of truth for "pick consumed/remaining"), and the
  // recorded form/AF/MLF transition history.
  harvestSources       LotHarvestSource[]
  stateEvents          LotStateEvent[]
  // Phase 7: the 1:1 continuable-bottle projection (present only while BOTTLED_IN_PROCESS).
  bottledState         BottledLotState?
  // Phase 8: direct absorbed cost lines on this lot's ops, inherited-cost transfer edges, and the
  // 1:1 lazy cost cache.
  costLines            CostLine[]
  costTransfersFrom    OperationCostTransfer[] @relation("CostTransferFrom")
  costTransfersTo      OperationCostTransfer[] @relation("CostTransferTo")
  costState            LotCostState?
  // Phase 8b (Unit 8): barrel-aging residency intervals for this lot (fill-based amortization).
  barrelFills          BarrelFill[]
  // Phase 1 (identity presentation): LotIdentifier / LotCodeEvent reference this lot via a COMPOSITE
  // (tenantId, lotId)->(tenantId, id) FK declared in raw SQL (like work_order_task's lot ref, K11) —
  // NOT a Prisma relation. Multi-field Prisma relations here blow TS's type-instantiation depth
  // (excessive-stack-depth on VesselLot/Lot), so we keep the FK at the DB level and query by lotId.

  @@unique([tenantId, code])
  @@unique([tenantId, id])
  @@index([status])
  @@index([originVineyardId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("lot")
}

// Phase 1 (identity presentation) — external/source identifiers for a lot: the current human
// `code` (a convenience projection kept in sync on rename), legacy incumbent codes imported in
// Phase 3, spreadsheet aliases, TTB labels. This is the cross-identifier SEARCH index AND the
// Phase-3 idempotent re-import key. Rename HISTORY lives in LotCodeEvent, NOT here (plan Q13):
// the app rename path never writes a `prior-code` row — it updates the single `current-code`
// row's value in place; `prior-code` is reserved for Phase-3 imported incumbent labels.
// Tenant checklist: composite FK (tenantId,lotId)->lot(tenantId,id); RLS + the null-safe
// re-import partial uniques + the single-`current-code`-per-lot partial unique live in raw SQL
// (Prisma can't express partial uniques). `kind` stays an open String (Phase-3 adapters add
// kinds without an ALTER TYPE) — plan Q4.
model LotIdentifier {
  tenantId         String    @default("")
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id               String    @id @default(cuid())
  lotId            String
  kind             String // current-code | source-system-id | spreadsheet-alias | ttb-label | prior-code(Phase-3 imports only)
  sourceSystem     String? // e.g. "innovint" | "vintrace" | null for app-native identifiers
  sourceObjectType String?
  value            String
  validFrom        DateTime?
  validTo          DateTime?
  isCurrent        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  // Composite FK (tenantId, lotId)->lot(tenantId, id) is declared in raw SQL (see the schema
  // migration) — not a Prisma relation (avoids the multi-field-relation type-depth blowup).

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([tenantId, lotId])
  @@index([tenantId, value]) // cross-identifier search index
  @@map("lot_identifier")
}

// Phase 1 (identity presentation) — the append-only SOURCE OF TRUTH for in-app renames
// (NAMING-2). A rename appends one row here and NEVER rewrites a LotOperationLine snapshot;
// historical-code search reads fromValue/toValue. `commandId` is the idempotency key, scoped
// per tenant (checklist step 4). `field` is CHECK-constrained to ('code','displayName') in raw
// SQL (a fixed domain — plan Q4). Composite FK + RLS in raw SQL.
model LotCodeEvent {
  tenantId    String   @default("")
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id          String   @id @default(cuid())
  lotId       String
  field       String // code | displayName (CHECK-constrained in migration)
  fromValue   String?
  toValue     String
  actorUserId String?
  actorEmail  String? // email snapshot (provenance), mirrors the ledger actor shape
  observedAt  DateTime @default(now())
  commandId   String // idempotency; UNIQUE per tenant (see @@unique below)
  createdAt   DateTime @default(now())
  // Composite FK (tenantId, lotId)->lot(tenantId, id) is declared in raw SQL (see the schema
  // migration) — not a Prisma relation (avoids the multi-field-relation type-depth blowup).

  @@unique([tenantId, id])
  @@unique([tenantId, commandId]) // idempotency (checklist step 4: tenant-scoped, not global)
  @@index([tenantId, lotId])
  @@index([tenantId, toValue]) // historical-code search
  @@index([tenantId, fromValue]) // historical-code search
  @@index([tenantId, ownerId])
  @@map("lot_code_event")
}

// Phase 1 (identity presentation) — a per-tenant, versioned tokenized naming scheme. Mirrors the
// WorkOrderTemplate/Version clone-on-customize pattern: the header points at currentVersion; each
// edit inserts a new immutable NamingTemplateVersion. The built-in default (isSystem+isDefault)
// reproduces today's buildLotCode output byte-for-byte (the renderer delegates to it). Single
// active default per tenant is a raw-SQL partial unique. Composite FK + RLS in raw SQL.
model NamingTemplate {
  tenantId       String    @default("")
  id             String    @id @default(cuid())
  code           String // per-tenant stable key
  name           String
  isSystem       Boolean   @default(false)
  isDefault      Boolean   @default(false)
  clonedFromId   String? // lineage of a clone-on-customize
  currentVersion Int       @default(1) // naked pointer, matching WorkOrderTemplate precedent
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // Versions reference this header via a COMPOSITE (tenantId, templateId)->(tenantId, id) FK declared
  // in raw SQL — not a Prisma relation (multi-field relation type-depth blowup). Query versions by
  // (tenantId, templateId, version) directly.

  @@unique([tenantId, code])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("naming_template")
}

// An immutable version snapshot of a NamingTemplate's tokenized spec. Editing a template creates
// a new version, never mutating an old one (WO-template parity). Composite tenant FK to the header.
model NamingTemplateVersion {
  tenantId       String   @default("")
  id             String   @id @default(cuid())
  templateId     String
  version        Int
  spec           Json // the tokenized pattern (ordered typed segments + blend-variant flag)
  createdAt      DateTime @default(now())
  createdById    String?
  createdByEmail String?
  // Composite FK (tenantId, templateId)->naming_template(tenantId, id) in raw SQL (not a Prisma relation).

  @@unique([tenantId, templateId, version])
  @@unique([tenantId, id])
  @@index([tenantId])
  @@map("naming_template_version")
}

// One immutable ledger event. The autoincrement `id` IS the monotonic fold order
// (deterministic ordering; `observedAt` can collide / drift — D14). `correctsOperationId`
// is unique so any op can be corrected at most once (kills the double-correction race).
model LotOperation {
  tenantId            String        @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id                  Int           @id @default(autoincrement())
  type                OperationType
  observedAt          DateTime      @default(now())
  enteredAt           DateTime      @default(now())
  actorUserId         String?
  enteredBy           String // email snapshot (provenance)
  captureMethod       CaptureMethod @default(MANUAL)
  note                String?
  correctsOperationId Int?          @unique
  batchId             String? // Phase 3: groups the per-vessel ops of one group fan-out (D13)
  // Phase 6: client-generated idempotency key for mutating transforms (crush/press/saignée).
  // UNIQUE so a double-tap on a flaky crush-pad network is a no-op success, not a duplicate
  // lot (council S4). Nullable: pre-Phase-6 ops have none; Postgres allows many NULLs.
  commandId           String?       @unique
  metadata            Json?
  createdAt           DateTime      @default(now())

  corrects           LotOperation?           @relation("OpCorrection", fields: [correctsOperationId], references: [id], onDelete: Restrict)
  correctedBy        LotOperation?           @relation("OpCorrection")
  lines              LotOperationLine[]
  vesselTransfer     VesselTransfer? // 1:1 derived read-model (FK lives on VesselTransfer)
  treatments         LotTreatment[]          @relation("TreatmentOperation") // detail rows this op created
  voidedTreatments   LotTreatment[]          @relation("TreatmentVoid") // treatments this (CORRECTION) op voided
  stateEvents        LotStateEvent[] // form/AF/MLF transitions caused by this op (shares fold order)
  // Phase 8: the append-only cost artifacts hung off this op (all composite-tenant-FK'd at the DB).
  costLines          CostLine[]
  supplyConsumptions SupplyConsumption[]
  costTransfers      OperationCostTransfer[]

  @@unique([tenantId, id]) // Phase 8: composite-tenant-FK target for cost artifacts (K11)
  @@index([type, observedAt])
  @@index([batchId])
  @@index([tenantId])
  @@index([tenantId, observedAt]) // Phase 14 (S3): period-boundary fold — lines by tenant + observedAt
  @@map("lot_operation")
}

// A signed volumetric line. `vesselId = null` is the external counter-account that
// keeps each operation balanced (seed-in, loss-out, bottle-out). `lotCode`/`vesselCode`
// are durable snapshots so history reads survive later renames/deletes.
model LotOperationLine {
  tenantId     String       @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id           Int          @id @default(autoincrement())
  operationId  Int
  lotId        String
  vesselId     String? // null = "outside the cellar"
  deltaL       Decimal      @db.Decimal(10, 2) // signed; CHECK(deltaL <> 0) in migration
  reason       String?
  // Phase 7 (K3): the explicit account this leg touches. VESSEL (vesselId set) | EXTERNAL
  // (left the cellar) | BOTTLE_STORAGE (wine-in-bottle). A BOTTLE_STORAGE leg carries BOTH
  // deltaL and bottleDelta; every other leg has bottleDelta NULL. The pairing is enforced by
  // a DB CHECK (bucket='BOTTLE_STORAGE' ⇔ bottleDelta IS NOT NULL). Backfilled on existing
  // rows: VESSEL where vesselId is set, else EXTERNAL.
  bucket       LedgerBucket @default(EXTERNAL)
  bottleDelta  Int? // signed bottle-count change on a BOTTLE_STORAGE leg (else NULL)
  lotCode      String
  vesselCode   String?
  // Phase 2 (BOND-1): line-level, time-aware bond affiliation. A bond-moving op (TRANSFER_IN_BOND,
  // RETURN_TO_BOND) stamps these with an EXPLICIT, non-null, source≠dest bond (enforced in the core,
  // not the schema). Legacy/origination lines leave them NULL and the bond derives to the tenant's
  // primary bond (OQ-3). The authoritative bond of a position is DERIVED point-in-time from these
  // (deriveBond), never a mutable Lot column. Composite (tenantId, bondId) → bond(tenantId, id) FKs
  // live in raw SQL (M2) — no Prisma @relation (Phase-1 Surprise 1: composite relations blow TS depth).
  sourceBondId String?
  destBondId   String?
  operation    LotOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  lot          Lot          @relation(fields: [lotId], references: [id], onDelete: Restrict)
  vessel       Vessel?      @relation(fields: [vesselId], references: [id], onDelete: SetNull)

  @@index([operationId])
  @@index([lotId])
  @@index([vesselId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([tenantId, destBondId]) // Phase 2: bond derivation lookup (latest dest bond ≤ asOf)
  @@map("lot_operation_line")
}

// The materialized current-state projection: how much of one lot sits in one vessel.
// Always equals the fold of the ledger (INVARIANT #7). CHECK(volumeL > 0) in migration;
// a row at functional zero is deleted, never stored at 0.
model VesselLot {
  tenantId  String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id        String   @id @default(cuid())
  vesselId  String
  lotId     String
  volumeL   Decimal  @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt
  vessel    Vessel   @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  lot       Lot      @relation(fields: [lotId], references: [id], onDelete: Restrict)

  // LEDGER-12 (plan 088): a vessel holds ONE cohesive liquid. The app refuses it at the ledger
  // chokepoint in domain language; this makes it structurally impossible — for scripts, imports,
  // and any future code that forgets. The inverse stays unbounded: one lot may occupy MANY
  // vessels (40 barrels is normal), which is why this keys on the vessel, never the lot.
  // Safe because BOTTLE_STORAGE ledger legs carry vesselId: null, so bottled wine is not
  // vessel occupancy and never lands here.
  @@unique([tenantId, vesselId])
  // Kept deliberately: strictly weaker than the above, but it is a live WhereUniqueInput target
  // for existing findUnique/upsert call sites. Removing it is a separate mechanical sweep.
  @@unique([tenantId, vesselId, lotId])
  @@index([lotId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("vessel_lot")
}

// Parent→child lineage edges for splits/blends (structure-only in Phase 1; blends are
// Phase 5). `fraction` is the parent's share of the child where meaningful.
model LotLineage {
  tenantId    String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id          String   @id @default(cuid())
  parentLotId String
  childLotId  String
  fraction    Decimal? @db.Decimal(6, 5)
  kind        String // SPLIT | BLEND | TOPPING
  createdAt   DateTime @default(now())
  parent      Lot      @relation("LotParent", fields: [parentLotId], references: [id], onDelete: Restrict)
  child       Lot      @relation("LotChild", fields: [childLotId], references: [id], onDelete: Cascade)

  @@unique([parentLotId, childLotId])
  @@index([childLotId])
  @@index([tenantId])
  // Phase 8 (Unit 2): tenant-scoped edge indexes for the cost roll-up's recursive-CTE walk (both
  // directions — ancestry up via childLotId, descendants down via parentLotId).
  @@index([tenantId, parentLotId])
  @@index([tenantId, childLotId])
  @@map("lot_lineage")
}

// ───────────────────────── Phase 6: state transforms & fermentation ─────────────────────────

// The crush linkage: which harvest pick(s) were consumed (in part or full) into which lot.
// SINGLE SOURCE OF TRUTH for pick consumption (council S8) — "remaining = weightKg − Σ
// consumedKg" is DERIVED from these rows, never also stored on the pick. NO unique on
// harvestPickId: a big pick is legitimately split across several fermenters; the crush tx
// enforces Σ consumedKg ≤ HarvestPick.weightKg. kg never enters a ledger line (D8) — it is
// op metadata; the measured output liters is the only balanced line.
model LotHarvestSource {
  tenantId      String      @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id            String      @id @default(cuid())
  lotId         String
  harvestPickId String
  consumedKg    Decimal     @db.Decimal(12, 3)
  createdAt     DateTime    @default(now())
  lot           Lot         @relation(fields: [lotId], references: [id], onDelete: Cascade)
  harvestPick   HarvestPick @relation(fields: [harvestPickId], references: [id], onDelete: Restrict)

  @@index([lotId])
  @@index([harvestPickId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("lot_harvest_source")
}

// A recorded transition of one of the three orthogonal state vectors (form / AF / MLF).
// Form is mutable only through these (direct writes banned). Ordering (council/Codex): when a
// transition is caused by a transform it carries the triggering `operationId` (shares the
// ledger's monotonic fold order); standalone changes use a per-lot optimistic version check.
// `commandId` UNIQUE makes a phase mutation idempotent (duplicate-as-success, council S4).
model LotStateEvent {
  tenantId       String        @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id             String        @id @default(cuid())
  lotId          String
  vesselId       String? // snapshot context (the vessel the lot sat in at the transition)
  kind           String // FORM | AF | MLF — which vector changed (validated in code)
  fromValue      String // the prior enum value as text (durable across enum edits)
  toValue        String // the new enum value as text
  observedAt     DateTime
  enteredAt      DateTime      @default(now())
  enteredById    String? // actor id snapshot (no FK; matches LotOperation.actorUserId)
  enteredByEmail String // durable provenance snapshot
  captureMethod  CaptureMethod @default(MANUAL)
  note           String?
  operationId    Int? // set when a transform (crush/press/saignée/AF-dry) drove this transition
  commandId      String?       @unique // idempotency for a standalone phase mutation (duplicate=success)
  createdAt      DateTime      @default(now())
  lot            Lot           @relation(fields: [lotId], references: [id], onDelete: Cascade)
  vessel         Vessel?       @relation(fields: [vesselId], references: [id], onDelete: SetNull)
  operation      LotOperation? @relation(fields: [operationId], references: [id], onDelete: SetNull)

  @@index([lotId, observedAt])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("lot_state_event")
}

// Phase 7 (K1/K2): the 1:1 continuable-bottle projection for a lot in BOTTLED_IN_PROCESS
// form. Holds a bottle COUNT and a VOLUME, both DETERMINISTIC FOLDS of the ledger's
// BOTTLE_STORAGE legs, materialized INSIDE the writeLotOperation chokepoint (never by cores
// after it — council CRITICAL #1). Deleted at functional zero (FINISH closes both to ~0),
// exactly like a VesselLot row. CHECK(bottleCount >= 0) and CHECK(volumeL >= 0) in migration.
model BottledLotState {
  tenantId            String          @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  lotId               String          @id
  bottleCount         Int
  nominalFillMl       Int             @default(750)
  volumeL             Decimal         @db.Decimal(10, 2)
  method              SparklingMethod // TRADITIONAL | PETNAT (TANK never gets a state)
  stage               BottleStage
  tirageAt            DateTime // materialized + backdatable (months-on-lees + legacy seed)
  locationId          String? // physical bin (nullable; no bin-CRUD in Phase 7 — K12)
  // Descriptive attributes set by the cores (not folded from lines):
  tirageSugarAddedGpl Decimal?        @db.Decimal(6, 2) // liqueur de tirage sugar (Unit 5) → ABV-bump advisory
  disgorgedAt         DateTime? // set on a disgorged (child) lot (Unit 7)
  disgorgementRunId   String? // groups tranches peeled in one disgorgement run (K4/Unit 7)
  dosageStyle         DosageStyle? // EU sweetness style after dosage (Unit 8)
  dosageGramsPerL     Decimal?        @db.Decimal(6, 2) // actual dosage sugar g/L → carried to BottlingRun (Unit 8)
  updatedAt           DateTime        @updatedAt
  lot                 Lot             @relation(fields: [lotId], references: [id], onDelete: Cascade)
  location            Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([locationId])
  @@index([stage])
  @@index([disgorgementRunId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("bottled_lot_state")
}

// ───────────────────────── Phase 5: blends, lineage source-set & RBAC ─────────────────────────

// A lot's source-vineyard SET. A single-origin lot has one row; a blend has the UNION of its
// parents' full sets (materialized at the BLEND write, inductively transitive — council C6).
// Populated at SEED from originVineyardId and backfilled for existing lots. The scoping/lens
// query is "lots whose source vineyard ∈ my set" → index on vineyardId.
model LotVineyard {
  tenantId   String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id         String   @id @default(cuid())
  lotId      String
  vineyardId String
  createdAt  DateTime @default(now())
  lot        Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)
  vineyard   Vineyard @relation(fields: [vineyardId], references: [id], onDelete: Restrict)

  @@unique([tenantId, lotId, vineyardId])
  @@index([vineyardId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("lot_vineyard")
}

// D9 RBAC: a user's vineyard MEMBERSHIP set, replacing the single User.assignedVineyardId.
// A manager can manage N vineyards; a blended lot spans many. Added here (dual-read);
// assignedVineyardId is dropped in Unit 3 after the backfill is verified.
model UserVineyard {
  tenantId   String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id         String   @id @default(cuid())
  userId     String
  vineyardId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vineyard   Vineyard @relation(fields: [vineyardId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, vineyardId])
  @@index([vineyardId])
  @@index([tenantId])
  @@map("user_vineyard")
}

enum BlendTrialStatus {
  DRAFT
  CHOSEN
  PROMOTED
  DISCARDED
}

// An OFF-LEDGER bench trial — a throwaway small-scale blend experiment (component lots +
// proportions/volumes + a tasting outcome). Zero ledger impact until PROMOTED, when the chosen
// ratios prefill the blend builder and a real BLEND op runs (promotedToLotId links the result).
// Reuses the Phase 4 tasting enums. CHECK (score-with-scale together-or-neither) in migration.
model BlendTrial {
  tenantId        String                @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id              String                @id @default(cuid())
  name            String
  targetWine      String? // intent — what this trial aims at; groups DRAFTs (council S9)
  note            String?
  baseVolume      Decimal?              @db.Decimal(12, 3) // bench base size
  baseUnit        String? // mL | L (validated in code)
  status          BlendTrialStatus      @default(DRAFT)
  score           Int?
  scoreScale      TastingScoreScale?
  readiness       TastingReadiness?
  tastingNotes    String?
  chosenAt        DateTime?
  promotedToLotId String?
  enteredAt       DateTime              @default(now())
  enteredById     String? // actor id snapshot (no FK; matches LotOperation.actorUserId)
  enteredByEmail  String // durable provenance snapshot
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  components      BlendTrialComponent[]
  promotedToLot   Lot?                  @relation("TrialPromotedLot", fields: [promotedToLotId], references: [id], onDelete: SetNull)

  @@unique([tenantId, id])
  @@index([status])
  @@index([promotedToLotId])
  @@index([tenantId])
  @@map("blend_trial")
}

// One component of a bench trial: a lot + its share (proportion ∈ (0,1]) or absolute volume.
// CHECK (proportion ∈ (0,1]) in migration.
model BlendTrialComponent {
  tenantId   String     @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id         String     @id @default(cuid())
  trialId    String
  lotId      String
  proportion Decimal?   @db.Decimal(6, 5) // share of the base, (0,1]
  volume     Decimal?   @db.Decimal(12, 3)
  unit       String? // mL | L
  createdAt  DateTime   @default(now())
  trial      BlendTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)
  lot        Lot        @relation(fields: [lotId], references: [id], onDelete: Restrict)

  @@unique([tenantId, trialId, lotId])
  @@index([lotId])
  @@index([tenantId])
  @@map("blend_trial_component")
}

// ───────────────────────── Cellar operations (Phase 3) ─────────────────────────
// Detail rows for cellar operations that ride ON TOP of a LotOperation. A
// volume-NEUTRAL op (addition, fining, cap management) is a LotOperation with NO
// volumetric lines + one of these treatment rows; a volume-CHANGING op (filtration,
// loss, topping) carries lines AND, where it has material/medium detail, a treatment.
// The lot timeline UNIONs lot_operation_line.lotId with lot_treatment.lotId so neutral
// ops still appear. Material/rate/total + the volume SNAPSHOT used are stored, never
// recomputed (VISION D14). Corrected/voided via voidedByOperationId (stays visible).
model LotTreatment {
  tenantId            String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id                  String   @id @default(cuid())
  operationId         Int
  lotId               String
  vesselId            String? // the vessel the op happened in (snapshot context)
  kind                String // ADDITION | FINING | FILTRATION | PUMPOVER | PUNCHDOWN
  materialId          String? // optional catalog link
  materialName        String? // durable snapshot of the material name
  rateValue           Decimal? @db.Decimal(12, 4)
  rateBasis           String? // G_HL | MG_L | G_L | ML_L (validated in code, not a DB enum)
  computedTotal       Decimal? @db.Decimal(12, 3)
  computedUnit        String? // g | mL
  volumeLAtAddition   Decimal? @db.Decimal(10, 2) // vessel volume used for the math (snapshot)
  durationMin         Int? // cap management duration
  medium              String? // filtration medium (e.g. "pad", "membrane")
  micron              Decimal? @db.Decimal(8, 2) // filtration nominal micron
  note                String?
  voidedByOperationId Int? // set when a CORRECTION op voids this treatment (D6/D15)
  createdAt           DateTime @default(now())

  operation LotOperation    @relation("TreatmentOperation", fields: [operationId], references: [id], onDelete: Cascade)
  voidedBy  LotOperation?   @relation("TreatmentVoid", fields: [voidedByOperationId], references: [id], onDelete: SetNull)
  lot       Lot             @relation(fields: [lotId], references: [id], onDelete: Restrict)
  vessel    Vessel?         @relation(fields: [vesselId], references: [id], onDelete: SetNull)
  material  CellarMaterial? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([lotId])
  @@index([operationId])
  @@index([vesselId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("lot_treatment")
}

// Light material catalog (SO₂, nutrients, acids, tannins, fining agents) upserted on
// first use, deduped by normalizedKey within a kind (mirrors FieldInput). Carries a
// default dose basis + optional %active; cost/inventory is deferred to Phase 8.
model CellarMaterial {
  tenantId       String         @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id             String         @id @default(cuid())
  name           String // display label
  normalizedKey  String // dedup key (strip-non-alphanumeric, UPPERCASE)
  kind           String // load-bearing family (cost/dosing/identity): YEAST | MLF | SO2 | NUTRIENT | ACID | SUGAR | TANNIN | FINING | BENTONITE | CHITOSAN | ENZYME | CLEANING | SANITIZER | PACKAGING | OTHER
  subcategory    String? // Phase 034: optional user-defined subcategory (organizational only). Retired from UI in Phase 036 (family = kind); column kept dormant. NOT part of identity.
  // Phase 036: STORED main category (cost-safety authority: isDoseableCategory) + a richer purchase record.
  // `category` is one of ADDITIVE|CLEANING_SANITIZING|PACKAGING|OTHER (validated in code); nullable with a
  // categoryOf(kind) fallback so legacy rows keep working. All organizational/display/purchase-metadata —
  // NONE are part of identity (@@unique stays kind+normalizedKey).
  category       String? // stored main category (Phase 036); fallback = categoryOf(kind)
  genericName    String? // e.g. "Bentonite"
  brand          String? // manufacturer, e.g. "Lallemand"
  brandName      String? // product/brand name, e.g. "EC-1118"
  preferGeneric  Boolean        @default(false) // display toggle: show generic name instead of brand name
  vendor         String? // LEGACY free-text "where purchased" (Plan 069: superseded by vendorId; kept for read-compat)
  vendorUrl      String? // LEGACY free-text supplier/product URL (Plan 069: superseded by Vendor.url; kept for read-compat)
  vendorId       String? // Plan 069: managed vendor — composite-tenant FK → vendor(tenantId,id) (raw SQL, K11)
  packageAmount  Decimal?       @db.Decimal(18, 6) // purchase package size AMOUNT (e.g. 100 for a 100-gallon drum)
  packageUnit    String? // purchase package UNIT of measure (e.g. gal, lb, mL — see src/lib/units/measure.ts)
  defaultBasis   String? // G_HL | MG_L | G_L | ML_L
  percentActive  Decimal?       @db.Decimal(6, 3) // %active (material property, not a dose basis)
  isActive       Boolean        @default(true)
  // Phase 8 (Unit 1): stock + cost tracking, all additive. `stockUnit` is the canonical unit stock is
  // held/consumed in (g | mg | kg | mL | L | unit — validated in code); `packagingSize` is how much of
  // stockUnit one purchased package holds (informational, for receive-by-package UX). `isStockTracked`
  // opts a material into stock draw-down; a free-text/untracked material still doses (cost unknown, D14).
  packagingSize  Decimal?       @db.Decimal(18, 6)
  stockUnit      String?
  isStockTracked Boolean        @default(false)
  createdAt      DateTime       @default(now())
  treatments     LotTreatment[]
  supplyLots     SupplyLot[]

  @@unique([tenantId, kind, normalizedKey])
  @@unique([tenantId, id]) // Phase 8: composite-tenant-FK target for supply_lot (K11)
  @@index([tenantId])
  @@map("cellar_material")
}

// A named set of vessels (e.g. a barrel group) so one operation can fan out to its
// members (D13). Structure-only in Phase 1; the fan-out UI/logic lands in Phase 3.
model VesselGroup {
  tenantId  String              @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id        String              @id @default(cuid())
  name      String
  note      String?
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  members   VesselGroupMember[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("vessel_group")
}

model VesselGroupMember {
  tenantId String      @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id       String      @id @default(cuid())
  groupId  String
  vesselId String
  group    VesselGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  vessel   Vessel      @relation(fields: [vesselId], references: [id], onDelete: Cascade)

  @@unique([tenantId, groupId, vesselId])
  @@index([vesselId])
  @@index([tenantId])
  @@map("vessel_group_member")
}

// ───────────────────────── Chemistry / tasting / samples (Phase 4) ─────────────────────────
// STANDALONE records (NOT ledger ops — they describe the liquid, they don't move liters, so
// they do NOT go through writeLotOperation). They take BrixLog's standalone + inline-provenance
// shape and LotTreatment's appears-on-the-lot-timeline behavior. Each attaches to exactly ONE
// homogeneous lot (VISION D2). Undo is a soft-delete (voidedAt/voidedById), never a CORRECTION.
// Surfaced on the lot timeline by UNIONing these onto the loader, slotted by observedAt. Do NOT
// touch the vineyard BrixLog — cellar chemistry is lot/vessel-scoped and a separate domain.
//
// Provenance: actor ids are plain String? (no User FK relation) matching LotOperation.actorUserId
// and BrixLog.createdById; *ByEmail is the durable snapshot.

enum SampleStatus {
  PULLED
  SENT
  PENDING
  RESULT_RETURNED
  ATTACHED
  CANCELLED
}

enum TastingReadiness {
  NEEDS_MORE_TIME
  READY_TO_BLEND
  READY_TO_BOTTLE
  HOLD
  DECLINING
}

enum TastingScoreScale {
  HUNDRED_POINT
  TWENTY_POINT
}

// A panel HEADER groups one batch of readings observed together (a bench reading is a
// 1-child panel). The header owns observedAt + provenance + the optional sample link +
// voidedAt (so a panel voids ATOMICALLY — void the header, all readings drop). A returned
// lab result is a panel with `sampleId` set. SO₂ pairing happens WITHIN one panel only.
model AnalysisPanel {
  tenantId             String            @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id                   String            @id @default(cuid())
  lotId                String
  vesselId             String? // snapshot context (the vessel the lot sat in when measured)
  sampleId             String? // set when this panel is a returned result for a Sample
  observedAt           DateTime // when the wine was sampled/measured (time axis for trends)
  enteredAt            DateTime          @default(now())
  enteredById          String? // actor id snapshot (no FK; matches LotOperation.actorUserId)
  enteredByEmail       String // durable provenance snapshot
  captureMethod        CaptureMethod     @default(MANUAL)
  note                 String?
  clientRequestId      String?           @unique // idempotency: a double-submit is a no-op (= the offline "panel" command key)
  // Phase 6 offline capture (council S2/S5/S6): a Round row's Brix+temp commit as ONE atomic
  // panel. `deviceObservedAt` is the tablet clock at capture; `serverReceivedAt` is set on
  // insert; the stuck detector buckets by winery-tz. `occupancyToken` is the vessel's
  // resident-lot version at capture — validated against vessel-lot history as of observedAt so
  // a late offline sync can't attach a reading to the wrong lot. All nullable (chemistry
  // panels created online leave them null).
  deviceObservedAt     DateTime?
  serverReceivedAt     DateTime?
  occupancyToken       String?
  // Plan 060 fan-out: when ONE physical reading is taken on a multi-lot vessel (co-ferment),
  // it writes one panel per co-resident lot, ALL sharing this id (VISION D2 intact — each panel
  // still attaches to exactly one lot). Vessel-scoped views dedup by coalesce(vesselReadingGroupId, id);
  // lot-scoped views are unaffected so each lot keeps its curve. NULL = ordinary single-lot reading.
  // Derived deterministically from the capture's stable clientRequestId so retries/offline re-sync land
  // the same group. The @@unique below makes fan-out idempotent + blocks divergent same-(group,lot) rows.
  vesselReadingGroupId String?
  voidedAt             DateTime?
  voidedById           String?
  createdAt            DateTime          @default(now())
  lot                  Lot               @relation(fields: [lotId], references: [id], onDelete: Restrict)
  vessel               Vessel?           @relation(fields: [vesselId], references: [id], onDelete: SetNull)
  sample               Sample?           @relation(fields: [sampleId], references: [id], onDelete: SetNull)
  readings             AnalysisReading[]

  @@unique([tenantId, id])
  // Fan-out idempotency + integrity: one panel per (group, lot). NULLs are distinct in Postgres
  // unique indexes, so legacy/single-lot rows (null group) never collide — effectively partial.
  @@unique([tenantId, vesselReadingGroupId, lotId])
  @@index([lotId, observedAt])
  @@index([vesselId])
  @@index([vesselId, vesselReadingGroupId])
  @@index([sampleId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("analysis_panel")
}

// One analyte reading inside a panel. `analyte` is a code-validated string (the TS registry
// in src/lib/chemistry/analytes.ts — a new analyte is a config edit, not a migration). Trends
// query readings by `analyte` joined to the non-voided parent panel; the panel's `observedAt`
// is the time axis.
model AnalysisReading {
  tenantId  String        @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id        String        @id @default(cuid())
  panelId   String
  analyte   String // registry key (PH, FREE_SO2, …) — validated in code, not a DB enum
  value     Decimal       @db.Decimal(12, 4)
  unit      String // the unit the value was entered in (registry-allowed)
  // Phase 6 offline idempotency (council S1): a client-minted UUID per analyte reading.
  // UNIQUE + ON CONFLICT DO NOTHING on insert; a duplicate sync is treated as SUCCESS. A
  // captured reading is immutable — an edit mints a NEW captureId, never reuses one. Nullable:
  // online chemistry readings have none.
  captureId String?       @unique
  createdAt DateTime      @default(now())
  panel     AnalysisPanel @relation(fields: [panelId], references: [id], onDelete: Cascade)

  @@unique([tenantId, panelId, analyte]) // a panel holds at most one reading per analyte (Brix+temp can't desync)
  @@index([panelId])
  @@index([analyte])
  @@index([tenantId])
  @@map("analysis_reading")
}

// A structured tasting note on a lot. Free-text search (NICE) is a `contains` over
// notes/aroma/flavor — no tsvector this phase (avoids the search_vector migration gotcha).
model LotTastingNote {
  tenantId        String             @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id              String             @id @default(cuid())
  lotId           String
  vesselId        String?
  observedAt      DateTime
  enteredAt       DateTime           @default(now())
  enteredById     String?
  enteredByEmail  String
  captureMethod   CaptureMethod      @default(MANUAL)
  appearance      String?
  aroma           String?
  flavor          String?
  tannin          Int? // 1–5 structure scores
  acidity         Int?
  body            Int?
  finish          Int?
  score           Int?
  scoreScale      TastingScoreScale?
  readiness       TastingReadiness?
  notes           String?
  clientRequestId String?            @unique
  voidedAt        DateTime?
  voidedById      String?
  createdAt       DateTime           @default(now())
  lot             Lot                @relation(fields: [lotId], references: [id], onDelete: Restrict)
  vessel          Vessel?            @relation(fields: [vesselId], references: [id], onDelete: SetNull)

  @@index([lotId, observedAt])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("lot_tasting_note")
}

// A lab/bench sample with a lifecycle (PULLED → SENT → PENDING → RESULT_RETURNED → ATTACHED,
// plus CANCELLED). 1→many AnalysisPanel: a returned result is a panel linked here. Transitions
// go through guarded core fns that set status + the matching timestamp together. The sample's
// `lotId` is captured AT PULL and inherited by its result panels (never re-resolved from the
// current vessel — backdated/late-resulted readings must not be misattributed). D2.
model Sample {
  tenantId        String          @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id              String          @id @default(cuid())
  lotId           String
  vesselId        String?
  status          SampleStatus    @default(PULLED)
  source          String? // free text, e.g. "Barrel A3"
  lab             String? // outside lab name (e.g. "ETS")
  pulledAt        DateTime        @default(now()) // the sample's observed time
  sentAt          DateTime?
  expectedAt      DateTime?
  resultedAt      DateTime? // when the lab ran it (metadata, not the reading's observed time)
  attachedAt      DateTime?
  cancelledAt     DateTime?
  enteredById     String?
  enteredByEmail  String
  captureMethod   CaptureMethod   @default(MANUAL)
  note            String?
  clientRequestId String?         @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lot             Lot             @relation(fields: [lotId], references: [id], onDelete: Restrict)
  vessel          Vessel?         @relation(fields: [vesselId], references: [id], onDelete: SetNull)
  panels          AnalysisPanel[]

  @@index([lotId, status])
  @@index([status])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("sample")
}

// ───────────────────────── Phase 14: TTB 5120.17 compliance reporting ─────────────────────────
// Both tables are tenant-scoped + RLS-isolated per the AGENTS.md Phase-12 checklist: tenantId +
// index + FK→organization ON DELETE RESTRICT, per-tenant uniques, RLS ENABLE+FORCE+tenant_isolation
// (USING + WITH CHECK on current_setting('app.tenant_id', true)), app_rls DML grant, isolation test.

// A generated Report of Wine Premises Operations for one period + version. FILED rows are IMMUTABLE
// (eng-review E1): regeneration/amendment always writes a NEW row. `computed`/`overrides`/`onHandEnd`
// are snapshots; audit backing is re-derived on demand for DRAFTs and frozen into `computed` at FILE
// (E2). `onHandEnd` is the S3 carry-forward source for the next period's on-hand-beginning.
model ComplianceReport {
  tenantId              String                  @default("") // Phase 12 tenant scope; FK+RLS at DB level
  id                    String                  @id @default(cuid())
  periodStart           DateTime // inclusive
  periodEnd             DateTime // inclusive
  cadence               ReportCadence           @default(MONTHLY)
  // plan-026 Fork 1A: which form this row is. Defaults to the 5120.17 so existing rows read as
  // operations reports; the excise generator sets TTB_5000_24. formType scopes every report query.
  formType              ComplianceFormType      @default(TTB_5120_17)
  status                ComplianceReportStatus  @default(DRAFT)
  version               ComplianceReportVersion @default(ORIGINAL)
  // plan-026: the net wine excise tax (amount to pay) for a TTB_5000_24 row; null for 5120.17.
  // Display/query mirror of computed.summary.amountToPay — the worksheet Json remains authoritative.
  taxDollars            Decimal?                @db.Decimal(12, 2)
  // S4: "Final" is a one-time business-closing flag, separate from status + version.
  isFinalBusinessReport Boolean                 @default(false)
  amendsReportId        String? // the ORIGINAL this row amends (version AMENDED)
  // Phase 2 (BOND-1 / per-bond scoping): the bond this 5120.17 chain files for. NULL = legacy
  // single-bond (pre-Phase-2 rows, backfilled to the tenant's primary bond). Carry-forward chains
  // per (formType, bondId) so per-bond filing chains never cross. Composite (tenantId, bondId) →
  // bond(tenantId, id) FK in raw SQL (M2). The 5000.24 excise return stays bond-agnostic (NULL).
  bondId                String?
  // Phase 2 (OQ-2, council Codex-DESIGN2): filer identity resolved bond-first (else the tenant
  // ComplianceProfile) and SNAPSHOTTED at FILE, so an amended reprint never drifts if the Bond/
  // profile is later edited. NULL on DRAFT (resolved live); frozen at markReportFiled.
  filerSnapshot         Json?
  onHandEnd             Json // per section/column/sub gallons — the S3 carry-forward source
  computed              Json // full §A/§B line snapshot (frozen at FILE; re-derived for DRAFT — E2)
  overrides             Json // saved per-lot tax-class overrides applied at generation
  remarks               String                  @default("") // Part X
  generatedAt           DateTime                @default(now())
  filedAt               DateTime?
  filedByEmail          String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  amends    ComplianceReport?  @relation("ReportAmendment", fields: [amendsReportId], references: [id], onDelete: Restrict)
  amendedBy ComplianceReport[] @relation("ReportAmendment")

  @@index([tenantId])
  @@index([tenantId, periodStart, periodEnd])
  @@index([tenantId, formType])
  // Phase 2 (council Codex-SF): carry-forward + AMEND-1 downstream-mark scans filter by
  // (formType, bondId, status) and order by periodEnd/generatedAt — cover them all.
  @@index([tenantId, formType, bondId, status, periodEnd, generatedAt])
  @@index([amendsReportId])
  @@map("compliance_report")
}

// Per-tenant compliance profile (like AppSettings): the filer identity that heads the form.
model ComplianceProfile {
  tenantId             String        @default("") // Phase 12 tenant scope; FK+RLS at DB level
  id                   String        @id @default(cuid())
  ein                  String?
  registryNumber       String?
  operatedByName       String?
  // Composed single-line address (kept in sync from the structured parts below) — the value
  // printed on the Form 5120.17 header. The structured parts drive the settings/compliance UI.
  operatedByAddress    String?
  operatedByStreet1    String?
  operatedByStreet2    String?
  operatedByCity       String?
  operatedByState      String?
  operatedByZip        String?
  operatedByPhone      String?
  defaultCadence       ReportCadence @default(MONTHLY)
  // plan-026: the wine EXCISE-return cadence (27 CFR 24.271), separate from the ops defaultCadence.
  // Defaults to SEMIMONTHLY (the fallback cadence when annual liability > $50k); the generate screen
  // seeds from it. isEftPayer flips the September triple-split boundaries (council C1).
  defaultReturnCadence ReportCadence @default(SEMIMONTHLY)
  isEftPayer           Boolean       @default(false)
  updatedAt            DateTime      @updatedAt

  @@unique([tenantId])
  @@index([tenantId])
  @@map("compliance_profile")
}

// ───────────────────────── Phase 2: Bond + tax-class model (line-scoped, time-aware) ─────────────────────────
// Both tables are tenant-scoped + RLS-isolated per the AGENTS.md Phase-12 checklist (tenantId
// @default("") + @@index([tenantId]) + FK→organization ON DELETE RESTRICT + per-tenant uniques +
// RLS ENABLE+FORCE+tenant_isolation, kept OUT of GLOBAL_MODELS). Composite cross-tenant FKs
// (line→bond, report→bond, event→lot) are RAW SQL (tenantId, refId)→(tenantId, id) at the DB level
// (K11 / Phase-1 Surprise 1) — NO Prisma @relation (composite relations blow TS type-instantiation
// depth). Migrations: _bond_taxclass_enums (OperationType + status ADD VALUE), _bond_taxclass_schema
// (these tables + line/report columns + RLS), _bond_taxclass_backfill (primary bond + report.bondId).

// A TTB bond instrument. The winery's wine sits "in bond" under exactly one bond at a time; a
// cross-bond movement (TRANSFER_IN_BOND) posts symmetric removed/received-in-bond to both bonds'
// 5120.17 chains (BOND-1). Bonds are tenant-editable self-serve (ux-principle 9) — never a support
// ticket. The authoritative bond of a position is DERIVED from the ledger line, never a mutable
// Lot column; this table is the registry, not the per-lot source of truth.
model Bond {
  tenantId       String   @default("") // Phase 12 tenant scope; FK+RLS at DB level
  id             String   @id @default(cuid())
  registryNumber String // TTB bond registry number (per-tenant unique)
  penalSum       Decimal? @db.Decimal(12, 2)
  premises       String? // bonded-premises address/description
  ownerId        String? // Plan 093: the Owner this bond belongs to (an AP proprietor's own bond). Composite (tenantId, ownerId) → owner(tenantId, id), enforced raw-SQL (K11). NULL = the tenant's own/primary bond.
  isPrimary      Boolean  @default(false) // the tenant's default bond (exactly one; created at backfill)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, registryNumber])
  @@unique([tenantId, id]) // composite cross-tenant FK target (K11)
  @@index([tenantId])
  @@index([tenantId, isPrimary])
  @@map("bond")
}

// A dated, append-only Change-Of-Tax-Class event (TAXCLASS-1). Tax class stays DERIVED (never a
// stored Lot column); this event is the point-in-time OVERRIDE the winemaker sets to intentionally
// declare/correct a class. It carries NO volume (so it is NOT a ledger op — a zero-volume line would
// violate LEDGER-2); instead `volumeAtEvent` snapshots the lot's on-hand volume as-of `observedAt`
// at write time, and the 5120.17 fold posts §A 10/24/25 from it. `resolveClassesForLots` reads the
// latest in-scope event before falling back to ABV derivation. Append-only: a correction is a new event.
model ChangeOfTaxClassEvent {
  tenantId      String   @default("") // Phase 12 tenant scope; FK+RLS at DB level
  id            String   @id @default(cuid())
  lotId         String // composite (tenantId, lotId) → lot(tenantId, id) FK in raw SQL (M2)
  fromClass     String? // WineTaxClass (TS union); null = previously derived/undeclared
  toClass       String // WineTaxClass the lot is declared into as-of observedAt
  volumeAtEvent Decimal? @db.Decimal(10, 2) // on-hand liters as-of observedAt, stamped at write
  observedAt    DateTime // the dated point-in-time change (drives §A 10/24/25 in the period fold)
  actor         String? // actor email snapshot
  reason        String?
  commandId     String? // idempotency (double-submit → no-op); NULLs distinct per Postgres
  createdAt     DateTime @default(now())

  @@unique([tenantId, commandId])
  @@unique([tenantId, id]) // composite cross-tenant FK target (K11)
  @@index([tenantId, lotId, observedAt]) // point-in-time class resolution lookup
  @@map("change_of_tax_class_event")
}

// Phase 3: generic migration kernel. These tenant-scoped tables stage a Day-Zero import, preserve
// legacy history as archive evidence, and gate publish on accepted reconciliation. Status/kind values
// are String columns constrained in SQL, so later partner-specific phases can widen contracts without
