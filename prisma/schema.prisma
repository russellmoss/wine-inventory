// Bhutan Wine Company — Prisma schema (Prisma 6, Neon Postgres)
// Auth models (User/Session/Account/Verification) are owned by Better Auth
// (generated via its CLI). Domain + audit models follow.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ───────────────────────── Auth (Better Auth) ─────────────────────────

model User {
  id                     String                  @id
  name                   String
  email                  String
  emailVerified          Boolean                 @default(false)
  image                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  role                   String?
  banned                 Boolean?                @default(false)
  banReason              String?
  banExpires             DateTime?
  mustChangePassword     Boolean?                @default(false)
  passwordChangedAt      DateTime?
  sessions               Session[]
  accounts               Account[]
  fieldNotes             FieldNote[]
  assistantConversations AssistantConversation[]
  // Phase 5 (D9): vineyard MEMBERSHIP set — replaced the single assignedVineyardId column
  // (dropped in migration 20260629000300 after the backfill was verified).
  vineyardMemberships    UserVineyard[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ───────────────────────── Enums ─────────────────────────

enum VesselType {
  BARREL
  TANK
}

enum ItemKind {
  BOTTLED_WINE
  FINISHED_GOOD
}

enum MovementKind {
  RECEIVE
  ADJUST
  TRANSFER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  PASSWORD_RESET
  PASSWORD_CHANGE
  USER_CREATED
  USER_DELETED
  BOTTLING
  STOCK_MOVEMENT
  FIELD_NOTE_CREATED
  FIELD_INPUT_CREATED
  USER_VINEYARD_ASSIGNED
  BRIX_LOGGED
  HARVEST_ESTIMATED
  HARVEST_PICK_RECORDED
  // Phase 4 sample lifecycle (added in a dedicated ALTER TYPE migration — a new enum
  // VALUE can't be used in the transaction that adds it). Panel/tasting create+void
  // reuse CREATE/DELETE.
  SAMPLE_PULLED
  SAMPLE_SENT
  SAMPLE_ATTACHED
  SAMPLE_CANCELLED
}

// ───────────────────────── Shared registries ─────────────────────────

model Location {
  id                    String                  @id @default(cuid())
  name                  String                  @unique
  isSystem              Boolean                 @default(false) // "Winery" = true
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  bottledInventory      BottledInventory[]
  finishedGoodInventory FinishedGoodInventory[]
  stockMovements        StockMovement[]
  bottlingRuns          BottlingRun[]

  @@map("location")
}

model Variety {
  id              String            @id @default(cuid())
  name            String            @unique
  abbreviation    String?           @unique // 2–4 uppercase code for lot codes (PN, CS). Nullable→backfilled; Postgres unique allows multiple NULLs.
  isActive        Boolean           @default(true)
  color           String? // canonical per-variety map color (hex), consistent across vineyards
  createdAt       DateTime          @default(now())
  components      VesselComponent[]
  bottlingSources BottlingSource[]
  vineyardBlocks  VineyardBlock[]

  @@map("variety")
}

model Vineyard {
  id              String            @id @default(cuid())
  name            String            @unique
  abbreviation    String?           @unique // 2–4 uppercase code for lot codes (GS, NT). Nullable→backfilled; Postgres unique allows multiple NULLs.
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  components      VesselComponent[]
  bottlingSources BottlingSource[]
  detail          VineyardDetail?
  blocks          VineyardBlock[]
  fieldNotes      FieldNote[]
  brixLogs        BrixLog[]
  harvestRecords  HarvestRecord[]
  // Phase 5.
  lotMemberships  LotVineyard[]     // lots whose source set includes this vineyard
  userMemberships UserVineyard[]    // users who manage this vineyard (D9 membership set)

  @@map("vineyard")
}

// ───────────────────────── Vineyard details + blocks ─────────────────────────

// Sparse, optional per-vineyard metadata (1:1 with Vineyard, created lazily).
// Spacing/elevation are stored canonically in METRIC; the UI converts for display.
model VineyardDetail {
  id          String   @id @default(cuid())
  vineyardId  String   @unique
  gpsLat      Decimal? @db.Decimal(9, 6)
  gpsLng      Decimal? @db.Decimal(9, 6)
  elevationM  Decimal? @db.Decimal(8, 2)
  soilType    String?
  manager     String?
  defaultUnit String   @default("imperial") // "imperial" | "metric"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vineyard    Vineyard @relation(fields: [vineyardId], references: [id], onDelete: Cascade)

  @@map("vineyard_detail")
}

// A planted block within a vineyard. All fields optional; nothing required to save.
// Acreage is NOT stored — it is derived from rowSpacing * vineSpacing * vineCount.
model VineyardBlock {
  id             String             @id @default(cuid())
  vineyardId     String
  blockLabel     String? // e.g. "Block 1", "A"
  code           String? // short token for lot codes (e.g. "1", "A"); falls back to a normalized blockLabel
  numRows        Int? // informational (drives optional vines/row readout)
  rowSpacingM    Decimal?           @db.Decimal(10, 4) // canonical metric
  vineSpacingM   Decimal?           @db.Decimal(10, 4) // canonical metric
  varietyId      String?
  clone          String?
  rootstock      String?
  vineCount      Int?
  yearPlanted    Int?
  irrigated      Boolean?
  polygon        Json? // GeoJSON Polygon geometry (illustrative, not the area source)
  color          String? // optional per-block polygon color override (hex)
  sortOrder      Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  vineyard       Vineyard           @relation(fields: [vineyardId], references: [id], onDelete: Cascade)
  variety        Variety?           @relation(fields: [varietyId], references: [id], onDelete: SetNull)
  brixLogs       BrixLog[]
  harvestRecords HarvestRecord[]
  subblocks      VineyardSubblock[]

  @@index([vineyardId])
  @@index([varietyId])
  @@map("vineyard_block")
}

// A geographic sub-division of a block (e.g. "A"/"B") for differential picks / experiments.
// `code` is the short token that appears in a lot code between BLOCK and VARIETY.
model VineyardSubblock {
  id        String        @id @default(cuid())
  blockId   String
  code      String // short uppercase token for lot codes (e.g. "A")
  label     String? // optional human label
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  block     VineyardBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, code])
  @@index([blockId])
  @@map("vineyard_subblock")
}

// ───────────────────────── Vineyard operations: field notes ─────────────────────────

// One canonical weekly field report per vineyard (Friday-anchored). JSON columns
// hold the LLM-friendly weather / inputs / per-block status payloads; vineyard +
// manager stay real FKs for querying. `userEmail` snapshots provenance (mirror
// BottlingRun) so deleting the manager (SetNull) never erases who logged it.
model FieldNote {
  id                 String    @id @default(cuid())
  vineyardId         String
  userId             String? // manager who logged it; SetNull so user delete doesn't cascade
  userEmail          String // durable provenance snapshot
  weekOf             DateTime  @db.Date // Friday anchor, written via the canonical UTC helper
  weatherData        Json // { rainfallMm, maxTempC, minTempC }
  spraysApplied      Json // [{ name, scope: "WHOLE"|"BLOCKS", blockIds: [] }]
  fertilizersApplied Json // same shape as spraysApplied
  blockLevelStatuses Json // { [blockId]: BlockStatus }
  schemaVersion      Int       @default(1) // JSON shape version
  generalNotes       String?
  aiSummary          String?
  aiSummaryStatus    String    @default("PENDING") // PENDING | READY | FAILED
  aiSummaryAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  vineyard           Vineyard  @relation(fields: [vineyardId], references: [id], onDelete: Cascade)
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([vineyardId, weekOf]) // one canonical note per vineyard per week
  @@index([vineyardId, weekOf])
  @@map("field_note")
}

// Master list of sprays/fertilizers. `normalizedKey` (strip-all-non-alphanumeric
// UPPERCASE) dedupes "NEEM OIL" / "NEEM-OIL" to one row; `name` keeps the label.
model FieldInput {
  id            String   @id @default(cuid())
  type          String // SPRAY | FERTILIZER
  name          String // display, cleaned UPPERCASE
  normalizedKey String // dedup key, strip-all-non-alphanumeric UPPERCASE
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@unique([type, normalizedKey])
  @@map("field_input")
}

// ───────────────────────── Vineyard operations: harvest ledger ─────────────────────────

// Per-block Brix readings logged repeatedly across the ripening window.
// `vineyardId` denormalized for clean aggregates; block delete is Restricted so
// ripening history is never erased by a block edit. DB CHECK enforces 0..40.
model BrixLog {
  id             String        @id @default(cuid())
  blockId        String
  vineyardId     String // denormalized FK for aggregates
  brixValue      Decimal       @db.Decimal(4, 1)
  recordedAt     DateTime      @default(now())
  createdById    String?
  createdByEmail String // provenance snapshot
  note           String?
  block          VineyardBlock @relation(fields: [blockId], references: [id], onDelete: Restrict)
  vineyard       Vineyard      @relation(fields: [vineyardId], references: [id], onDelete: Restrict)

  @@index([blockId, recordedAt])
  @@index([vineyardId])
  @@map("brix_log")
}

// One record per (block, vintage): holds the pre-harvest estimate and parents the
// pick passes. `totalWeightKg` is NOT stored — it is the sum of `picks`.
model HarvestRecord {
  id              String        @id @default(cuid())
  blockId         String
  vineyardId      String // denormalized FK for aggregates
  vintageYear     Int
  yieldEstimateKg Decimal?      @db.Decimal(12, 3) // pre-harvest estimate, canonical kg
  createdById     String?
  createdByEmail  String
  updatedByEmail  String?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  block           VineyardBlock @relation(fields: [blockId], references: [id], onDelete: Restrict)
  vineyard        Vineyard      @relation(fields: [vineyardId], references: [id], onDelete: Restrict)
  picks           HarvestPick[]

  @@unique([blockId, vintageYear])
  @@index([vineyardId, vintageYear])
  @@map("harvest_record")
}

// Each pick pass against a HarvestRecord. Vineyards pick a block in multiple
// passes; the total auto-rolls up from these rows.
model HarvestPick {
  id              String        @id @default(cuid())
  harvestRecordId String
  pickDate        DateTime      @db.Date
  weightKg        Decimal       @db.Decimal(12, 3) // canonical kg
  brixAtPick      Decimal?      @db.Decimal(4, 1) // optional Brix the fruit came off at
  createdById     String?
  createdByEmail  String
  note            String?
  createdAt       DateTime      @default(now())
  harvestRecord   HarvestRecord @relation(fields: [harvestRecordId], references: [id], onDelete: Cascade)

  @@index([harvestRecordId, pickDate])
  @@map("harvest_pick")
}

// ───────────────────────── Bulk / in-process wine ─────────────────────────

model Vessel {
  id               String              @id @default(cuid())
  code             String // barrels: "Barrel #"; tanks: code. Unique per type (see @@unique below).
  type             VesselType
  capacityL        Decimal             @db.Decimal(10, 2)
  isActive         Boolean             @default(true)
  blendName        String? // optional label for the current blend in this vessel
  // Barrel-only metadata (null for tanks). Volume = capacityL (not duplicated here).
  // The barrel's "Barrel #" is its `code` above — no separate number column.
  oakOrigin        String? // e.g. French, American, Hungarian
  cooperageYear    Int? // year the barrel was made
  cooperage        String? // barrel maker, e.g. Seguin Moreau
  toastLevel       String? // e.g. Light, Medium, Medium+, Heavy
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  components       VesselComponent[]
  bottlingSources  BottlingSource[]
  transfersOut     VesselTransfer[]    @relation("VesselTransfersOut")
  transfersIn      VesselTransfer[]    @relation("VesselTransfersIn")
  // Lot + ledger spine (Phase 1): the projection rows, group memberships, and the
  // operation lines that reference this vessel. Additive; existing relations unchanged.
  vesselLots       VesselLot[]
  groupMemberships VesselGroupMember[]
  operationLines   LotOperationLine[]
  treatments       LotTreatment[]
  // Phase 4 standalone records (snapshot context; vessel delete SetNulls these).
  analysisPanels   AnalysisPanel[]
  tastingNotes     LotTastingNote[]
  samples          Sample[]

  @@unique([type, code]) // barrel "1" and tank "1" can coexist; numbers unique within a type
  @@map("vessel")
}

model VesselComponent {
  id         String   @id @default(cuid())
  vesselId   String
  varietyId  String
  vineyardId String
  vintage    Int
  volumeL    Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vessel     Vessel   @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  variety    Variety  @relation(fields: [varietyId], references: [id], onDelete: Restrict)
  vineyard   Vineyard @relation(fields: [vineyardId], references: [id], onDelete: Restrict)

  @@unique([vesselId, varietyId, vineyardId, vintage])
  @@index([vesselId])
  @@index([varietyId])
  @@map("vessel_component")
}

// One racking / wine transfer between two vessels. `volumeL` is the volume drawn
// OUT of the source; `lossL` is what was lost to lees (volume INTO the destination
// = volumeL - lossL). `components` is a JSON snapshot of the moved breakdown
// ([{ varietyName, vineyardName, vintage, volumeL }]) so history reads correctly
// even for multi-lot (tank) racks and survives later vessel edits. Vessel codes
// are snapshotted so a deleted vessel (FK SetNull) still shows in history.
model VesselTransfer {
  id             String           @id @default(cuid())
  fromVesselId   String?
  toVesselId     String?
  fromVesselCode String
  toVesselCode   String
  volumeL        Decimal          @db.Decimal(10, 2)
  lossL          Decimal          @default(0) @db.Decimal(10, 2)
  components     Json
  note           String?
  actorUserId    String?
  actorEmail     String
  rackedAt       DateTime         @default(now())
  // Revert tracking (LEGACY undo path). Phase 1 (D6/D15) replaces row-reversion with
  // a CORRECTION ledger op; "reverted" is derived from a correction's existence. These
  // columns remain for the pre-cutover history read and are dropped in a later cleanup.
  revertedAt     DateTime?
  revertsId      String?
  reverts        VesselTransfer?  @relation("TransferReversal", fields: [revertsId], references: [id], onDelete: SetNull)
  reversedBy     VesselTransfer[] @relation("TransferReversal")
  fromVessel     Vessel?          @relation("VesselTransfersOut", fields: [fromVesselId], references: [id], onDelete: SetNull)
  toVessel       Vessel?          @relation("VesselTransfersIn", fields: [toVesselId], references: [id], onDelete: SetNull)
  // Phase 1: a RACK is a derived read-model of one ledger operation. Unique 1:1 link;
  // written only by the ledger writer.
  lotOperationId Int?             @unique
  lotOperation   LotOperation?    @relation(fields: [lotOperationId], references: [id], onDelete: SetNull)

  @@index([fromVesselId, rackedAt])
  @@index([toVesselId, rackedAt])
  @@index([rackedAt])
  @@index([revertsId])
  @@map("vessel_transfer")
}

// ───────────────────────── Bottling ─────────────────────────

model WineSku {
  id               String                @id @default(cuid())
  name             String
  vintage          Int
  bottleSizeMl     Int                   @default(750)
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  categoryId       String?
  category         FinishedGoodCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  bottlingRuns     BottlingRun[]
  bottledInventory BottledInventory[]
  stockMovements   StockMovement[]

  @@unique([name, vintage, bottleSizeMl])
  @@index([categoryId])
  @@map("wine_sku")
}

model BottlingRun {
  id                    String           @id @default(cuid())
  date                  DateTime
  wineSkuId             String
  bottlesProduced       Int
  volumeConsumedL       Decimal          @db.Decimal(10, 2)
  destinationLocationId String
  createdById           String? // soft-deleted users; snapshot below survives
  createdByEmail        String
  createdAt             DateTime         @default(now())
  wineSku               WineSku          @relation(fields: [wineSkuId], references: [id], onDelete: Restrict)
  destinationLocation   Location         @relation(fields: [destinationLocationId], references: [id], onDelete: Restrict)
  sources               BottlingSource[]
  stockMovements        StockMovement[]

  @@index([wineSkuId])
  @@index([date])
  @@map("bottling_run")
}

model BottlingSource {
  id              String      @id @default(cuid())
  bottlingRunId   String
  vesselId        String
  varietyId       String
  vineyardId      String
  vintage         Int
  volumeConsumedL Decimal     @db.Decimal(10, 2)
  // Phase 1: lot provenance for NEW runs going forward. Nullable; historical rows are
  // NOT backfilled (D11 — inferred links are fabricated provenance).
  lotId           String?
  bottlingRun     BottlingRun @relation(fields: [bottlingRunId], references: [id], onDelete: Cascade)
  vessel          Vessel      @relation(fields: [vesselId], references: [id], onDelete: Restrict)
  variety         Variety     @relation(fields: [varietyId], references: [id], onDelete: Restrict)
  vineyard        Vineyard    @relation(fields: [vineyardId], references: [id], onDelete: Restrict)
  lot             Lot?        @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([bottlingRunId])
  @@index([vesselId])
  @@index([lotId])
  @@map("bottling_source")
}

// ───────────────────────── Inventory ledger + cached balances ─────────────────────────

model StockMovement {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  createdById     String?
  createdByEmail  String
  itemKind        ItemKind
  wineSkuId       String?
  finishedGoodId  String?
  locationId      String
  kind            MovementKind
  deltaUnits      Int // bottles (wine) or each (goods); signed
  reason          String?
  transferGroupId String? // pairs the out/in legs of a TRANSFER
  bottlingRunId   String?
  wineSku         WineSku?      @relation(fields: [wineSkuId], references: [id], onDelete: Restrict)
  finishedGood    FinishedGood? @relation(fields: [finishedGoodId], references: [id], onDelete: Restrict)
  location        Location      @relation(fields: [locationId], references: [id], onDelete: Restrict)
  bottlingRun     BottlingRun?  @relation(fields: [bottlingRunId], references: [id], onDelete: SetNull)

  @@index([wineSkuId])
  @@index([finishedGoodId])
  @@index([locationId])
  @@index([createdAt])
  @@index([transferGroupId])
  @@map("stock_movement")
}

model BottledInventory {
  id           String   @id @default(cuid())
  wineSkuId    String
  locationId   String
  totalBottles Int      @default(0)
  updatedAt    DateTime @updatedAt
  wineSku      WineSku  @relation(fields: [wineSkuId], references: [id], onDelete: Restrict)
  location     Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@unique([wineSkuId, locationId])
  @@index([locationId])
  @@map("bottled_inventory")
}

// ───────────────────────── Finished goods (merch) ─────────────────────────

model FinishedGoodCategory {
  id        String         @id @default(cuid())
  name      String         @unique
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  goods     FinishedGood[]
  wineSkus  WineSku[]

  @@map("finished_good_category")
}

model FinishedGood {
  id             String                  @id @default(cuid())
  name           String
  categoryId     String
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  category       FinishedGoodCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  inventory      FinishedGoodInventory[]
  stockMovements StockMovement[]

  @@index([categoryId])
  @@map("finished_good")
}

model FinishedGoodInventory {
  id             String       @id @default(cuid())
  finishedGoodId String
  locationId     String
  quantity       Int          @default(0)
  updatedAt      DateTime     @updatedAt
  finishedGood   FinishedGood @relation(fields: [finishedGoodId], references: [id], onDelete: Restrict)
  location       Location     @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@unique([finishedGoodId, locationId])
  @@index([locationId])
  @@map("finished_good_inventory")
}

// ───────────────────────── Audit ─────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  actorUserId String?
  actorEmail  String
  action      AuditAction
  entityType  String
  entityId    String?
  changes     Json?
  summary     String
  ipAddress   String?
  userAgent   String?

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("audit_log")
}

// ───────────────────────── Assistant (chat) ─────────────────────────

// Single-use guard for the assistant's confirm-before-write flow. A write tool
// returns a signed, short-TTL proposal token; on confirm we insert the token's
// nonce here (unique) BEFORE committing, so a replayed/double-submitted confirm
// can never double-apply a change (critical for inventory deltas).
model AssistantConfirmation {
  id         String   @id @default(cuid())
  nonce      String   @unique
  tool       String
  actorEmail String
  usedAt     DateTime @default(now())

  @@map("assistant_confirmation")
}

// User feedback on assistant replies (thumbs up/down + optional "what was wrong").
// `conversation` snapshots the transcript so the feedback-fix agent has context.
// `status` tracks the improvement loop: NEW -> TRIAGED (agent opened a PR) -> ...
model AssistantFeedback {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  rating       String // "up" | "down"
  comment      String? // free-text "what was wrong" (UNTRUSTED input)
  conversation Json // [{ role, content }] transcript for context
  actorUserId  String?
  actorEmail   String
  status       String   @default("NEW") // NEW | TRIAGED | RESOLVED | DISMISSED
  prUrl        String?
  notes        String?

  @@index([status, createdAt])
  @@map("assistant_feedback")
}

// A persisted assistant chat. Scoped to the owning user (personal history, not
// vineyard data). `title` is auto-generated from the first user message. Messages
// cascade-delete with the conversation.
model AssistantConversation {
  id          String             @id @default(cuid())
  ownerUserId String
  title       String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  owner       User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  messages    AssistantMessage[]

  @@index([ownerUserId, updatedAt])
  @@map("assistant_conversation")
}

// One persisted text turn in a conversation. Only "user"/"assistant" text turns
// are stored (ephemeral write-proposal cards are not). `search_vector` is a
// Postgres generated tsvector column (added in the migration, not managed by
// Prisma) backing full-text search; it is intentionally absent from this model.
model AssistantMessage {
  id             String                   @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String                   @db.Text
  metadata       Json?
  createdAt      DateTime                 @default(now())
  // Postgres GENERATED tsvector over `content` (see migration). Declared here so
  // Prisma tracks the column + GIN index and won't flag drift; never written by app.
  searchVector   Unsupported("tsvector")? @map("search_vector")
  conversation   AssistantConversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([searchVector], type: Gin)
  @@map("assistant_message")
}

// ───────────────────────── Lot + operation ledger (Phase 1 spine) ─────────────────────────
// The append-only source of truth for BULK wine. `VesselComponent` (above) is retired
// after the Day-Zero migration; `VesselLot` is the materialized projection. See
// VISION §3, docs/INVARIANTS.md. Enums mirror src/lib/ledger/vocabulary.ts.
//
// NOTE: CHECK constraints (volumeL > 0, deltaL <> 0) and the vessel-capacity guard are
// NOT expressible in Prisma — they are added in the migration's raw SQL (D14).

enum LotForm {
  FRUIT
  MUST
  JUICE
  WINE
  BOTTLED_IN_PROCESS
  FINISHED
}

enum OperationType {
  SEED
  RACK
  LOSS
  ADJUST
  DEPLETE
  BOTTLE
  CORRECTION
  // Phase 3 cellar operations (added in a dedicated enum-only migration — Postgres
  // ALTER TYPE ... ADD VALUE can't be used in the same migration that adds it).
  ADDITION
  TOPPING
  FINING
  FILTRATION
  CAP_MGMT
  // Phase 5: blend operation (originates a new child lot OR grows an existing lot) —
  // added in its own enum-only migration (Postgres ALTER TYPE ADD VALUE gotcha).
  BLEND
}

enum CaptureMethod {
  MANUAL
  VOICE
  SENSOR
  IMPORT
}

// A batch of wine with a durable identity (VISION §1–3). Vintage is an ATTRIBUTE, not
// part of identity (D3). Origin columns are provenance snapshots (no FK — the
// authoritative tuple lives in legacySnapshot for legacy lots). Provenance metadata is
// immutable after the first operation (enforced in the service layer).
model Lot {
  id               String   @id @default(cuid())
  code             String   @unique
  form             LotForm  @default(WINE)
  originVineyardId String?
  originBlockId    String?
  originSubblockId String?
  originVarietyId  String?
  vintageYear      Int?
  status           String   @default("ACTIVE") // ACTIVE | DEPLETED | ARCHIVED | CORRECTED
  isLegacy         Boolean  @default(false)
  // Phase 5: false when this lot's source-vineyard set may be incomplete (a blend with a
  // parent of unknown provenance). Contagious: a blend with any incomplete parent is itself
  // incomplete (council C6). Drives the "admin-only-visible" NULL-source bucket.
  provenanceComplete Boolean @default(true)
  legacySnapshot   Json?
  sublotTag        String? // optional human variant tag in the lot code (experiments / differential picks)
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  operationLines  LotOperationLine[]
  vesselLots      VesselLot[]
  parentEdges     LotLineage[]       @relation("LotChild") // edges where this lot is the child
  childEdges      LotLineage[]       @relation("LotParent") // edges where this lot is the parent
  bottlingSources BottlingSource[]
  treatments      LotTreatment[]
  // Phase 4 standalone chemistry/tasting/sample records (NOT ledger ops).
  analysisPanels  AnalysisPanel[]
  tastingNotes    LotTastingNote[]
  samples         Sample[]
  // Phase 5 blends.
  sourceVineyards      LotVineyard[]          // the lot's source-vineyard SET (union over lineage at blend)
  blendTrialComponents BlendTrialComponent[]  // bench-trial component rows referencing this lot
  promotedFromTrials   BlendTrial[]           @relation("TrialPromotedLot") // trials promoted into this lot

  @@index([status])
  @@index([originVineyardId])
  @@map("lot")
}

// One immutable ledger event. The autoincrement `id` IS the monotonic fold order
// (deterministic ordering; `observedAt` can collide / drift — D14). `correctsOperationId`
// is unique so any op can be corrected at most once (kills the double-correction race).
model LotOperation {
  id                  Int           @id @default(autoincrement())
  type                OperationType
  observedAt          DateTime      @default(now())
  enteredAt           DateTime      @default(now())
  actorUserId         String?
  enteredBy           String // email snapshot (provenance)
  captureMethod       CaptureMethod @default(MANUAL)
  note                String?
  correctsOperationId Int?          @unique
  batchId             String? // Phase 3: groups the per-vessel ops of one group fan-out (D13)
  metadata            Json?
  createdAt           DateTime      @default(now())

  corrects         LotOperation?      @relation("OpCorrection", fields: [correctsOperationId], references: [id], onDelete: Restrict)
  correctedBy      LotOperation?      @relation("OpCorrection")
  lines            LotOperationLine[]
  vesselTransfer   VesselTransfer? // 1:1 derived read-model (FK lives on VesselTransfer)
  treatments       LotTreatment[]     @relation("TreatmentOperation") // detail rows this op created
  voidedTreatments LotTreatment[]     @relation("TreatmentVoid") // treatments this (CORRECTION) op voided

  @@index([type, observedAt])
  @@index([batchId])
  @@map("lot_operation")
}

// A signed volumetric line. `vesselId = null` is the external counter-account that
// keeps each operation balanced (seed-in, loss-out, bottle-out). `lotCode`/`vesselCode`
// are durable snapshots so history reads survive later renames/deletes.
model LotOperationLine {
  id          Int          @id @default(autoincrement())
  operationId Int
  lotId       String
  vesselId    String? // null = "outside the cellar"
  deltaL      Decimal      @db.Decimal(10, 2) // signed; CHECK(deltaL <> 0) in migration
  reason      String?
  lotCode     String
  vesselCode  String?
  operation   LotOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  lot         Lot          @relation(fields: [lotId], references: [id], onDelete: Restrict)
  vessel      Vessel?      @relation(fields: [vesselId], references: [id], onDelete: SetNull)

  @@index([operationId])
  @@index([lotId])
  @@index([vesselId])
  @@map("lot_operation_line")
}

// The materialized current-state projection: how much of one lot sits in one vessel.
// Always equals the fold of the ledger (INVARIANT #7). CHECK(volumeL > 0) in migration;
// a row at functional zero is deleted, never stored at 0.
model VesselLot {
  id        String   @id @default(cuid())
  vesselId  String
  lotId     String
  volumeL   Decimal  @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt
  vessel    Vessel   @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  lot       Lot      @relation(fields: [lotId], references: [id], onDelete: Restrict)

  @@unique([vesselId, lotId])
  @@index([lotId])
  @@map("vessel_lot")
}

// Parent→child lineage edges for splits/blends (structure-only in Phase 1; blends are
// Phase 5). `fraction` is the parent's share of the child where meaningful.
model LotLineage {
  id          String   @id @default(cuid())
  parentLotId String
  childLotId  String
  fraction    Decimal? @db.Decimal(6, 5)
  kind        String // SPLIT | BLEND | TRANSFORM
  createdAt   DateTime @default(now())
  parent      Lot      @relation("LotParent", fields: [parentLotId], references: [id], onDelete: Restrict)
  child       Lot      @relation("LotChild", fields: [childLotId], references: [id], onDelete: Cascade)

  @@unique([parentLotId, childLotId])
  @@index([childLotId])
  @@map("lot_lineage")
}

// ───────────────────────── Phase 5: blends, lineage source-set & RBAC ─────────────────────────

// A lot's source-vineyard SET. A single-origin lot has one row; a blend has the UNION of its
// parents' full sets (materialized at the BLEND write, inductively transitive — council C6).
// Populated at SEED from originVineyardId and backfilled for existing lots. The scoping/lens
// query is "lots whose source vineyard ∈ my set" → index on vineyardId.
model LotVineyard {
  id         String   @id @default(cuid())
  lotId      String
  vineyardId String
  createdAt  DateTime @default(now())
  lot        Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)
  vineyard   Vineyard @relation(fields: [vineyardId], references: [id], onDelete: Restrict)

  @@unique([lotId, vineyardId])
  @@index([vineyardId])
  @@map("lot_vineyard")
}

// D9 RBAC: a user's vineyard MEMBERSHIP set, replacing the single User.assignedVineyardId.
// A manager can manage N vineyards; a blended lot spans many. Added here (dual-read);
// assignedVineyardId is dropped in Unit 3 after the backfill is verified.
model UserVineyard {
  id         String   @id @default(cuid())
  userId     String
  vineyardId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vineyard   Vineyard @relation(fields: [vineyardId], references: [id], onDelete: Cascade)

  @@unique([userId, vineyardId])
  @@index([vineyardId])
  @@map("user_vineyard")
}

enum BlendTrialStatus {
  DRAFT
  CHOSEN
  PROMOTED
  DISCARDED
}

// An OFF-LEDGER bench trial — a throwaway small-scale blend experiment (component lots +
// proportions/volumes + a tasting outcome). Zero ledger impact until PROMOTED, when the chosen
// ratios prefill the blend builder and a real BLEND op runs (promotedToLotId links the result).
// Reuses the Phase 4 tasting enums. CHECK (score-with-scale together-or-neither) in migration.
model BlendTrial {
  id              String                @id @default(cuid())
  name            String
  targetWine      String? // intent — what this trial aims at; groups DRAFTs (council S9)
  note            String?
  baseVolume      Decimal?              @db.Decimal(12, 3) // bench base size
  baseUnit        String? // mL | L (validated in code)
  status          BlendTrialStatus      @default(DRAFT)
  score           Int?
  scoreScale      TastingScoreScale?
  readiness       TastingReadiness?
  tastingNotes    String?
  chosenAt        DateTime?
  promotedToLotId String?
  enteredAt       DateTime              @default(now())
  enteredById     String? // actor id snapshot (no FK; matches LotOperation.actorUserId)
  enteredByEmail  String // durable provenance snapshot
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  components      BlendTrialComponent[]
  promotedToLot   Lot?                  @relation("TrialPromotedLot", fields: [promotedToLotId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([promotedToLotId])
  @@map("blend_trial")
}

// One component of a bench trial: a lot + its share (proportion ∈ (0,1]) or absolute volume.
// CHECK (proportion ∈ (0,1]) in migration.
model BlendTrialComponent {
  id         String     @id @default(cuid())
  trialId    String
  lotId      String
  proportion Decimal?   @db.Decimal(6, 5) // share of the base, (0,1]
  volume     Decimal?   @db.Decimal(12, 3)
  unit       String? // mL | L
  createdAt  DateTime   @default(now())
  trial      BlendTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)
  lot        Lot        @relation(fields: [lotId], references: [id], onDelete: Restrict)

  @@unique([trialId, lotId])
  @@index([lotId])
  @@map("blend_trial_component")
}

// ───────────────────────── Cellar operations (Phase 3) ─────────────────────────
// Detail rows for cellar operations that ride ON TOP of a LotOperation. A
// volume-NEUTRAL op (addition, fining, cap management) is a LotOperation with NO
// volumetric lines + one of these treatment rows; a volume-CHANGING op (filtration,
// loss, topping) carries lines AND, where it has material/medium detail, a treatment.
// The lot timeline UNIONs lot_operation_line.lotId with lot_treatment.lotId so neutral
// ops still appear. Material/rate/total + the volume SNAPSHOT used are stored, never
// recomputed (VISION D14). Corrected/voided via voidedByOperationId (stays visible).
model LotTreatment {
  id                  String   @id @default(cuid())
  operationId         Int
  lotId               String
  vesselId            String? // the vessel the op happened in (snapshot context)
  kind                String // ADDITION | FINING | FILTRATION | PUMPOVER | PUNCHDOWN
  materialId          String? // optional catalog link
  materialName        String? // durable snapshot of the material name
  rateValue           Decimal? @db.Decimal(12, 4)
  rateBasis           String? // G_HL | MG_L | G_L | ML_L (validated in code, not a DB enum)
  computedTotal       Decimal? @db.Decimal(12, 3)
  computedUnit        String? // g | mL
  volumeLAtAddition   Decimal? @db.Decimal(10, 2) // vessel volume used for the math (snapshot)
  durationMin         Int? // cap management duration
  medium              String? // filtration medium (e.g. "pad", "membrane")
  micron              Decimal? @db.Decimal(8, 2) // filtration nominal micron
  note                String?
  voidedByOperationId Int? // set when a CORRECTION op voids this treatment (D6/D15)
  createdAt           DateTime @default(now())

  operation LotOperation    @relation("TreatmentOperation", fields: [operationId], references: [id], onDelete: Cascade)
  voidedBy  LotOperation?   @relation("TreatmentVoid", fields: [voidedByOperationId], references: [id], onDelete: SetNull)
  lot       Lot             @relation(fields: [lotId], references: [id], onDelete: Restrict)
  vessel    Vessel?         @relation(fields: [vesselId], references: [id], onDelete: SetNull)
  material  CellarMaterial? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([lotId])
  @@index([operationId])
  @@index([vesselId])
  @@map("lot_treatment")
}

// Light material catalog (SO₂, nutrients, acids, tannins, fining agents) upserted on
// first use, deduped by normalizedKey within a kind (mirrors FieldInput). Carries a
// default dose basis + optional %active; cost/inventory is deferred to Phase 8.
model CellarMaterial {
  id            String         @id @default(cuid())
  name          String // display label
  normalizedKey String // dedup key (strip-non-alphanumeric, UPPERCASE)
  kind          String // SO2 | NUTRIENT | ACID | TANNIN | FINING | ENZYME | OTHER
  defaultBasis  String? // G_HL | MG_L | G_L | ML_L
  percentActive Decimal?       @db.Decimal(6, 3) // %active (material property, not a dose basis)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  treatments    LotTreatment[]

  @@unique([kind, normalizedKey])
  @@map("cellar_material")
}

// A named set of vessels (e.g. a barrel group) so one operation can fan out to its
// members (D13). Structure-only in Phase 1; the fan-out UI/logic lands in Phase 3.
model VesselGroup {
  id        String              @id @default(cuid())
  name      String              @unique
  note      String?
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  members   VesselGroupMember[]

  @@map("vessel_group")
}

model VesselGroupMember {
  id       String      @id @default(cuid())
  groupId  String
  vesselId String
  group    VesselGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  vessel   Vessel      @relation(fields: [vesselId], references: [id], onDelete: Cascade)

  @@unique([groupId, vesselId])
  @@index([vesselId])
  @@map("vessel_group_member")
}

// ───────────────────────── Chemistry / tasting / samples (Phase 4) ─────────────────────────
// STANDALONE records (NOT ledger ops — they describe the liquid, they don't move liters, so
// they do NOT go through writeLotOperation). They take BrixLog's standalone + inline-provenance
// shape and LotTreatment's appears-on-the-lot-timeline behavior. Each attaches to exactly ONE
// homogeneous lot (VISION D2). Undo is a soft-delete (voidedAt/voidedById), never a CORRECTION.
// Surfaced on the lot timeline by UNIONing these onto the loader, slotted by observedAt. Do NOT
// touch the vineyard BrixLog — cellar chemistry is lot/vessel-scoped and a separate domain.
//
// Provenance: actor ids are plain String? (no User FK relation) matching LotOperation.actorUserId
// and BrixLog.createdById; *ByEmail is the durable snapshot.

enum SampleStatus {
  PULLED
  SENT
  PENDING
  RESULT_RETURNED
  ATTACHED
  CANCELLED
}

enum TastingReadiness {
  NEEDS_MORE_TIME
  READY_TO_BLEND
  READY_TO_BOTTLE
  HOLD
  DECLINING
}

enum TastingScoreScale {
  HUNDRED_POINT
  TWENTY_POINT
}

// A panel HEADER groups one batch of readings observed together (a bench reading is a
// 1-child panel). The header owns observedAt + provenance + the optional sample link +
// voidedAt (so a panel voids ATOMICALLY — void the header, all readings drop). A returned
// lab result is a panel with `sampleId` set. SO₂ pairing happens WITHIN one panel only.
model AnalysisPanel {
  id              String           @id @default(cuid())
  lotId           String
  vesselId        String? // snapshot context (the vessel the lot sat in when measured)
  sampleId        String? // set when this panel is a returned result for a Sample
  observedAt      DateTime // when the wine was sampled/measured (time axis for trends)
  enteredAt       DateTime         @default(now())
  enteredById     String? // actor id snapshot (no FK; matches LotOperation.actorUserId)
  enteredByEmail  String // durable provenance snapshot
  captureMethod   CaptureMethod    @default(MANUAL)
  note            String?
  clientRequestId String?          @unique // idempotency: a double-submit is a no-op
  voidedAt        DateTime?
  voidedById      String?
  createdAt       DateTime         @default(now())
  lot             Lot              @relation(fields: [lotId], references: [id], onDelete: Restrict)
  vessel          Vessel?          @relation(fields: [vesselId], references: [id], onDelete: SetNull)
  sample          Sample?          @relation(fields: [sampleId], references: [id], onDelete: SetNull)
  readings        AnalysisReading[]

  @@index([lotId, observedAt])
  @@index([vesselId])
  @@index([sampleId])
  @@map("analysis_panel")
}

// One analyte reading inside a panel. `analyte` is a code-validated string (the TS registry
// in src/lib/chemistry/analytes.ts — a new analyte is a config edit, not a migration). Trends
// query readings by `analyte` joined to the non-voided parent panel; the panel's `observedAt`
// is the time axis.
model AnalysisReading {
  id        String        @id @default(cuid())
  panelId   String
  analyte   String // registry key (PH, FREE_SO2, …) — validated in code, not a DB enum
  value     Decimal       @db.Decimal(12, 4)
  unit      String // the unit the value was entered in (registry-allowed)
  createdAt DateTime      @default(now())
  panel     AnalysisPanel @relation(fields: [panelId], references: [id], onDelete: Cascade)

  @@index([panelId])
  @@index([analyte])
  @@map("analysis_reading")
}

// A structured tasting note on a lot. Free-text search (NICE) is a `contains` over
// notes/aroma/flavor — no tsvector this phase (avoids the search_vector migration gotcha).
model LotTastingNote {
  id              String             @id @default(cuid())
  lotId           String
  vesselId        String?
  observedAt      DateTime
  enteredAt       DateTime           @default(now())
  enteredById     String?
  enteredByEmail  String
  captureMethod   CaptureMethod      @default(MANUAL)
  appearance      String?
  aroma           String?
  flavor          String?
  tannin          Int? // 1–5 structure scores
  acidity         Int?
  body            Int?
  finish          Int?
  score           Int?
  scoreScale      TastingScoreScale?
  readiness       TastingReadiness?
  notes           String?
  clientRequestId String?            @unique
  voidedAt        DateTime?
  voidedById      String?
  createdAt       DateTime           @default(now())
  lot             Lot                @relation(fields: [lotId], references: [id], onDelete: Restrict)
  vessel          Vessel?            @relation(fields: [vesselId], references: [id], onDelete: SetNull)

  @@index([lotId, observedAt])
  @@map("lot_tasting_note")
}

// A lab/bench sample with a lifecycle (PULLED → SENT → PENDING → RESULT_RETURNED → ATTACHED,
// plus CANCELLED). 1→many AnalysisPanel: a returned result is a panel linked here. Transitions
// go through guarded core fns that set status + the matching timestamp together. The sample's
// `lotId` is captured AT PULL and inherited by its result panels (never re-resolved from the
// current vessel — backdated/late-resulted readings must not be misattributed). D2.
model Sample {
  id              String          @id @default(cuid())
  lotId           String
  vesselId        String?
  status          SampleStatus    @default(PULLED)
  source          String? // free text, e.g. "Barrel A3"
  lab             String? // outside lab name (e.g. "ETS")
  pulledAt        DateTime        @default(now()) // the sample's observed time
  sentAt          DateTime?
  expectedAt      DateTime?
  resultedAt      DateTime? // when the lab ran it (metadata, not the reading's observed time)
  attachedAt      DateTime?
  cancelledAt     DateTime?
  enteredById     String?
  enteredByEmail  String
  captureMethod   CaptureMethod   @default(MANUAL)
  note            String?
  clientRequestId String?         @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lot             Lot             @relation(fields: [lotId], references: [id], onDelete: Restrict)
  vessel          Vessel?         @relation(fields: [vesselId], references: [id], onDelete: SetNull)
  panels          AnalysisPanel[]

  @@index([lotId, status])
  @@index([status])
  @@map("sample")
}
