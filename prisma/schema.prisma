  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([tenantId])
  @@map("audit_log")
}

// ───────────────────────── Assistant (chat) ─────────────────────────

// Single-use guard for the assistant's confirm-before-write flow. A write tool
// returns a signed, short-TTL proposal token; on confirm we insert the token's
// nonce here (unique) BEFORE committing, so a replayed/double-submitted confirm
// can never double-apply a change (critical for inventory deltas).
model AssistantConfirmation {
  tenantId   String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id         String   @id @default(cuid())
  nonce      String   @unique
  tool       String
  actorEmail String
  usedAt     DateTime @default(now())

  @@index([tenantId])
  @@map("assistant_confirmation")
}

// User feedback on assistant replies (thumbs up/down + optional "what was wrong").
// `conversation` snapshots the transcript so the feedback-fix agent has context.
// `status` tracks the improvement loop: NEW -> TRIAGED (agent opened a PR) -> ...
model AssistantFeedback {
  tenantId              String                   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id                    String                   @id @default(cuid())
  createdAt             DateTime                 @default(now())
  rating                String // "up" | "down"
  comment               String? // free-text "what was wrong" (UNTRUSTED input)
  conversation          Json // [{ role, content }] transcript for context
  conversationId        String?
  ratedMessageId        String?
  debugContext          Json?
  actorUserId           String?
  actorEmail            String
  status                String                   @default("NEW") // NEW | TRIAGED | RESOLVED | DISMISSED
  prUrl                 String?
  notes                 String?
  modeAtSubmission      FeedbackAutomationMode   @default(AGENTIC_FIX)
  automationStatus      FeedbackAutomationStatus @default(NOT_REQUESTED)
  severity              FeedbackSeverity?
  githubIssueUrl        String?
  githubRunUrl          String?
  planMarkdown          String?
  planTitle             String?
  planGeneratedAt       DateTime?
  resolvedAt            DateTime?
  resolvedByUserId      String?
  developerNotes        String?
  developerNotesVersion Int                      @default(1)
  triageClass           FeedbackTriageClass? // Plan 059: disposition assigned by the bug-triage goalie (null = untriaged)
  currentAutomationRunId String? // Plan 079: the run whose status this row mirrors (multiple runs can exist across clarification rounds)
  attachments           FeedbackAttachment[]
  linearLinks           FeedbackLinearLink[]
  automationRuns        AutomationRun[]          @relation("AssistantFeedbackAutomationRuns")
  clarifications        FeedbackClarification[]

  @@unique([tenantId, id])
  @@index([status, createdAt])
  @@index([conversationId])
  @@index([ratedMessageId])
  @@index([tenantId])
  @@index([tenantId, triageClass])
  @@index([tenantId, rating, createdAt, id])
  @@map("assistant_feedback")
}

model FeedbackTicket {
  tenantId              String                   @default("")
  id                    String                   @id @default(cuid())
  kind                  FeedbackTicketKind
  title                 String
  body                  String
  pageUrl               String?
  userAgent             String?
  debugContext          Json?
  actorUserId           String?
  actorEmail            String
  modeAtSubmission      FeedbackAutomationMode
  automationStatus      FeedbackAutomationStatus @default(NOT_REQUESTED)
  status                FeedbackItemStatus       @default(NEW)
  severity              FeedbackSeverity?
  githubIssueUrl        String?
  githubRunUrl          String?
  prUrl                 String?
  planMarkdown          String?
  planTitle             String?
  planGeneratedAt       DateTime?
  resolvedAt            DateTime?
  resolvedByUserId      String?
  developerNotes        String?
  developerNotesVersion Int                      @default(1)
  triageClass           FeedbackTriageClass? // Plan 059: disposition assigned by the bug-triage goalie (null = untriaged)
  currentAutomationRunId String? // Plan 079: the run whose status this row mirrors (multiple runs across clarification rounds)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  attachments           FeedbackAttachment[]
  linearLinks           FeedbackLinearLink[]
  automationRuns        AutomationRun[]          @relation("FeedbackTicketAutomationRuns")
  clarifications        FeedbackClarification[]

  @@unique([tenantId, id])
  @@index([tenantId, kind, status, createdAt])
  @@index([tenantId, severity, createdAt])
  @@index([tenantId, automationStatus, createdAt])
  @@index([tenantId, triageClass, createdAt])
  @@index([tenantId, createdAt, id])
  @@map("feedback_ticket")
}

model FeedbackAttachment {
  tenantId            String                          @default("")
  id                  String                          @id @default(cuid())
  ticketId            String?
  assistantFeedbackId String?
  filename            String
  contentType         String
  byteSize            Int
  width               Int?
  height              Int?
  sha256              String
  blobUrl             String
  annotatedBlobUrl    String?
  captureSource       FeedbackAttachmentCaptureSource
  createdAt           DateTime                        @default(now())
  ticket              FeedbackTicket?                 @relation(fields: [tenantId, ticketId], references: [tenantId, id], onDelete: Cascade)
  assistantFeedback   AssistantFeedback?              @relation(fields: [tenantId, assistantFeedbackId], references: [tenantId, id], onDelete: Cascade)

  @@index([tenantId, ticketId])
  @@index([tenantId, assistantFeedbackId])
  @@index([tenantId, createdAt])
  @@map("feedback_attachment")
}

model FeedbackLinearLink {
  tenantId            String             @default("")
  id                  String             @id @default(cuid())
  ticketId            String?
  assistantFeedbackId String?
  linearIssueKey      String
  linearIssueUrl      String
  linkedByUserId      String
  linkedAt            DateTime           @default(now())
