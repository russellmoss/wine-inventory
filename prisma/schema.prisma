}

model BottledInventory {
  tenantId     String   @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  ownerId            String? // Plan 093 Unit 2: owner-scope; nullable (Estate=NULL); maintained per Unit 4; composite FK -> owner(tenantId,id) in the migration (K11)
  id           String   @id @default(cuid())
  wineSkuId    String
  locationId   String
  totalBottles Int      @default(0)
  updatedAt    DateTime @updatedAt
  wineSku      WineSku  @relation(fields: [wineSkuId], references: [id], onDelete: Restrict)
  location     Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@unique([tenantId, wineSkuId, locationId])
  @@index([locationId])
  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@map("bottled_inventory")
}

// ───────────────────────── Finished goods (merch) ─────────────────────────

// Plan 080 U7 (council C4) — the PURCHASED-cost layer for finished goods. Append-only receipts; on-hand
// valuation is the WEIGHTED AVERAGE over them, never a mutable `unitCogs` column on the SKU (that would be a
// second source of truth with no history) and never last-cost (which whipsaws COGS).
//
// Scope is deliberately narrow: this covers 3rd-party / merchandise / externally-purchased wine only.
// INTERNALLY-BOTTLED wine keeps its specific-lot COGS from the frozen BottlingCostSnapshot and is NOT
// touched here (COST-3 — that snapshot is immutable). A library buy-back of your own wine IS a purchase and
// legitimately gets a receipt (council DQ1: lock only when the provenance is an internal bottling run).
//
// Exactly ONE of wineSkuId / finishedGoodId is set (CHECK-constrained). `unitCostBase` is ALWAYS the tenant
// base currency (COST-4); the foreign quintet mirrors SupplyLot as immutable audit provenance (IAS 21).
model FinishedGoodReceipt {
  tenantId            String    @default("")
  id                  String    @id @default(cuid())
  wineSkuId           String? // composite-tenant FK -> wine_sku(tenantId,id) (raw SQL, K11)
  finishedGoodId      String? // composite-tenant FK -> finished_good(tenantId,id) (raw SQL, K11)
  qty                 Int // units received on this receipt (> 0, CHECK-constrained)
  unitCostBase        Decimal   @db.Decimal(18, 8) // per unit, tenant BASE currency — the valuation basis
  currency            String    @default("USD") // the BASE currency stamp
  // Immutable foreign-invoice provenance (all null for a base-currency purchase) — audit only, never revalued.
  foreignUnitCost     Decimal?  @db.Decimal(18, 8)
  foreignCurrency     String?
  fxRate              Decimal?  @db.Decimal(18, 8)
  fxRateDate          DateTime?
  fxRateSource        String?
  locationId          String // where the units landed — composite-tenant FK -> location(tenantId,id)
  receivedAt          DateTime  @default(now())
  vendorId            String? // composite-tenant FK -> vendor(tenantId,id)
  sourceInvoiceLineId String? // provenance when this came from an invoice line (Wave 3 / U5)
  note                String?
  createdById         String?
  createdByEmail      String
  createdAt           DateTime  @default(now())

  @@unique([tenantId, id])
  @@index([tenantId])
  @@index([tenantId, wineSkuId, receivedAt]) // weighted-avg scan per SKU
  @@index([tenantId, finishedGoodId, receivedAt]) // weighted-avg scan per good
  @@index([tenantId, locationId])
  @@map("finished_good_receipt")
}

model FinishedGoodCategory {
  tenantId  String         @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id        String         @id @default(cuid())
  name      String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  goods     FinishedGood[]
  wineSkus  WineSku[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("finished_good_category")
}

model FinishedGood {
  tenantId       String                  @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id             String                  @id @default(cuid())
  name           String
  categoryId     String
  /// Plan 080 U7: list PRICE (see the note on WineSku.msrp — price, never cost).
  msrp           Decimal?                @db.Decimal(18, 2)
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  category       FinishedGoodCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  inventory      FinishedGoodInventory[]
  stockMovements StockMovement[]

  @@unique([tenantId, id]) // Plan 080 U7: composite-tenant-FK target for finished_good_receipt (K11)
  @@index([categoryId])
  @@index([tenantId])
  @@map("finished_good")
}

model FinishedGoodInventory {
  tenantId       String       @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id             String       @id @default(cuid())
  finishedGoodId String
  locationId     String
  quantity       Int          @default(0)
  updatedAt      DateTime     @updatedAt
  finishedGood   FinishedGood @relation(fields: [finishedGoodId], references: [id], onDelete: Restrict)
  location       Location     @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@unique([tenantId, finishedGoodId, locationId])
  @@index([locationId])
  @@index([tenantId])
  @@map("finished_good_inventory")
}

// ───────────────────────── Audit ─────────────────────────

model AuditLog {
  tenantId    String      @default("") // Phase 12 tenant scope (nullable U2 -> backfill U3 -> NOT NULL U5); FK+RLS at DB level
  id          String      @id @default(cuid())
