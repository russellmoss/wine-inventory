filters:
  and:
    - file.hasTag("parity")
    - 'file.ext == "md"'
    - 'file.folder != "docs/_templates"'

formulas:
  status_icon: 'if(status == "covered", "✅ covered", if(status == "partial", "🟨 partial", if(status == "deliberately-omitted", "⚪ omitted", "❌ gap")))'
  overlap_icon: 'if(overlap == "both", "⭐ both", if(overlap == "vintrace-only", "VT only", if(overlap == "innovint-only", "IV only", "—")))'
  edge: 'if(aiNativeEdge, aiNativeEdge, "—")'

properties:
  id:
    displayName: "ID"
  formula.status_icon:
    displayName: "Status"
  formula.overlap_icon:
    displayName: "Overlap"
  incumbent:
    displayName: "Incumbent"
  capability:
    displayName: "Capability"
  group:
    displayName: "Domain"
  ourApproach:
    displayName: "Our approach"
  formula.edge:
    displayName: "AI-native edge"
  evidence:
    displayName: "Evidence"
  counterpart:
    displayName: "Counterpart article"

views:
  - type: table
    name: "All (by status)"
    groupBy:
      property: status
      direction: ASC
    order:
      - formula.status_icon
      - formula.overlap_icon
      - incumbent
      - capability
      - group
      - ourApproach

  - type: table
    name: "⭐ Table stakes (both incumbents)"
    filters:
      and:
        - 'overlap == "both"'
    groupBy:
      property: status
      direction: ASC
    order:
      - formula.status_icon
      - capability
      - group
      - ourApproach
      - counterpart

  - type: table
    name: "⭐ Table stakes — our remaining gaps"
    filters:
      and:
        - 'overlap == "both"'
        - or:
            - 'status == "gap"'
            - 'status == "partial"'
    groupBy:
      property: group
      direction: ASC
    order:
      - formula.status_icon
      - capability
      - ourApproach

  - type: table
    name: "⚠ Gaps & partial"
    filters:
      or:
        - 'status == "gap"'
        - 'status == "partial"'
    groupBy:
      property: group
      direction: ASC
    order:
      - formula.status_icon
      - incumbent
      - capability
      - evidence

  - type: table
    name: "✅ Covered (AI-native edge)"
    filters:
      and:
        - 'status == "covered"'
    order:
      - capability
      - incumbent
      - formula.edge
      - evidence

  - type: table
    name: "By domain"
    groupBy:
      property: group
      direction: ASC
    order:
      - formula.status_icon
      - incumbent
      - capability

  - type: cards
    name: "Gallery"
    order:
      - capability
      - formula.status_icon
      - incumbent
