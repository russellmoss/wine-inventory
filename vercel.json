{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "ignoreCommand": "if [ \"$VERCEL_ENV\" = \"production\" ]; then exit 1; fi; case \"$VERCEL_GIT_COMMIT_REF\" in claude/*|feedback-bug/*) exit 0 ;; *) exit 1 ;; esac",
  "crons": [
    {
      "path": "/api/cron/compliance-reminders",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/accounting-token-refresh",
      "schedule": "15 13 * * *"
    },
    {
      "path": "/api/cron/accounting-post",
      "schedule": "30 13 * * *"
    },
    {
      "path": "/api/cron/accounting-reconcile",
      "schedule": "45 13 * * *"
    },
    {
      "path": "/api/cron/commerce7-poll",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/commerce7-inventory",
      "schedule": "15 14 * * *"
    },
    {
      "path": "/api/cron/qbo-vendor-poll",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/cron/qbo-vendor-sync",
      "schedule": "45 14 * * *"
    },
    {
      "path": "/api/cron/feedback-automation-sweep",
      "schedule": "0 15 * * *"
    }
  ]
}
