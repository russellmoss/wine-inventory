# Wine Inventory — environment template. Copy to .env and fill in.

# --- Database (Neon Postgres) ---
# DATABASE_URL = runtime pooled connection. Phase 12 multi-tenancy: at ACTIVATION this is
# repointed at the non-owner app_rls role (== DATABASE_URL_APP below) so Postgres RLS actually
# applies (the owner carries BYPASSRLS and silently bypasses RLS). DATABASE_URL_UNPOOLED stays
# the OWNER (direct) connection and is used ONLY for migrations (prisma migrate deploy).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.us-east-1.aws.neon.tech/wine_inventory?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.us-east-1.aws.neon.tech/wine_inventory?sslmode=require"
# Pooled connection AS the non-owner NOBYPASSRLS app_rls role. Written by
# scripts/setup-app-rls-credential.ts. Used by the isolation tests now; becomes the runtime
# DATABASE_URL (here + in Vercel) at activation once tenant-context plumbing is live.
DATABASE_URL_APP=

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Seed admin (prisma/seed.ts)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# --- Email (Brevo transactional API — free tier; powers password resets) ---
# Sender MUST be a verified sender in Brevo. Disable Brevo "Authorised IPs"
# (Security settings) — Vercel uses dynamic IPs and can't be allowlisted.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Bhutan Wine Inventory

# --- Compliance filing-deadline reminder cron (plan-027) ---
# Vercel Cron (vercel.json) hits /api/cron/compliance-reminders daily with
# `Authorization: Bearer $CRON_SECRET`. Set a long random value here AND in Vercel.
CRON_SECRET=

# --- Maps (Google Map Tiles API — satellite basemap) ---
# Optional. When set, the vineyard map uses Google satellite imagery (sharper +
# more current than the keyless Esri fallback). Needs a Google Cloud project with
# billing enabled and the "Map Tiles API" turned on. This key is exposed to the
# browser by design (like the Google Maps JS API) — restrict it to the Map Tiles
# API and your app's HTTP referrers in the Cloud Console. Unset = keyless Esri.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Photo storage (Vercel Blob) ---
# Field-note disease/pest photos upload here (src/app/api/field-notes/upload).
# Create a Blob store in the Vercel dashboard; this token is auto-injected on
# Vercel deploys. For local dev, copy it from the Vercel project's env. Unset =
# the upload route returns 503 and the form stays submittable text-only.
BLOB_READ_WRITE_TOKEN=

# --- AI / Council ---
# council-mcp reads GEMINI_API_KEY from the project-root .env (dotenv).
# Codex CLI uses its own auth (`codex login`) — no key needed here.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# --- Assistant voice mode ---
# Hands-free "talk to the assistant" mode (src/lib/voice, src/app/(app)/assistant/voice).
# Both directions use ElevenLabs on a SINGLE key: text-to-speech and speech-to-text
# (Scribe). Reuse the same ELEVENLABS_API_KEY from the horseplay project (.env there).
# Unset = the Talk button hides and the app stays text-only. Voice/model/tuning are
# optional overrides with sane low-latency defaults (see src/lib/voice/config.ts).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=
ELEVENLABS_STT_MODEL=
ELEVENLABS_STT_LANGUAGE=
ELEVENLABS_STABILITY=
ELEVENLABS_SIMILARITY_BOOST=

# --- QuickBooks Online accounting integration (Phase 15) ---
# Per-tenant OAuth2 to each winery's own QBO company. Build + test against the SANDBOX
# using the app's DEVELOPMENT keys (Keys & credentials → Development tab). Production keys
# are a SEPARATE pair, only for real companies after Intuit app-review — do NOT use them
# for dev/testing. QBO_ENVIRONMENT selects the API base (sandbox vs production).
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox
# Must match a Redirect URI registered on the app EXACTLY. localhost may use http.
QBO_REDIRECT_URI=http://localhost:3000/api/accounting/qbo/callback
# Token-at-rest encryption (Phase 15 SEC-C4): per-record data key wrapped by this KEK.
# 32-byte value, base64. Split sandbox vs prod. Never commit the real value.
APP_ENCRYPTION_KEK=

# --- Sentry (error monitoring — ROADMAP Phase 22) ---
# The DSN is a public value (it ships in the client bundle); safe to commit here.
# Same DSN is used client-side and server-side. Unset = Sentry is inert.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Build-time token for uploading source maps so prod stack traces are readable.
# Generate in Sentry → Settings → Auth Tokens. Set it in Vercel (Production +
# Preview); leave blank locally. Without it the build still succeeds, just with
# minified prod stack traces. Org/project are pinned in next.config.ts
# (bhutan-wine / javascript-nextjs).
SENTRY_AUTH_TOKEN=
