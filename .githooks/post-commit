#!/bin/sh
# ---------------------------------------------------------------------------
# Brain-freshness detector — deterministic, no LLM, NEVER blocks the commit.
#
# If this commit touched architecturally significant code, it prints a nudge
# that the docs "brain" (system-map + registers) may be stale. It does NOT
# edit any tracked files (no churn). The nightly GitHub Actions "brain-refresh"
# loop is what actually updates the docs and opens a PR; this is just the
# local heads-up so you know when a refresh is worth it.
#
# Installed via: git config core.hooksPath .githooks   (see docs/AUTOMATION.md)
# ---------------------------------------------------------------------------

significant='^(prisma/schema\.prisma|prisma/migrations/|src/lib/tenant/|src/lib/ledger/|src/lib/transform/|src/lib/cost/|src/lib/compliance/|src/lib/auth)'

changed=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null | grep -E "$significant")

if [ -n "$changed" ]; then
  printf '\n\033[33m⚠  brain may be stale\033[0m — this commit touched architecturally significant code:\n'
  echo "$changed" | sed 's/^/      /'
  printf '   → the nightly refresh will update docs/architecture/*, or ask Claude now: "refresh the brain".\n\n'
fi

# Invariant-guard check — warn (never block) if any invariant lost its guard.
# (An invariant whose verify: script was renamed/deleted = a live safety hole.)
if command -v node >/dev/null 2>&1 && [ -f scripts/verify-invariant-guards.mjs ]; then
  inv_out=$(node scripts/verify-invariant-guards.mjs 2>&1)
  if [ $? -ne 0 ]; then
    printf '\033[31m✗  invariant guard gap\033[0m — an invariant has no working guard:\n'
    echo "$inv_out" | grep -E 'MISSING|✗' | sed 's/^/      /'
    printf '   → run: npm run verify:invariants\n\n'
  fi
fi

# Tripwire check — warn (never block) if a tripwire lost its guard OR a `static`
# tripwire FIRED (a forbidden pattern like runAsSystem in src/app now appears).
if command -v node >/dev/null 2>&1 && [ -f scripts/verify-tripwire-guards.mjs ]; then
  trip_out=$(node scripts/verify-tripwire-guards.mjs 2>&1)
  if [ $? -ne 0 ]; then
    printf '\033[31m✗  tripwire gap / fired\033[0m — a tripwire is unguarded or its forbidden pattern appeared:\n'
    echo "$trip_out" | grep -E 'MISSING|FIRED|✗|•' | sed 's/^/      /'
    printf '   → run: npm run verify:tripwires\n\n'
  fi
fi

# Parity check — warn (never block) if a status:covered parity note's evidence path
# went stale (a "we cover this" claim that no longer points at real code).
if command -v node >/dev/null 2>&1 && [ -f scripts/verify-parity-guards.mjs ]; then
  par_out=$(node scripts/verify-parity-guards.mjs 2>&1)
  if [ $? -ne 0 ]; then
    printf '\033[31m✗  parity gap\033[0m — a covered capability lost its evidence:\n'
    echo "$par_out" | grep -E 'MISSING|✗|•' | sed 's/^/      /'
    printf '   → run: npm run verify:parity\n\n'
  fi
fi

exit 0
