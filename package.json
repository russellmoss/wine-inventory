    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:field-inputs": "tsx prisma/seed-field-inputs.ts",
    "seed:demo-tenant": "tsx --env-file=.env scripts/seed-demo-tenant.ts",
    "seed:demo-scenario": "tsx --conditions=react-server --env-file=.env scripts/seed-demo-scenario.ts",
    "seed:demo-accounting": "tsx --conditions=react-server --env-file=.env scripts/seed-demo-accounting.ts",
    "seed:work-order-templates": "tsx --conditions=react-server --env-file=.env scripts/seed-work-order-templates.ts",
