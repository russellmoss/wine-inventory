    "verify:accounting-refresh": "tsx --conditions=react-server --env-file=.env scripts/verify-accounting-refresh.ts",
    "verify:accounting-reversal": "tsx --conditions=react-server scripts/verify-accounting-reversal.ts",
    "verify:accounting-idempotency": "tsx --conditions=react-server --env-file=.env scripts/verify-accounting-idempotency.ts",
    "verify:accounting": "tsx --conditions=react-server --env-file=.env scripts/verify-accounting.ts",
    "verify:commerce7-idempotency": "tsx --conditions=react-server --env-file=.env scripts/verify-commerce7-idempotency.ts",
