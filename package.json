    "qa:e2e:report": "playwright show-report",
    "eval:assistant": "vitest run test/evals/assistant-tools.eval.test.ts",
    "calibrate:ttb": "tsx scripts/calibrate-ttb-fields.ts",
    "postinstall": "prisma generate"
