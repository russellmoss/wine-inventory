{
  "name": "wine-inventory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:field-inputs": "tsx prisma/seed-field-inputs.ts",
    "verify:chemistry": "tsx --conditions=react-server --env-file=.env scripts/verify-chemistry.ts",
    "verify:reverse": "tsx --env-file=.env scripts/verify-reverse.ts",
    "verify:reverse-transform": "tsx --env-file=.env scripts/verify-reverse-transform.ts",
  "verify:ttb": "tsx --conditions=react-server --env-file=.env scripts/verify-ttb.ts",
    "verify:excise": "tsx --conditions=react-server --env-file=.env scripts/verify-excise.ts",
    "verify:cost": "tsx --conditions=react-server --env-file=.env scripts/verify-cost.ts",
  "calibrate:ttb": "tsx scripts/calibrate-ttb-fields.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@geoman-io/leaflet-geoman-free": "^2.20.0",
    "@mapbox/shp-write": "^0.4.3",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.3",
    "@vercel/blob": "^2.4.1",
    "better-auth": "^1.6.18",
    "dexie": "^4.4.4",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "next": "16.2.9",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.3.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
