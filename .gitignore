# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# rstack / claude ephemeral worktrees (never commit)
.claude/worktrees/

# Prisma generated client (if output is set inside src)
/src/generated/prisma

.vercel

# Design-system reference kit (not part of the app build)
design-system/

# Local MCP server config (machine-specific paths / credentials refs)
.mcp.json

# Obsidian: commit the SHARED vault config (app.json, core-plugins.json, daily-notes.json —
# they hold the ignore filters + note routing); ignore machine-specific state.
.obsidian/workspace*
.obsidian/appearance.json
.obsidian/graph.json
.obsidian/cache
.obsidian/hotkeys.json

# Personal Obsidian scratch (daily/new notes): keep the folder (routing target) but not its
# contents — daily notes are personal, not app content.
/docs/_notes/*
!/docs/_notes/.gitkeep

# Stray inventory exports (not part of the app)
/Inventory - Sheet1.csv

# Playwright e2e QA (Phase 15)
test-results/
playwright-report/
test/e2e/.auth/

# rstack / gstack agent toolchain state + local health-* skills/workflows (kept local, not versioned here)
.rstack/
.gstack/
.claude/workflows/*
.claude/skills/health-check/
.claude/skills/health-remediate/
# ...except /bug-triage, which IS versioned here so the team shares one copy.
# (Pattern above must be `workflows/*`, not `workflows/`: git cannot re-include a
# file whose parent directory is itself excluded.)
!.claude/workflows/bug-triage.js

# vintrace docs corpus: keep the Markdown, ignore the raw API dumps
vintrace-docs/_raw/

# innovint docs corpus: keep the Markdown, ignore the raw page HTML
innovint-docs/_raw/

# AI agent tool dirs (Codex/agents scratch — never commit)
.agents/
.codex/

# Generated pronunciation listening-pass audio (plan 091) — never commit
pronunciation-sample*.mp3
